@model IEnumerable<QLSanPickleball_65132651.Models.SAN>

@{
    bool isAdmin = (Session["Role"] != null && Session["Role"].ToString() != "KhachHang");
    Layout = isAdmin ? "~/Views/Shared/_LayoutAdmin.cshtml" : "~/Views/Shared/_LayoutKhachHang.cshtml";

    var danhSachLoai = ViewBag.MaLoaiSan as List<QLSanPickleball_65132651.Models.LOAISAN>;
    ViewBag.Title = "Trang chủ - Army Pickleball";
}

<style>
    html {
        scroll-behavior: smooth;
    }
    /* HERO BANNER */
    .hero-banner {
        position: relative;
        overflow: hidden;
        padding: 45px 60px;
        border-radius: 36px;
        background: linear-gradient( 135deg, #0f172a, #14532d, #16a34a );
        box-shadow: 0 25px 60px rgba(0,0,0,0.18);
        transition: all 0.5s ease;
    }

        /* Hover Gradient Animation */
        .hero-banner::before {
            content: "";
            position: absolute;
            inset: -2px;
            background: linear-gradient( 130deg, rgba(255,255,255,0.15), transparent, rgba(255,255,255,0.08) );
            opacity: 0;
            transition: 0.5s;
        }

        .hero-banner:hover::before {
            opacity: 1;
        }

    /* Glow */
    .hero-glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.35;
    }

    .hero-glow-1 {
        width: 250px;
        height: 250px;
        background: #22c55e;
        top: -60px;
        right: -60px;
        animation: floatGlow 6s ease-in-out infinite;
    }

    .hero-glow-2 {
        width: 180px;
        height: 180px;
        background: #84cc16;
        bottom: -40px;
        left: -40px;
        animation: floatGlow 8s ease-in-out infinite;
    }

    /* Content */
    .hero-content {
        position: relative;
        z-index: 2;
    }

    /* Badge */
    .hero-badge {
        display: inline-flex;
        align-items: center;
        padding: 10px 18px;
        margin-bottom: 24px;
        border-radius: 999px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.15);
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
        backdrop-filter: blur(10px);
    }

    /* Title */
    .hero-title {
        font-size: 3.4rem;
        font-weight: 800;
        line-height: 1.15;
        color: white;
        margin-bottom: 22px;
    }

        .hero-title span {
            color: #bef264;
            position: relative;
        }

    /* Description */
    .hero-desc {
        color: rgba(255,255,255,0.8);
        font-size: 1.05rem;
        line-height: 1.8;
        max-width: 620px;
        margin-bottom: 30px;
    }

    /* Buttons */
    .hero-btn-main {
        padding: 14px 26px;
        border-radius: 16px;
        background: white;
        color: #166534;
        font-weight: 700;
        border: none;
        transition: all 0.3s ease;
    }

        .hero-btn-main:hover {
            transform: translateY(-3px);
            background: #bef264;
            color: #14532d;
            box-shadow: 0 15px 30px rgba(190,242,100,0.25);
        }

    /* Outline Button */
    .hero-btn-outline {
        padding: 14px 26px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.25);
        color: white;
        font-weight: 700;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
    }

        .hero-btn-outline:hover {
            background: rgba(255,255,255,0.12);
            color: white;
            transform: translateY(-3px);
        }

    /* Stats */
    .hero-stats {
        display: flex;
        gap: 45px;
        margin-top: 45px;
    }

    .hero-stat-item h3 {
        color: white;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .hero-stat-item span {
        color: rgba(255,255,255,0.7);
        font-size: 0.92rem;
    }

    /* Image */
    .hero-image-wrapper {
        position: relative;
        z-index: 2;
    }

    .hero-image {
        width: 100%;
        border-radius: 30px;
        transform: rotate(-2deg);
        transition: 0.5s ease;
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }

    .hero-banner:hover .hero-image {
        transform: rotate(0deg) scale(1.03);
    }

    /* Floating Cards */
    .floating-card {
        position: absolute;
        padding: 12px 18px;
        border-radius: 18px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(14px);
        color: white;
        font-weight: 700;
        border: 1px solid rgba(255,255,255,0.18);
        z-index: 5;
        animation: floatCard 4s ease-in-out infinite;
    }

    .card-1 {
        top: -15px;
        left: -20px;
    }

    .card-2 {
        bottom: 20px;
        right: -15px;
        animation-delay: 1.5s;
    }

    /* Animations */
    @@keyframes floatCard {
        0%,100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    @@keyframes floatGlow {
        0%,100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.15);
        }
    }

    /* Responsive */
    @@media(max-width: 992px) {

        .hero-banner {
            padding: 45px 30px;
        }

        .hero-title {
            font-size: 2.4rem;
        }

        .hero-stats {
            gap: 20px;
            flex-wrap: wrap;
        }
    }

    .feature-box {
        padding: 40px 30px;
        background: #fff;
        border-radius: 24px;
        text-align: center;
        transition: 0.3s;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        height: 100%;
        border: 1px solid #edf2ef;
    }

        .feature-box:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(34,197,94,0.1);
            border-color: #a4eb5d;
        }

    .icon-wrapper {
        width: 80px;
        height: 80px;
        background: #eef8f1;
        color: #16a34a;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin-bottom: 20px;
    }
</style>

<div class="container py-5">
    @if (!isAdmin)
    {
        <div class="hero-banner mb-5">

            <!-- Background Glow -->
            <div class="hero-glow hero-glow-1"></div>
            <div class="hero-glow hero-glow-2"></div>

            <div class="row align-items-center">

                <!-- Left Content -->
                <div class="col-lg-7">
                    <div class="hero-content">

                        <span class="hero-badge">
                            <i class="fas fa-fire me-2"></i>
                            Hệ thống đặt sân hiện đại
                        </span>

                        <h1 class="hero-title">
                            Trải nghiệm
                            <span>Pickleball</span>
                            đẳng cấp tại Army
                        </h1>

                        <p class="hero-desc">
                            Đặt sân nhanh chóng, giao diện hiện đại,
                            sân chất lượng cao cùng trải nghiệm chuyên nghiệp.
                        </p>

                        <div class="d-flex gap-3 flex-wrap">
                            <a href="@Url.Action("ChonHinhThucDat", "DatSan65132651")"
                               class="btn hero-btn-main">
                                <i class="fas fa-calendar-check me-2"></i>
                                Đặt sân ngay
                            </a>
                        </div>

                        <!-- Stats -->
                        <div class="hero-stats">

                            <div class="hero-stat-item">
                                <h3>20+</h3>
                                <span>Sân hiện đại</span>
                            </div>

                            <div class="hero-stat-item">
                                <h3>5K+</h3>
                                <span>Khách hàng</span>
                            </div>

                            <div class="hero-stat-item">
                                <h3>4.9★</h3>
                                <span>Đánh giá</span>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- Right -->
                <div class="col-lg-5 d-none d-lg-block">

                    <div class="hero-image-wrapper">

                        <div class="floating-card card-1">
                            <i class="fas fa-trophy"></i>
                            Sân VIP
                        </div>

                        <div class="floating-card card-2">
                            <i class="fas fa-bolt"></i>
                            Booking nhanh
                        </div>

                        <img src="~/Content/Images/anhsan.jpg"
                             class="hero-image"
                             alt="Banner">

                    </div>

                </div>

            </div>
        </div>

        <div class="text-center mb-5 mt-5 pt-4">
            <h6 class="text-success fw-bold text-uppercase tracking-wider">Về Army Pickleball</h6>
            <h2 class="fw-bold mb-3" style="color: #0f172a;">Tiên Phong Chất Lượng & Dịch Vụ</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">Hệ thống sân tập quy mô lớn, đáp ứng mọi nhu cầu từ người mới bắt đầu đến vận động viên chuyên nghiệp.</p>
        </div>

        <div class="row g-4 mb-5 pb-4">
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="icon-wrapper"><i class="fas fa-layer-group"></i></div>
                    <h5 class="fw-bold">Mặt Sân Chuẩn Quốc Tế</h5>
                    <p class="text-muted small">Được thi công bằng vật liệu cao cấp, độ ma sát hoàn hảo, bảo vệ xương khớp cho người chơi.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="icon-wrapper"><i class="fas fa-lightbulb"></i></div>
                    <h5 class="fw-bold">Chiếu Sáng Đỉnh Cao</h5>
                    <p class="text-muted small">Dàn đèn LED chống chói phân bổ đều, đảm bảo tầm nhìn hoàn hảo cho các trận đấu buổi tối.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="icon-wrapper"><i class="fas fa-mobile-alt"></i></div>
                    <h5 class="fw-bold">Đặt Sân Thông Minh</h5>
                    <p class="text-muted small">Kiểm tra lịch trống, chọn sân và thanh toán trực tuyến dễ dàng chỉ trong 3 bước.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="p-5 bg-white rounded-4 shadow-sm text-center">
            <i class="fas fa-user-cog fs-1 text-success mb-3"></i>
            <h3>Quản trị viên: @Session["TenUser"]</h3>
            <p>Vui lòng sử dụng thanh menu Admin để quản lý sân và doanh thu.</p>
        </div>
    }
</div>
