@model IEnumerable<QLSanPickleball_65132651.Models.SAN>

@{
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";
    var dsPhieu = ViewBag.DanhSachPhieu as List<QLSanPickleball_65132651.Models.PHIEUDATSAN>;
    DateTime ngayDat = ViewBag.NgayDat;
    ViewBag.Title = "Đặt lịch ngày trực quan";
}

<style>
    body {
        background-color: #f4f7f6;
    }

    .booking-top-bar {
        background: #1e5631;
        border-radius: 20px 20px 0 0;
        padding: 25px 30px;
        color: white;
    }

    .legend-container {
        display: flex;
        gap: 20px;
        align-items: center;
        background: #eefbf2;
        padding: 12px 30px;
        border-bottom: 2px solid #e2e8f0;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        color: #333;
    }

    .legend-box {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        border: 1px solid rgba(0,0,0,0.1);
    }

    /* =========================
       BẢNG LỊCH
    ========================== */

    .schedule-container {
        background: white;
        border-radius: 0 0 20px 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        overflow-x: auto;
        padding-bottom: 20px;
    }

    /* 1 cột sân + 33 ô thời gian */
    .schedule-grid {
        display: grid;
        grid-template-columns: 180px repeat(33, minmax(110px, 1fr));
        min-width: 3900px;
    }

    .time-header-row {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .time-cell {
        padding: 10px 5px;
        text-align: center;
        font-weight: 700;
        color: #475569;
        border-right: 1px solid #e2e8f0;
        font-size: 0.75rem;
        white-space: nowrap;
    }

    .court-header {
        background: white;
        padding: 15px;
        font-weight: 800;
        color: #1e5631;
        border-right: 2px solid #e2e8f0;
        border-bottom: 1px solid #e2e8f0;
        position: sticky;
        left: 0;
        z-index: 5;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .court-header small {
            font-size: 0.75rem;
            color: #64748b;
            font-weight: 500;
        }

    /* =========================
       SLOT
    ========================== */

    .slot {
        height: 60px;
        border-right: 1px solid #e2e8f0;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        transition: all 0.2s;
        position: relative;
        user-select: none;
    }

    .slot-empty {
        background: white;
        color: transparent;
        cursor: pointer;
    }

        .slot-empty:hover {
            background: #eefbf2;
            color: #16a34a;
            box-shadow: inset 0 0 0 2px #22c55e;
        }

    .slot-booked {
        background: #ff4d4f;
        color: white;
        cursor: not-allowed;
    }

    .slot-maintenance {
        background: #a0aec0;
        color: white;
        cursor: not-allowed;
    }

    .slot-selected {
        background: #16a34a !important;
        color: white !important;
        box-shadow: 0 5px 15px rgba(22, 163, 74, 0.4);
        transform: scale(0.92);
        border-radius: 8px;
        z-index: 2;
    }

    /* =========================
       SIDEBAR
    ========================== */

    .summary-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        position: sticky;
        top: 20px;
    }

    .selection-list {
        max-height: 250px;
        overflow-y: auto;
        margin-bottom: 15px;
    }

    .selection-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 12px;
        border-radius: 12px;
        margin-bottom: 10px;
    }

    .btn-next {
        background: #eab308;
        color: white;
        font-weight: 800;
        font-size: 1.1rem;
        padding: 15px;
        border-radius: 12px;
        border: none;
        width: 100%;
        transition: 0.3s;
    }

        .btn-next:hover {
            background: #ca8a04;
            transform: translateY(-2px);
        }
</style>

<div class="container-fluid px-4 py-5">
    <div class="row g-4">

        <!-- LEFT -->
        <div class="col-xl-9">

            <div class="booking-top-bar d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="fw-bold mb-1">
                        <i class="fas fa-calendar-alt me-2"></i>
                        Đặt lịch ngày / Sự kiện
                    </h3>

                    <p class="mb-0 opacity-75">
                        Mỗi ô tương ứng 30 phút.
                    </p>
                </div>

                <div class="d-flex gap-2">
                    <input type="date"
                           id="ngayDat"
                           value="@ngayDat.ToString("yyyy-MM-dd")"
                           class="form-control fw-bold border-0 shadow-sm"
                           style="width: 180px; height: 45px;">

                    <button class="btn btn-warning fw-bold px-4 shadow-sm"
                            onclick="locNgay()">
                        TẢI LẠI
                    </button>
                </div>
            </div>

            <div class="legend-container">
                <div class="legend-item">
                    <div class="legend-box" style="background:white;"></div>
                    Trống
                </div>

                <div class="legend-item">
                    <div class="legend-box"
                         style="background:#16a34a;border-color:#16a34a;"></div>
                    Đang chọn
                </div>

                <div class="legend-item">
                    <div class="legend-box"
                         style="background:#ff4d4f;border-color:#ff4d4f;"></div>
                    Đã đặt
                </div>

                <div class="legend-item">
                    <div class="legend-box"
                         style="background:#a0aec0;border-color:#a0aec0;"></div>
                    Bảo trì
                </div>
            </div>

            <div class="schedule-container">

                <!-- HEADER -->
                <div class="schedule-grid time-header-row">

                    <div class="time-cell bg-white border-end-0"></div>

                    @for (int h = 5; h <= 21; h++)
                    {
                        <div class="time-cell">
                            @($"{h}:00 - {h}:30")
                        </div>

                        if (h < 21)
                        {
                            <div class="time-cell">
                                @($"{h}:30 - {h + 1}:00")
                            </div>
                        }
                    }

                </div>

                <!-- ROW -->
                @foreach (var san in Model)
                {
                    <div class="schedule-grid">

                        <div class="court-header">
                            @san.TENSAN
                            <small>@san.LOAISAN.TENLOAISAN</small>
                        </div>

                        @for (int h = 5; h <= 21; h++)
                        {
                            for (int m = 0; m <= 30; m += 30)
                            {
                                if (h == 21 && m == 30)
                                {
                                    break;
                                }

                                TimeSpan gioBD = new TimeSpan(h, m, 0);
                                TimeSpan gioKT = gioBD.Add(new TimeSpan(0, 30, 0));

                                decimal gia30Phut = 75000;

                                bool daDat = dsPhieu.Any(x =>
                                    x.MASAN == san.MASAN
                                    && gioBD < x.GIOKETTHUC
                                    && gioKT > x.GIOBATDAU
                                );

                                if (san.TRANGTHAISAN == "Bảo trì")
                                {
                                    <div class="slot slot-maintenance">
                                        <i class="fas fa-wrench"></i>
                                    </div>
                                }
                                else if (daDat)
                                {
                                    <div class="slot slot-booked">
                                        X
                                    </div>
                                }
                                else
                                {
                                    <div class="slot slot-empty"
                                         data-masan="@san.MASAN"
                                         data-tensan="@san.TENSAN"
                                         data-start="@gioBD.ToString(@"hh\:mm")"
                                         data-end="@gioKT.ToString(@"hh\:mm")"
                                         data-price="@gia30Phut">

                                        +

                                    </div>
                                }
                            }
                        }

                    </div>
                }

            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-xl-3">

            <div class="summary-card">

                <h4 class="fw-bold mb-4 text-success border-bottom pb-2">
                    <i class="fas fa-receipt me-2"></i>
                    Chi tiết đặt sân
                </h4>

                <div class="summary-item mb-2 border-0 pb-0">
                    <span class="text-muted">Ngày chơi:</span>
                    <strong class="text-dark">
                        @ngayDat.ToString("dd/MM/yyyy")
                    </strong>
                </div>

                <div class="selection-list" id="selectionList">

                    <div class="text-muted small text-center my-3 border rounded p-3">
                        Bạn chưa chọn khung giờ nào.
                    </div>

                </div>

                <div class="mt-2 p-3 bg-light rounded-3 text-center mb-4 border">

                    <span class="text-muted d-block mb-1">
                        Tạm tính tiền sân
                    </span>

                    <span id="tongTien"
                          class="fs-2 fw-bold text-success">
                        0đ
                    </span>

                </div>

                <button class="btn-next shadow"
                        onclick="xacNhanDatNhieuSan()">

                    TIẾP THEO
                    <i class="fas fa-arrow-right ms-2"></i>

                </button>

            </div>

        </div>

    </div>
</div>

<script>

    let selectedSlots = [];

    const formatCurrency = (amount) => {
        return new Intl.NumberFormat(
            'vi-VN',
            {
                style: 'currency',
                currency: 'VND'
            }
        ).format(amount);
    };

    const timeToMinutes = (timeStr) => {

        let parts = timeStr.split(':');

        return parseInt(parts[0]) * 60 + parseInt(parts[1]);
    };

    // CLICK SLOT
    document.querySelectorAll('.slot-empty').forEach(cell => {

        cell.addEventListener('click', function () {

            let slotInfo = {

                maSan: this.dataset.masan,
                tenSan: this.dataset.tensan,
                start: this.dataset.start,
                end: this.dataset.end,
                price: parseFloat(this.dataset.price)

            };

            // BỎ CHỌN
            if (this.classList.contains('slot-selected')) {

                this.classList.remove('slot-selected');

                this.innerText = "+";

                selectedSlots = selectedSlots.filter(s =>
                    !(s.maSan === slotInfo.maSan
                        && s.start === slotInfo.start)
                );
            }

            // CHỌN
            else {

                this.classList.add('slot-selected');

                this.innerHTML = '<i class="fas fa-check"></i>';

                selectedSlots.push(slotInfo);
            }

            renderSummary();

        });

    });

    // RENDER SUMMARY
    function renderSummary() {

        let listContainer = document.getElementById("selectionList");
        let tongTienEl = document.getElementById("tongTien");

        if (selectedSlots.length === 0) {

            listContainer.innerHTML =
                `<div class="text-muted small text-center my-3 border rounded p-3">
                    Bạn chưa chọn khung giờ nào.
                </div>`;

            tongTienEl.innerText = "0đ";

            return;
        }

        let groupedByCourt = {};

        selectedSlots.forEach(slot => {

            if (!groupedByCourt[slot.maSan]) {
                groupedByCourt[slot.maSan] = [];
            }

            groupedByCourt[slot.maSan].push(slot);

        });

        let htmlContent = "";
        let totalAmount = 0;

        for (let maSan in groupedByCourt) {

            let courts = groupedByCourt[maSan];

            courts.sort((a, b) =>
                timeToMinutes(a.start)
                - timeToMinutes(b.start)
            );

            let mergedBlocks = [];
            let currentBlock = null;

            courts.forEach(slot => {

                if (!currentBlock) {

                    currentBlock = { ...slot };

                }
                else if (currentBlock.end === slot.start) {

                    currentBlock.end = slot.end;

                    currentBlock.price += slot.price;

                }
                else {

                    mergedBlocks.push(currentBlock);

                    currentBlock = { ...slot };

                }

            });

            if (currentBlock) {
                mergedBlocks.push(currentBlock);
            }

            mergedBlocks.forEach(block => {

                totalAmount += block.price;

                htmlContent += `

                    <div class="selection-item">

                        <div class="d-flex justify-content-between mb-1">

                            <strong class="text-dark">
                                ${block.tenSan}
                            </strong>

                            <span class="text-success fw-bold">
                                ${formatCurrency(block.price)}
                            </span>

                        </div>

                        <div class="text-primary fw-bold small">

                            <i class="far fa-clock me-1"></i>

                            ${block.start} - ${block.end}

                        </div>

                    </div>

                `;

            });

        }

        listContainer.innerHTML = htmlContent;

        tongTienEl.innerText = formatCurrency(totalAmount);

    }

    function locNgay() {

        let ngay = document.getElementById("ngayDat").value;

        window.location.href =
            '/DatSan65132651/Booking?ngay=' + ngay;
    }

</script>