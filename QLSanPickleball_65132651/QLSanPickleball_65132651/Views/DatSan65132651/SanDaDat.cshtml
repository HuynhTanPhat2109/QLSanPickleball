@model QLSanPickleball_65132651.Controllers.SanDaDatViewModel

@{
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";
    ViewBag.Title = "Sân đã đặt";

    Func<TimeSpan, string> fmtTime = t => t.ToString(@"hh\:mm");


    Func<string, string> badgeClass = tt =>
    {
        if (string.IsNullOrWhiteSpace(tt)) return "badge-secondary";

        if (tt.Contains("Chờ xác nhận") || tt.Contains("Chờ duyệt"))
            return "badge-warning";

        if (tt.Contains("Đã xác nhận") || tt.Contains("Da xac nhan"))
            return "badge-success";

        if (tt.Contains("Hoàn thành") || tt.Contains("Hoan thanh"))
            return "badge-done";

        if (tt.Contains("Khách không đến"))
            return "badge-danger";

        if (tt.Contains("Hủy") || tt.Contains("Huỷ") || tt.Contains("DaHuy"))
            return "badge-danger";

        return "badge-info";
    };
}

<style>
    body {
        background: #eef7f1;
    }

    .my-booking-page {
        padding: 34px 22px;
    }

    .lookup-card {
        background: white;
        border-radius: 22px;
        padding: 22px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.07);
        margin-bottom: 22px;
    }

    .lookup-form {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .lookup-input {
        height: 40px;
        border-radius: 14px;
        border: 1px solid #cbd5e1;
        font-weight: 800;
        max-width: 320px;
    }

    .btn-lookup {
        height: 40px;
        border: none;
        border-radius: 14px;
        padding: 0 24px;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
        font-weight: 1000;
        box-shadow: 0 10px 22px rgba(217, 119, 6, 0.25);
    }

    .booking-list {
        display: grid;
        gap: 12px;
        max-width: 760px;
    }

    .booking-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .booking-card-top {
        background: linear-gradient(135deg, #f8fafc, #ecfdf5);
        padding: 11px 14px;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 10px;
        flex-wrap: wrap;
    }

    .booking-title {
        font-weight: 1000;
        color: #064e3b;
        font-size: 0.98rem;
        margin-bottom: 3px;
    }

    .booking-sub {
        color: #64748b;
        font-size: 0.8rem;
        font-weight: 750;
        margin-top: 1px;
    }

    .status-badge {
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 1000;
        font-size: 0.72rem;
        white-space: nowrap;
    }

    .badge-warning {
        background: #fef3c7;
        color: #92400e;
    }

    .badge-success {
        background: #dcfce7;
        color: #166534;
    }

    .badge-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .badge-info {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .badge-secondary {
        background: #e5e7eb;
        color: #374151;
    }

    .badge-done {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .booking-card-body {
        padding: 12px 14px 14px;
    }

    .slot-list {
        display: grid;
        gap: 8px;
    }

    .slot-line {
        border-left: 4px solid #10b981;
        border-radius: 14px;
        margin-bottom: 18px;
    }
    .slot-san {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 10px 12px;
    }

    .slot-main {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 6px;
    }

    .slot-court {
        font-weight: 1000;
        color: #0f172a;
        font-size: 0.9rem;
    }

    .slot-type {
        color: #64748b;
        font-size: 0.74rem;
        font-weight: 750;
        margin-top: 1px;
    }

    .slot-money {
        color: #047857;
        font-weight: 1000;
        white-space: nowrap;
        font-size: 0.88rem;
    }

    .slot-info-vertical {
        display: grid;
        gap: 4px;
        padding-top: 7px;
        border-top: 1px dashed #cbd5e1;
    }

    .slot-info-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
    }

    .slot-label {
        color: #64748b;
        font-size: 0.72rem;
        font-weight: 900;
    }

    .slot-value {
        color: #064e3b;
        font-weight: 950;
        text-align: right;
        font-size: 0.82rem;
    }

    .money-summary {
        margin-top: 10px;
        background: linear-gradient(135deg, #ecfdf5, #f0fdf4);
        border: 1px solid #bbf7d0;
        border-radius: 14px;
        padding: 10px 12px;
    }

    .money-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 3px 0;
        font-weight: 850;
        color: #475569;
        font-size: 0.82rem;
    }

        .money-row.total {
            color: #064e3b;
            font-size: 0.92rem;
            font-weight: 1000;
            border-top: 1px dashed #86efac;
            margin-top: 4px;
            padding-top: 7px;
        }

    .empty-box {
        background: white;
        border-radius: 24px;
        padding: 38px 24px;
        text-align: center;
        border: 1px dashed #cbd5e1;
        color: #64748b;
        font-weight: 700;
        max-width: 100%;
    }

    @@media (max-width: 576px) {
        .my-booking-page {
            padding: 24px 12px;
        }

        .booking-card-top,
        .slot-main,
        .slot-info-row,
        .money-row {
            align-items: flex-start;
            flex-direction: column;
        }

        .slot-value {
            text-align: left;
        }
    }
</style>

<div class="container-fluid my-booking-page">

    @if (!Model.LaDangNhap)
    {
        <div class="lookup-card">
            <h5 class="fw-bold text-success mb-3">
                <i class="fas fa-phone me-2"></i>
                Tra cứu lịch đặt khách vãng lai
            </h5>

            <form method="get" action="@Url.Action("SanDaDat", "DatSan65132651")" class="lookup-form">
                <input type="text"
                       name="sdt"
                       value="@Model.SoDienThoaiTraCuu"
                       class="form-control lookup-input"
                       placeholder="Nhập số điện thoại đặt sân" />

                <button type="submit" class="btn-lookup">
                    TRA CỨU
                    <i class="fas fa-search ms-2"></i>
                </button>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3 mb-0 fw-bold rounded-4">
                    @ViewBag.Error
                </div>
            }
        </div>
    }

    @if (Model.DanhSach == null || !Model.DanhSach.Any())
    {
        <div class="empty-box">
            <div style="font-size:48px;color:#94a3b8;margin-bottom:12px;">
                <i class="fas fa-calendar-times"></i>
            </div>

            Chưa có lịch đặt sân để hiển thị.
        </div>
    }
    else
    {
        <div class="booking-list">
            @foreach (var nhom in Model.DanhSach)
            {
                <div class="slot-line">
                    <div class="booking-card">
                        <div class="booking-card-top">
                            <div>
                                <div class="booking-title">
                                    <i class="fas fa-receipt me-2"></i>
                                    Phiếu đặt sân
                                </div>

                                <div class="booking-sub">
                                    <i class="fas fa-user me-1"></i>
                                    @nhom.TenKhachHang

                                    @if (!string.IsNullOrWhiteSpace(nhom.SoDienThoai))
                                    {
                                        <span> · @nhom.SoDienThoai</span>
                                    }
                                </div>

                                <div class="booking-sub">
                                    <i class="fas fa-clock me-1"></i>
                                    Ngày giờ đặt:
                                    <strong>
                                        @(nhom.NgayGioDat.HasValue
                        ? nhom.NgayGioDat.Value.ToString("dd/MM/yyyy HH:mm")
                        : "Không xác định")
                                    </strong>
                                </div>
                            </div>

                            <span class="status-badge @badgeClass(nhom.TrangThaiPhieu)">
                                @nhom.TrangThaiPhieu
                            </span>
                        </div>

                        <div class="booking-card-body">
                            <div class="slot-list">
                                @foreach (var ct in nhom.ChiTiet)
                                {
                                    <div class="slot-san">
                                        <div class="slot-main">
                                            <div>
                                                <div class="slot-court">
                                                    <i class="fas fa-table-tennis-paddle-ball me-1 text-success"></i>
                                                    @ct.TenSan
                                                </div>
                                                <div class="slot-type">@ct.LoaiSan</div>
                                            </div>

                                            <div class="slot-money">
                                                @ct.TienSan.ToString("N0")đ
                                            </div>
                                        </div>

                                        <div class="slot-info-vertical">
                                            <div class="slot-info-row">
                                                <span class="slot-label">Ngày chơi</span>
                                                <span class="slot-value">@ct.NgayDat.ToString("dd/MM/yyyy")</span>
                                            </div>

                                            <div class="slot-info-row">
                                                <span class="slot-label">Khung giờ</span>
                                                <span class="slot-value">
                                                    @fmtTime(ct.GioBatDau) - @fmtTime(ct.GioKetThuc)
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="money-summary">
                                <div class="money-row">
                                    <span>Tiền sân</span>
                                    <strong>@nhom.TongTienSan.ToString("N0")đ</strong>
                                </div>

                                <div class="money-row">
                                    <span>Tiền dịch vụ</span>
                                    <strong>@nhom.TongTienDichVu.ToString("N0")đ</strong>
                                </div>

                                <div class="money-row total">
                                    <span>Tổng thanh toán</span>
                                    <strong>@nhom.TongThanhToan.ToString("N0")đ</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
            }
        </div>
    }
</div>