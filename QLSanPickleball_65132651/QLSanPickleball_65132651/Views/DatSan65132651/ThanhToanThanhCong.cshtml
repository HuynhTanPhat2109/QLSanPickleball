@{
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";
    ViewBag.Title = "Gửi minh chứng thành công";
}

<div style="max-width:760px;margin:70px auto;background:white;padding:40px;border-radius:24px;text-align:center;box-shadow:0 15px 40px rgba(0,0,0,0.08);">
    <div style="font-size:58px;color:#16a34a;margin-bottom:14px;">
        <i class="fas fa-check-circle"></i>
    </div>

    <h2 style="font-weight:900;color:#064e3b;">Đã gửi minh chứng thanh toán</h2>

    <p style="color:#64748b;">
        Nhân viên sân sẽ kiểm tra chuyển khoản và xác nhận lịch đặt cho bạn.
    </p>

    <a href="@Url.Action("Index", "Home")"
       style="display:inline-block;margin-top:20px;background:#f59e0b;color:white;padding:13px 28px;border-radius:999px;font-weight:900;text-decoration:none;">
        VỀ TRANG CHỦ
    </a>
</div>