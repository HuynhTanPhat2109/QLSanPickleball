@using QLSanPickleball_65132651.Models
@using System.Globalization

@{
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";
    ViewBag.Title = "Xác nhận đặt sân";

    var dsPhieu = ViewBag.DanhSachPhieuDat as List<PHIEUDATSAN> ?? new List<PHIEUDATSAN>();
    var dsDichVu = ViewBag.DanhSachDichVu as List<DICHVU> ?? new List<DICHVU>();

    string maNhomDatSan = ViewBag.MaNhomDatSan as string;
    DateTime ngayDat = ViewBag.NgayDat == null ? DateTime.Today : (DateTime)ViewBag.NgayDat;
    decimal tongTienSan = ViewBag.TongTienSan == null ? 0 : (decimal)ViewBag.TongTienSan;
    bool laVangLai = ViewBag.LaVangLai == null ? true : (bool)ViewBag.LaVangLai;

    Func<TimeSpan, string> fmtTime = t => t.ToString(@"hh\:mm");

    int tongPhutSan = 0;
    foreach (var p in dsPhieu)
    {
        tongPhutSan += (int)(p.GIOKETTHUC - p.GIOBATDAU).TotalMinutes;
    }

    int tongGio = tongPhutSan / 60;
    int tongPhut = tongPhutSan % 60;

    string tongGioText = tongGio > 0 && tongPhut > 0
        ? tongGio + " giờ " + tongPhut + " phút"
        : tongGio > 0
            ? tongGio + " giờ"
            : tongPhut + " phút";
}

<style>
    body {
        background: #eef7f1;
    }

