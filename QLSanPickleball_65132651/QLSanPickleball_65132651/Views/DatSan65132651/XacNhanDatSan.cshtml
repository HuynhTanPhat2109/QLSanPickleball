</style>

<div class="container-fluid confirm-page">

    <div class="confirm-hero confirm-hero-grid">

        <div class="hero-left">
            <button type="button"
                    class="btn-back-booking"
                    onclick="quayLaiBooking()">
                <i class="fas fa-arrow-left"></i>
            </button>
        </div>

        <div class="hero-center">
            <h3>
                <i class="fas fa-clipboard-check me-2"></i>
                Xác nhận đặt sân
            </h3>

            <div class="hero-sub">
                Kiểm tra lịch đặt, chọn thêm dịch vụ và xác nhận thanh toán.
            </div>
        </div>

        <div class="hero-right">
            <div class="countdown-box">
                <span>Còn lại</span>
                <strong id="countdownTime">5:00</strong>
            </div>
        </div>

    </div>

    <div class="row g-4">
        <div class="col-lg-8">

            <div class="info-card">
                @{
                    var nhomTheoSan = dsPhieu
                        .GroupBy(p => new
                        {
                            MaSan = p.MASAN,
                            TenSan = p.SAN == null ? p.MASAN : p.SAN.TENSAN,
                            LoaiSan = p.SAN == null || p.SAN.LOAISAN == null
                                ? "Chưa phân loại"
                                : p.SAN.LOAISAN.TENLOAISAN
                        })
                        .ToList();
                }

                <div class="booking-vertical-card">
                    <div class="booking-vertical-title">
                        <i class="fas fa-ticket-alt"></i>
                        Thông tin lịch đặt
                    </div>

                    <div class="mb-3">
                        Ngày: <span class="booking-date-line">@ngayDat.ToString("dd/MM/yyyy")</span>
                    </div>

                    @{
                        var dsPhieuSapXep = dsPhieu
                            .Select(p => new
                            {
                                Phieu = p,
                                TenSan = p.SAN == null ? p.MASAN : p.SAN.TENSAN,
                                LoaiSan = p.SAN == null || p.SAN.LOAISAN == null
                                    ? "Chưa phân loại"
                                    : p.SAN.LOAISAN.TENLOAISAN
                            })
                            .OrderBy(x => x.Phieu.GIOBATDAU)
                            .ThenBy(x => x.TenSan)
                            .ToList();

                        var dsLoaiSan = dsPhieuSapXep
                            .Select(x => x.LoaiSan)
                            .Distinct()
                            .OrderBy(x => x)
                            .ToList();

                        string loaiSanText = string.Join(", ", dsLoaiSan);
                    }

                    @foreach (var item in dsPhieuSapXep)
                    {
                        <div class="booking-slot-line">
                            <div class="booking-slot-left">
                                <span class="me-2">- @item.TenSan:</span>
                                @fmtTime(item.Phieu.GIOBATDAU) - @fmtTime(item.Phieu.GIOKETTHUC)
                            </div>

                            <div class="booking-slot-money">
                                @item.Phieu.TONGTIENTAMTINH.ToString("N0") đ
                            </div>
                        </div>
                    }

                    <div class="mt-3">
                        Loại sân:
                        <span class="booking-object">@loaiSanText</span>
                    </div>

                    <div class="booking-summary-vertical">
                        <div class="booking-summary-row">
                            <span>Tổng giờ:</span>
                            <strong>@tongGioText</strong>
                        </div>

                        <div class="booking-summary-row total">
                            <span>Tổng tiền:</span>
                            <strong>@tongTienSan.ToString("N0") đ</strong>
                        </div>
                    </div>
                </div>
            </div>

            <div class="info-card">
                <div class="section-title">
                    <i class="fas fa-bottle-water"></i>
                    Dịch vụ đi kèm
                </div>

                <button type="button" class="service-toggle" onclick="toggleDichVu()">
                    <i class="fas fa-plus-circle me-2"></i>
                    Thêm dịch vụ
                </button>

                <div id="servicePanel" class="service-panel">
                    <div class="service-grid mt-3">
                        @foreach (var dv in dsDichVu)
                        {
                            <div class="service-card">
                                <div class="service-name">@dv.TENDV</div>
                                <div class="service-meta">
                                    @dv.LOAIDV · @dv.DONVITINH
                                </div>
                                <div class="service-meta">
                                    Còn: @dv.SOLUONGTON
                                </div>

                                <div class="qty-row">
                                    <strong class="text-success">
                                        @dv.DONGIA.ToString("N0")đ
                                    </strong>

                                    <input type="number"
                                           class="qty-input dichvu-qty"
                                           min="0"
                                           max="@dv.SOLUONGTON"
                                           value="0"
                                           data-madv="@dv.MADV"
                                           data-tendv="@dv.TENDV"
                                           data-dongia="@dv.DONGIA.ToString("0.##", CultureInfo.InvariantCulture)"
                                           oninput="capNhatTongTien()">
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="info-card guest-box">
                <div class="section-title">
                    <i class="fas fa-user"></i>
                    Thông tin khách vãng lai
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="fw-bold mb-2">Họ tên khách hàng</label>
                        <input type="text"
                               id="tenKhach"
                               class="form-control form-modern"
                               placeholder="Nhập họ tên">
                    </div>

                    <div class="col-md-6">
                        <label class="fw-bold mb-2">Số điện thoại</label>
                        <input type="text"
                               id="sdtKhach"
                               class="form-control form-modern"
                               placeholder="Nhập số điện thoại">
                    </div>
                </div>
            </div>

        </div>

        <div class="col-lg-4">
            <div class="payment-card">
                <div class="section-title">
                    <i class="fas fa-receipt"></i>
                    Tóm tắt thanh toán
                </div>

                <div class="money-row">
                    <span>Tiền sân</span>
                    <strong id="txtTienSan">@tongTienSan.ToString("N0")đ</strong>
                </div>

                <div class="money-row">
                    <span>Tiền dịch vụ</span>
                    <strong id="txtTienDichVu">0đ</strong>
                </div>

                <div class="money-row">
                    <span>Tổng thời lượng</span>
                    <strong>@tongGioText</strong>
                </div>

                <div class="total-box">
                    <span>Tổng thanh toán</span>
                    <h3 id="txtTongThanhToan">@tongTienSan.ToString("N0")đ</h3>
                </div>

                <button type="button" class="btn-pay" onclick="xacNhanThanhToan()">
                    XÁC NHẬN & THANH TOÁN
                    <i class="fas fa-arrow-right ms-2"></i>
                </button>

                <div class="note-box">
                    <i class="fas fa-info-circle me-1"></i>
                    Sân đang được tạm giữ trong 5 phút. Vui lòng hoàn tất thanh toán để xác nhận lịch đặt.
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const maNhomDatSan = '@maNhomDatSan';
    let daBamThanhToan = false;

    function layThoiGianTaoTuMaNhom(maNhom) {
        // Ma nhóm dạng: GRPyyyyMMddHHmmss
        // Ví dụ: GRP20260521153025
        if (!maNhom || maNhom.length < 17) {
            return new Date();
        }

        let raw = maNhom.substring(3, 17);

        let yyyy = parseInt(raw.substring(0, 4));
        let MM = parseInt(raw.substring(4, 6)) - 1;
        let dd = parseInt(raw.substring(6, 8));
        let hh = parseInt(raw.substring(8, 10));
        let mm = parseInt(raw.substring(10, 12));
        let ss = parseInt(raw.substring(12, 14));

        return new Date(yyyy, MM, dd, hh, mm, ss);
    }

    function batDauDemNguocGiuCho() {
        let countdownEl = document.getElementById("countdownTime");
        let boxEl = document.querySelector(".countdown-box");

        if (!countdownEl || !boxEl) return;

        let thoiGianTao = layThoiGianTaoTuMaNhom(maNhomDatSan);
        let thoiGianHetHan = new Date(thoiGianTao.getTime() + 5 * 60 * 1000);

        let timer = setInterval(function () {
            let now = new Date();
            let diff = thoiGianHetHan - now;

            if (diff <= 0) {
                clearInterval(timer);
                countdownEl.innerText = "00:00";

                if (!daBamThanhToan) {
                    huyTamGiuVaVeBooking();
                }

                return;
            }

            let totalSeconds = Math.floor(diff / 1000);
            let minutes = Math.floor(totalSeconds / 60);
            let seconds = totalSeconds % 60;

            countdownEl.innerText =
                String(minutes).padStart(2, "0") + ":" +
                String(seconds).padStart(2, "0");

            if (totalSeconds <= 60) {
                boxEl.classList.add("danger");
            }
        }, 1000);
    }

    batDauDemNguocGiuCho();
    const tongTienSan = parseFloat('@tongTienSan.ToString("0.##", CultureInfo.InvariantCulture)');
    const laVangLai = '@laVangLai'.toLowerCase() === 'true';

    function formatCurrency(amount) {
        return new Intl.NumberFormat('vi-VN', {
            style: 'currency',
            currency: 'VND'
        }).format(amount);
    }

    function toggleDichVu() {
        document.getElementById("servicePanel").classList.toggle("show");
    }

    function layDanhSachDichVuChon() {
        let result = [];

        document.querySelectorAll(".dichvu-qty").forEach(input => {
            let soLuong = parseInt(input.value || "0");

            if (soLuong > 0) {
                result.push({
                    maDV: input.dataset.madv,
                    tenDV: input.dataset.tendv,
                    soLuong: soLuong,
                    donGia: parseFloat(input.dataset.dongia)
                });
            }
        });

        return result;
    }

    function capNhatTongTien() {
        let tienDichVu = 0;

        document.querySelectorAll(".dichvu-qty").forEach(input => {
            let soLuong = parseInt(input.value || "0");
            let max = parseInt(input.getAttribute("max") || "0");

            if (soLuong < 0) {
                input.value = 0;
                soLuong = 0;
            }

            if (soLuong > max) {
                input.value = max;
                soLuong = max;
            }

            let donGia = parseFloat(input.dataset.dongia);
            tienDichVu += soLuong * donGia;
        });

        let tongThanhToan = tongTienSan + tienDichVu;

        document.getElementById("txtTienDichVu").innerText = formatCurrency(tienDichVu);
        document.getElementById("txtTongThanhToan").innerText = formatCurrency(tongThanhToan);
    }

    function xacNhanThanhToan() {
        let tenKhach = "";
        let sdtKhach = "";

        if (laVangLai) {
            tenKhach = document.getElementById("tenKhach").value.trim();
            sdtKhach = document.getElementById("sdtKhach").value.trim();

            if (!tenKhach) {
                alert("Vui lòng nhập họ tên khách hàng.");
                return;
            }

            if (!sdtKhach) {
                alert("Vui lòng nhập số điện thoại khách hàng.");
                return;
            }

            if (!/^[0-9]{10}$/.test(sdtKhach)) {
                alert("Số điện thoại phải gồm 10 chữ số.");
                return;
            }
        }

        let dichVuChon = layDanhSachDichVuChon();

        fetch('@Url.Action("LuuXacNhanDatSan", "DatSan65132651")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json; charset=utf-8'
            },
            body: JSON.stringify({
                maNhomDatSan: maNhomDatSan,
                tenKhach: tenKhach,
                sdtKhach: sdtKhach,
                dichVuChon: dichVuChon
            })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                daBamThanhToan = true;
                window.location.href =
                    '@Url.Action("ThanhToan", "DatSan65132651")' + '?id=' + encodeURIComponent(maNhomDatSan);
            }
            else {
                alert(data.message);
            }
        })
        .catch(() => {
            alert("Có lỗi khi xác nhận đặt sân. Vui lòng thử lại.");
        });
    }

    capNhatTongTien();

        function huyTamGiuVaVeBooking() {
        daBamThanhToan = true;

        fetch('@Url.Action("HuyTamGiu", "DatSan65132651")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: 'maNhomDatSan=' + encodeURIComponent(maNhomDatSan),
            keepalive: true
        })
        .finally(() => {
            window.location.replace('@Url.Action("Booking", "DatSan65132651")');
        });
    }

    function quayLaiBooking() {
        huyTamGiuVaVeBooking();
    }
    history.pushState({ page: "xac-nhan-dat-san" }, "", location.href);

    window.addEventListener("popstate", function () {
        if (daBamThanhToan) {
            return;
        }

        huyTamGiuVaVeBooking();
    });
    window.addEventListener("pagehide", function () {
    if (daBamThanhToan) {
        return;
    }

    let data = new URLSearchParams();
    data.append("maNhomDatSan", maNhomDatSan);

    navigator.sendBeacon(
        '@Url.Action("HuyTamGiu", "DatSan65132651")',
        data
    );
});
</script>