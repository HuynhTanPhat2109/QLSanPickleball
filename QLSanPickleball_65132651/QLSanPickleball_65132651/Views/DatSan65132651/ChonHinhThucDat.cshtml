@{
    Layout = "~/Views/Shared/_LayoutKhachHang.cshtml";
    ViewBag.Title = "Chọn hình thức đặt sân";
}

<style>

    :root {
        --primary: #166534;
        --secondary: #22c55e;
        --dark: #0f172a;
        --glass: rgba(255,255,255,0.72);
    }

    body {
        background: radial-gradient(circle at top left, #dcfce7, transparent 30%), radial-gradient(circle at bottom right, #bbf7d0, transparent 30%), linear-gradient(to bottom, #f5fff7, #eefbf1);
    }

    /* =========================
       HERO
    ========================= */

    .booking-type-hero {
        padding: 30px 0 0px;
        text-align: center;
    }

    .booking-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 999px;
        background: rgba(34,197,94,.12);
        color: #15803d;
        font-weight: 700;
        font-size: .92rem;
    }

    .booking-title {
        font-size: 3rem;
        font-weight: 900;
        color: #0f172a;
        margin-top: 15px;
        margin-bottom: 12px;
    }

    .booking-subtitle {
        max-width: 880px;
        margin: auto;
        color: #64748b;
        font-size: 1.08rem;
        line-height: 1.8;
    }

    /* =========================
       OPTION CARDS
    ========================= */

    .booking-options {
        margin-top: 40px;
        margin-bottom: 50px
    }

    .booking-card {
        position: relative;
        overflow: hidden;
        border-radius: 34px;
        padding: 28px;
        height: 100%;
        background: rgba(255,255,255,.72);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(255,255,255,.35);
        box-shadow: 0 20px 40px rgba(0,0,0,.06), inset 0 1px 0 rgba(255,255,255,.35);
        transition: .35s ease;
    }

        .booking-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 30px 55px rgba(0,0,0,.10), 0 0 0 1px rgba(34,197,94,.10);
        }

        /* Glow */

        .booking-card::before {
            content: "";
            position: absolute;
            width: 240px;
            height: 240px;
            border-radius: 50%;
            top: -80px;
            right: -80px;
            background: rgba(34,197,94,.12);
        }

    /* ICON */

    .booking-icon {
        width: 66px;
        height: 66px;
        border-radius: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: white;
        margin-bottom: 15px;
        position: relative;
        z-index: 2;
    }

    .daily-icon {
        background: linear-gradient(135deg,#22c55e,#15803d);
        box-shadow: 0 15px 30px rgba(34,197,94,.28);
    }

    .event-icon {
        background: linear-gradient(135deg,#f59e0b,#ea580c);
        box-shadow: 0 15px 30px rgba(245,158,11,.28);
    }

    /* CONTENT */

    .booking-card-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 10px;
        position: relative;
        z-index: 2;
    }

    .booking-card-desc {
        color: #64748b;
        line-height: 1.8;
        margin-bottom: 17px;
        position: relative;
        z-index: 2;
    }

    /* FEATURES */

    .booking-feature {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        color: #334155;
        font-weight: 600;
        position: relative;
        z-index: 2;
    }

        .booking-feature i {
            width: 30px;
            height: 30px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(34,197,94,.10);
            color: #16a34a;
            font-size: .82rem;
        }

    /* BUTTON */

    .btn-booking {
        margin-top: 15px;
        width: 100%;
        height: 48px;
        border: none;
        border-radius: 20px;
        font-size: 1rem;
        font-weight: 800;
        color: white;
        transition: .3s ease;
        position: relative;
        z-index: 2;
    }

    .btn-daily {
        background: linear-gradient(135deg,#16a34a,#22c55e);
    }

    .btn-event {
        background: linear-gradient(135deg,#ea580c,#f59e0b);
    }

    .btn-booking:hover {
        transform: translateY(-3px);
    }

    /* TAG */

    .booking-tag {
        position: absolute;
        top: 26px;
        right: 26px;
        padding: 10px 16px;
        border-radius: 999px;
        font-size: .82rem;
        font-weight: 700;
        backdrop-filter: blur(10px);
        z-index: 2;
    }

    .daily-tag {
        background: rgba(34,197,94,.12);
        color: #15803d;
    }

    .event-tag {
        background: rgba(245,158,11,.12);
        color: #c2410c;
    }

    /* =========================
       RESPONSIVE
    ========================= */

    @@media(max-width: 992px) {

        .booking-title {
            font-size: 2.3rem;
        }
    }

    @@media(max-width: 768px) {

        .booking-title {
            font-size: 2rem;
        }

        .booking-card {
            padding: 28px;
        }
    }
</style>

<div class="container">

    <!-- HERO -->

    <div class="booking-type-hero">

        <div class="booking-badge">
            <i class="fas fa-bolt"></i>
            Army Pickleball Booking System
        </div>

        <h1 class="booking-title">
            Chọn hình thức đặt sân
        </h1>

        <p class="booking-subtitle">
            Lựa chọn hình thức đặt phù hợp để hệ thống hiển thị lịch trống,
            sơ đồ sân và hỗ trợ thanh toán nhanh chóng.
        </p>

    </div>

    <!-- OPTIONS -->

    <div class="booking-options">

        <div class="row g-4">

            <!-- DAILY -->

            <div class="col-lg-6">

                <div class="booking-card">

                    <div class="booking-tag daily-tag">
                        Phổ biến nhất
                    </div>

                    <div class="booking-icon daily-icon">
                        <i class="fas fa-calendar-day"></i>
                    </div>

                    <div class="booking-card-title">
                        Đặt lịch ngày
                    </div>

                    <div class="booking-card-desc">
                        Đặt sân nhanh theo từng khung giờ trong ngày.
                        Phù hợp cho khách chơi cá nhân, nhóm bạn hoặc luyện tập thường xuyên.
                    </div>

                    <div class="booking-feature">
                        <i class="fas fa-check"></i>
                        Tùy chọn sân và khung giờ phù hợp
                    </div>

                    <div class="booking-feature">
                        <i class="fas fa-check"></i>
                        Hiển thị lịch trống realtime
                    </div>

                    <div class="booking-feature">
                        <i class="fas fa-check"></i>
                        Hỗ trợ thanh toán QR nhanh
                    </div>

                    <a href="@Url.Action("Booking", "DatSan65132651", new { loaiDat = "Ngay" })"
                       class="btn btn-booking btn-daily d-flex align-items-center justify-content-center">

                        Tiếp tục đặt lịch ngày
                        <i class="fas fa-arrow-right ms-3"></i>

                    </a>

                </div>

            </div>

            <!-- EVENT -->

            <div class="col-lg-6">

                <div class="booking-card">

                    <div class="booking-tag event-tag">
                        Đặt dài giờ
                    </div>

                    <div class="booking-icon event-icon">
                        <i class="fas fa-trophy"></i>
                    </div>

                    <div class="booking-card-title">
                        Đặt lịch sự kiện
                    </div>

                    <div class="booking-card-desc">
                        Dành cho giải đấu, team building, workshop hoặc thuê nhiều sân
                        trong thời gian dài với nhu cầu tổ chức chuyên nghiệp.
                    </div>

                    <div class="booking-feature">
                        <i class="fas fa-check"></i>
                        Thuê nhiều sân cùng lúc
                    </div>

                    <div class="booking-feature">
                        <i class="fas fa-check"></i>
                        Ưu tiên hỗ trợ tổ chức sự kiện
                    </div>

                    <div class="booking-feature">
                        <i class="fas fa-check"></i>
                        Quản lý lịch chuyên biệt
                    </div>

                    <a href="@Url.Action("Booking", "DatSan65132651", new { loaiDat = "SuKien" })"
                       class="btn btn-booking btn-event d-flex align-items-center justify-content-center">

                        Tiếp tục đặt sự kiện
                        <i class="fas fa-arrow-right ms-3"></i>

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>