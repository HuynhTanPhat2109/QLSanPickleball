                       name="ngayDat"
                       class="form-control"
                       value="@ViewBag.NgayDat" />
            </div>

            <div>
                <label class="form-label">Trạng thái phiếu</label>
                <select name="trangThaiPhieu" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="Tam_Giu" @(ViewBag.TrangThaiPhieu == "Tam_Giu" ? "selected" : "")>Tạm giữ</option>
                    <option value="Cho_Thanh_Toan" @(ViewBag.TrangThaiPhieu == "Cho_Thanh_Toan" ? "selected" : "")>Chờ thanh toán</option>
                    <option value="Chờ duyệt" @(ViewBag.TrangThaiPhieu == "Chờ duyệt" ? "selected" : "")>Chờ duyệt</option>
                    <option value="Chờ xác nhận" @(ViewBag.TrangThaiPhieu == "Chờ xác nhận" ? "selected" : "")>Chờ xác nhận</option>
                    <option value="Đã xác nhận" @(ViewBag.TrangThaiPhieu == "Đã xác nhận" ? "selected" : "")>Đã xác nhận</option>
                    <option value="Hoàn thành" @(ViewBag.TrangThaiPhieu == "Hoàn thành" ? "selected" : "")>Hoàn thành</option>
                    <option value="Đã hủy" @(ViewBag.TrangThaiPhieu == "Đã hủy" ? "selected" : "")>Đã hủy</option>
                </select>
            </div>

            <div>
                <label class="form-label">Thanh toán</label>
                <select name="trangThaiThanhToan" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="ChuaThanhToan" @(ViewBag.TrangThaiThanhToan == "ChuaThanhToan" ? "selected" : "")>Chưa thanh toán</option>
                    <option value="Cho_Chuyen_Khoan" @(ViewBag.TrangThaiThanhToan == "Cho_Chuyen_Khoan" ? "selected" : "")>Chờ chuyển khoản</option>
                    <option value="Chờ xác nhận chuyển khoản" @(ViewBag.TrangThaiThanhToan == "Chờ xác nhận chuyển khoản" ? "selected" : "")>Chờ xác nhận CK</option>
                    <option value="Đã đặt cọc" @(ViewBag.TrangThaiThanhToan == "Đã đặt cọc" ? "selected" : "")>Đã đặt cọc</option>
                    <option value="Đã thanh toán 100%" @(ViewBag.TrangThaiThanhToan == "Đã thanh toán 100%" ? "selected" : "")>Đã thanh toán 100%</option>
                    <option value="Đã hủy" @(ViewBag.TrangThaiThanhToan == "Đã hủy" ? "selected" : "")>Đã hủy</option>
                </select>
            </div>

            <div>
                <button type="submit" class="btn-filter">Lọc</button>
            </div>

            <div>
                @Html.ActionLink("Làm mới", "Index", "PhieuDatSanNV65134364", null, new { @class = "btn-reset" })
            </div>
        </div>
    }
</div>

<div class="booking-list">
    @if (Model != null && Model.Any())
    {
        var dsNhomPhieu = Model
        .GroupBy(p => LayKhoaNhom(p))
        .Select(g => new
        {
            MaNhom = g.Key,

            DanhSach = g.OrderBy(p => p.NGAYDAT)
                        .ThenBy(p => p.GIOBATDAU)
                        .ThenBy(p => p.SAN != null ? p.SAN.TENSAN : p.MASAN)
                        .ToList(),

            PhieuDaiDien = g
                .OrderBy(p => p.NGAYDAT.Date + p.GIOBATDAU)
                .FirstOrDefault(),

            ThoiGianBatDauNhom = g
                .Min(p => p.NGAYDAT.Date + p.GIOBATDAU),

            ThoiGianKetThucNhom = g
                .Max(p => p.NGAYDAT.Date + p.GIOKETTHUC)
        })
        .Where(g => g.PhieuDaiDien != null)

        // Sắp xếp ngày đặt giảm dần: 22/05 lên trước 18/05
        .OrderByDescending(g => g.ThoiGianBatDauNhom.Date)

        // Nếu cùng ngày thì giờ sớm hơn lên trước
        .ThenBy(g => g.ThoiGianBatDauNhom.TimeOfDay)

        .ToList();

        foreach (var nhom in dsNhomPhieu)
        {
            var item = nhom.PhieuDaiDien;
            var dsCungNhom = nhom.DanhSach;

            string tenSan = item.SAN != null ? item.SAN.TENSAN : item.MASAN;
            string tenKhach = item.KHACHHANG != null ? item.KHACHHANG.HOTENKH : "Khách vãng lai";
            string sdtKhach = item.KHACHHANG != null ? item.KHACHHANG.SODIENTHOAIKH : "";
            string tenNhanVien = item.NHANVIEN != null ? item.NHANVIEN.HOTENNV : "Chưa xử lý";
            string maNhom = LayMaNhomTuGhiChu(item.GHICHU);
            DateTime thoiGianKetThuc = item.NGAYDAT.Date + item.GIOKETTHUC;
            bool daQuaGio = DateTime.Now > thoiGianKetThuc;

            decimal tienDichVu = 0m;

            if (tienDichVuTheoPhieu != null)
            {
                foreach (var pNhom in dsCungNhom)
                {
                    if (tienDichVuTheoPhieu.ContainsKey(pNhom.MAPHIEUDAT))
                    {
                        tienDichVu += tienDichVuTheoPhieu[pNhom.MAPHIEUDAT];
                    }
                }
            }

            decimal tongTienSan = dsCungNhom.Sum(p => p.TONGTIENTAMTINH);
            decimal tongTamTinh = tongTienSan + tienDichVu;


            string trangThaiPhieuDaiDien = LayTrangThaiDaiDien(dsCungNhom);
            string trangThaiThanhToanDaiDien = LayThanhToanDaiDien(dsCungNhom);

            string classPhieu = "st-gray";

            if (trangThaiPhieuDaiDien == "Tam_Giu")
            {
                classPhieu = "st-temp";
            }
            else if (trangThaiPhieuDaiDien == "Cho_Thanh_Toan")
            {
                classPhieu = "st-pay";
            }
            else if (trangThaiPhieuDaiDien == "Chờ duyệt" || trangThaiPhieuDaiDien == "Chờ xác nhận")
            {
                classPhieu = "st-wait";
            }
            else if (trangThaiPhieuDaiDien == "Đã xác nhận")
            {
                classPhieu = "st-confirm";
            }
            else if (trangThaiPhieuDaiDien == "Hoàn thành")
            {
                classPhieu = "st-done";
            }
            else if (trangThaiPhieuDaiDien == "Đã hủy" || trangThaiPhieuDaiDien == "Đã huỷ" || trangThaiPhieuDaiDien == "Hủy" || item.TRANGTHAIPHIEU == "Huy" || item.TRANGTHAIPHIEU == "DaHuy")
            {
                classPhieu = "st-cancel";
            }

            string classThanhToan = "st-gray";

            if (trangThaiThanhToanDaiDien == "ChuaThanhToan")
            {
                classThanhToan = "st-temp";
            }
            else if (trangThaiThanhToanDaiDien == "Cho_Chuyen_Khoan")
            {
                classThanhToan = "st-pay";
            }
            else if (trangThaiThanhToanDaiDien == "Chờ xác nhận chuyển khoản")
            {
                classThanhToan = "st-wait";
            }
            else if (trangThaiThanhToanDaiDien == "Đã đặt cọc")
            {
                classThanhToan = "st-confirm";
            }
            else if (trangThaiThanhToanDaiDien == "Đã thanh toán 100%")
            {
                classThanhToan = "st-done";
            }
            else if (trangThaiThanhToanDaiDien == "Đã hủy" || trangThaiThanhToanDaiDien == "Đã huỷ")
            {
                classThanhToan = "st-cancel";
            }

            bool choXacNhan = trangThaiPhieuDaiDien == "Chờ xác nhận"
            || trangThaiPhieuDaiDien == "Chờ duyệt"
            || trangThaiThanhToanDaiDien == "Chờ xác nhận chuyển khoản";

            bool daXacNhan = trangThaiPhieuDaiDien == "Đã xác nhận";

            bool daHoanThanh = trangThaiPhieuDaiDien == "Hoàn thành";

            bool daHuy = trangThaiPhieuDaiDien == "Đã hủy"
                || trangThaiPhieuDaiDien == "Đã huỷ"
                || trangThaiPhieuDaiDien == "Hủy"
                || trangThaiPhieuDaiDien == "Huy"
                || trangThaiPhieuDaiDien == "DaHuy"
                || trangThaiThanhToanDaiDien == "Đã hủy"
                || trangThaiPhieuDaiDien == "Khách không đến"
                || trangThaiPhieuDaiDien == "Hủy do bảo trì"
                || trangThaiThanhToanDaiDien == "Đã huỷ";

            <div class="booking-card">
                <div class="booking-top">

                    <div class="court-box">
                        <div class="court-avatar">
                            @dsCungNhom.Count
                        </div>

                        <div>

                            @foreach (var pSlot in dsCungNhom)
                            {
                                string tenSanSlot = pSlot.SAN != null ? pSlot.SAN.TENSAN : pSlot.MASAN;

                                <div class="sub-text">
                                    @tenSanSlot:
                                    @FormatTime(pSlot.GIOBATDAU) - @FormatTime(pSlot.GIOKETTHUC)
                                </div>
                            }
                        </div>
                    </div>

                    <div>
                        <div class="info-label">Khách hàng</div>
                        <div class="info-value">@tenKhach</div>
                        <div class="sub-text">
                            @(string.IsNullOrWhiteSpace(sdtKhach) ? "Mã KH: " + (item.MAKH ?? "Không có") : sdtKhach)
                        </div>
                    </div>

                    <div>
                        <div class="info-label">Ngày đặt</div>
                        <div class="info-value">@item.NGAYDAT.ToString("dd/MM/yyyy")</div>
                        <div class="sub-text">
                            Bắt đầu: @FormatTime(dsCungNhom.Min(p => p.GIOBATDAU))
                        </div>
                    </div>

                    <div>
                        <div class="info-label">Tạm tính</div>
                        <div class="money">@tongTamTinh.ToString("N0") đ</div>

                        @if (tienDichVu > 0)
                        {
                            <div class="sub-text">
                                Sân: @tongTienSan.ToString("N0") đ • DV: @tienDichVu.ToString("N0") đ
                            </div>
                        }
                        else
                        {
                            <div class="sub-text">
                                Tiền sân: @tongTienSan.ToString("N0") đ
                            </div>
                        }
                    </div>

                    <div class="status-stack">
                        <span class="badge-status @classPhieu">@trangThaiPhieuDaiDien</span>
                        <span class="badge-status @classThanhToan">@trangThaiThanhToanDaiDien</span>
                    </div>
                </div>

                <div class="booking-actions">
                    <div class="action-left">
                        Nhân viên xử lý: <strong>@tenNhanVien</strong>
                    </div>

                    <div class="action-box">
                        @Html.ActionLink("Chi tiết", "Details", "PhieuDatSanNV65134364", new { id = item.MAPHIEUDAT }, new { @class = "btn-action btn-detail" })
                        @if (!daQuaGio)
                        {
                            if (choXacNhan && !daHuy)
                            {
                                @Html.ActionLink("Xác nhận", "XacNhanThanhToan", "PhieuDatSanNV65134364", new { id = item.MAPHIEUDAT }, new
                                {
                                    @class = "btn-action btn-confirm",
                                    onclick = "return confirm('Xác nhận thanh toán cho phiếu " + item.MAPHIEUDAT + "?');"
                                })
                            }

                            if (daXacNhan && !daHuy)
                            {
                                @Html.ActionLink("Vào sân", "KhachVaoSan", "PhieuDatSanNV65134364", new { id = item.MAPHIEUDAT }, new
                                {
                                    @class = "btn-action btn-start",
                                    onclick = "return confirm('Xác nhận khách vào sân?');"
                                })

                                @Html.ActionLink("Kết thúc", "KetThucLuotChoi", "PhieuDatSanNV65134364", new { id = item.MAPHIEUDAT }, new
                                {
                                    @class = "btn-action btn-finish",
                                    onclick = "return confirm('Kết thúc lượt chơi và chuyển sân về Trống?');"
                                })

                                @Html.ActionLink("Lập HĐ", "LapHoaDon", "PhieuDatSanNV65134364", new { id = item.MAPHIEUDAT }, new
                                {
                                    @class = "btn-action btn-invoice",
                                    onclick = "return confirm('Lập hóa đơn cho phiếu " + item.MAPHIEUDAT + "?');"
                                })
                            }

                            if (!daHuy && !daHoanThanh)
                            {
                                @Html.ActionLink("Hỗ trợ hủy", "HoTroHuySan", "PhieuDatSanNV65134364", new { id = item.MAPHIEUDAT }, new
                                {
                                    @class = "btn-action btn-cancel"
                                })
                            }
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-card">
            Không tìm thấy phiếu đặt sân nào.
        </div>
    }
</div>

@{
    int currentPage = ViewBag.CurrentPage == null ? 1 : (int)ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages == null ? 1 : (int)ViewBag.TotalPages;
    int pageSize = ViewBag.PageSize == null ? 10 : (int)ViewBag.PageSize;
    int totalItems = ViewBag.TotalItems == null ? 0 : (int)ViewBag.TotalItems;

    int fromItem = totalItems == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    int toItem = currentPage * pageSize;

    if (toItem > totalItems)
    {
        toItem = totalItems;
    }

    int startPage = currentPage - 2;
    int endPage = currentPage + 2;

    if (startPage < 1)
    {
        startPage = 1;
    }

    if (endPage > totalPages)
    {
        endPage = totalPages;
    }
}

@if (totalItems > 0)
{
    <div class="pagination-wrap">
        <div class="pagination-info">
            Hiển thị @fromItem - @toItem / @totalItems phiếu
        </div>

        <div class="pagination-list">
            @Html.ActionLink("Trước", "Index", "PhieuDatSanNV65134364",
                new
                {
                    page = currentPage - 1,
                    search = ViewBag.Search,
                    trangThaiPhieu = ViewBag.TrangThaiPhieu,
                    trangThaiThanhToan = ViewBag.TrangThaiThanhToan,
                    ngayDat = ViewBag.NgayDat
                },
                new
                {
                    @class = currentPage <= 1 ? "page-btn disabled" : "page-btn"
                })

            @if (startPage > 1)
            {
                @Html.ActionLink("1", "Index", "PhieuDatSanNV65134364",
                    new
                    {
                        page = 1,
                        search = ViewBag.Search,
                        trangThaiPhieu = ViewBag.TrangThaiPhieu,
                        trangThaiThanhToan = ViewBag.TrangThaiThanhToan,
                        ngayDat = ViewBag.NgayDat
                    },
                    new { @class = "page-btn" })

                if (startPage > 2)
                {
                    <span class="page-btn disabled">...</span>
                }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                @Html.ActionLink(i.ToString(), "Index", "PhieuDatSanNV65134364",
                    new
                    {
                        page = i,
                        search = ViewBag.Search,
                        trangThaiPhieu = ViewBag.TrangThaiPhieu,
                        trangThaiThanhToan = ViewBag.TrangThaiThanhToan,
                        ngayDat = ViewBag.NgayDat
                    },
                    new
                    {
                        @class = i == currentPage ? "page-btn active" : "page-btn"
                    })
            }

            @if (endPage < totalPages)
            {
                if (endPage < totalPages - 1)
                {
                    <span class="page-btn disabled">...</span>
                }

                @Html.ActionLink(totalPages.ToString(), "Index", "PhieuDatSanNV65134364",
                    new
                    {
                        page = totalPages,
                        search = ViewBag.Search,
                        trangThaiPhieu = ViewBag.TrangThaiPhieu,
                        trangThaiThanhToan = ViewBag.TrangThaiThanhToan,
                        ngayDat = ViewBag.NgayDat
                    },
                    new { @class = "page-btn" })
            }

            @Html.ActionLink("Sau", "Index", "PhieuDatSanNV65134364",
                new
                {
                    page = currentPage + 1,
                    search = ViewBag.Search,
                    trangThaiPhieu = ViewBag.TrangThaiPhieu,
                    trangThaiThanhToan = ViewBag.TrangThaiThanhToan,
                    ngayDat = ViewBag.NgayDat
                },
                new
                {
                    @class = currentPage >= totalPages ? "page-btn disabled" : "page-btn"
                })
        </div>
    </div>
}