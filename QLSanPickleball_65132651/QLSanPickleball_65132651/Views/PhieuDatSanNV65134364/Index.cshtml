<div class="filter-card">
    @using (Html.BeginForm("Index", "PhieuDatSanNV65134364", FormMethod.Get))
    {
        <input type="hidden" name="page" value="1" />

        <div class="filter-row">
            <div>
                <label class="form-label">Tìm kiếm</label>
                <input type="text"
                       name="search"
                       class="form-control"
                       value="@ViewBag.Search"
                       placeholder="Mã phiếu, mã nhóm, sân, khách hàng, số điện thoại..." />
            </div>

            <div>
                <label class="form-label">Ngày đặt</label>
