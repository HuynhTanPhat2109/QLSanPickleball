@using System
@using System.Linq
@using System.Collections.Generic
@model IEnumerable<QLSanPickleball_65132651.Models.PHIEUDATSAN>

@{
    ViewBag.Title = "Phiếu đặt sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    var tienDichVuTheoPhieu = ViewBag.TienDichVuTheoPhieu as Dictionary<string, decimal>;
}

@functions {
    public string LayMaNhomTuGhiChu(string ghiChu)
    {
        if (string.IsNullOrWhiteSpace(ghiChu))
        {
            return "";
        }

        int viTri = ghiChu.IndexOf("GRP");

        if (viTri < 0)
        {
            return "";
        }

        string chuoiTuGRP = ghiChu.Substring(viTri);

        int viTriKhoangTrang = chuoiTuGRP.IndexOf(" ");
        if (viTriKhoangTrang > 0)
        {
            chuoiTuGRP = chuoiTuGRP.Substring(0, viTriKhoangTrang);
        }

        int viTriGach = chuoiTuGRP.IndexOf("|");
        if (viTriGach > 0)
        {
            chuoiTuGRP = chuoiTuGRP.Substring(0, viTriGach);
        }

        return chuoiTuGRP.Trim();
    }

    public string LayKhoaNhom(QLSanPickleball_65132651.Models.PHIEUDATSAN p)
    {
        string maNhom = LayMaNhomTuGhiChu(p.GHICHU);

        if (!string.IsNullOrWhiteSpace(maNhom))
        {
            return maNhom;
        }

        return p.MAPHIEUDAT;
    }

    public string LayTrangThaiDaiDien(IEnumerable<QLSanPickleball_65132651.Models.PHIEUDATSAN> ds)
    {
        if (ds.Any(p =>
            p.TRANGTHAIPHIEU == "Chờ xác nhận" ||
            p.TRANGTHAIPHIEU == "Chờ duyệt" ||
            p.TRANGTHAITHANHTOAN == "Chờ xác nhận chuyển khoản"))
        {
            return "Chờ xác nhận";
        }

        if (ds.Any(p => p.TRANGTHAIPHIEU == "Đang sử dụng"))
        {
            return "Đang sử dụng";
        }

        if (ds.Any(p => p.TRANGTHAIPHIEU == "Đã xác nhận"))
        {
            return "Đã xác nhận";
        }

        if (ds.Any(p => p.TRANGTHAIPHIEU == "Hoàn thành"))
        {
            return "Hoàn thành";
        }

        if (ds.Any(p =>
            p.TRANGTHAIPHIEU == "Đã hủy" ||
            p.TRANGTHAIPHIEU == "Đã huỷ" ||
            p.TRANGTHAIPHIEU == "Hủy" ||
            p.TRANGTHAIPHIEU == "Huy" ||
            p.TRANGTHAIPHIEU == "DaHuy" ||
            p.TRANGTHAIPHIEU == "Khách không đến" ||
            p.TRANGTHAIPHIEU == "Hủy do bảo trì"))
        {
            return "Đã hủy";
        }

        return ds.First().TRANGTHAIPHIEU;
    }

    public string LayThanhToanDaiDien(IEnumerable<QLSanPickleball_65132651.Models.PHIEUDATSAN> ds)
    {
        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Hoàn cọc 100%"))
        {
            return "Hoàn cọc 100%";
        }

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Hoàn cọc 50%"))
        {
            return "Hoàn cọc 50%";
        }

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Hoàn cọc 20%"))
        {
            return "Hoàn cọc 20%";
        }

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Không hoàn cọc"))
        {
            return "Không hoàn cọc";
        }

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Chờ xác nhận chuyển khoản"))
        {
            return "Chờ xác nhận chuyển khoản";
        }

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Đã đặt cọc"))
        {
            return "Đã đặt cọc";
        }

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Đã thanh toán 100%"))
        {
            return "Đã thanh toán 100%";
        }

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Đã hủy" || p.TRANGTHAITHANHTOAN == "Đã huỷ"))
        {
            return "Đã hủy";
        }

        return ds.First().TRANGTHAITHANHTOAN;
    }

    public int LayThuTuSapXep(string trangThaiPhieu, string trangThaiThanhToan)
    {
        if (trangThaiPhieu == "Chờ xác nhận" ||
            trangThaiPhieu == "Chờ duyệt" ||
            trangThaiThanhToan == "Chờ xác nhận chuyển khoản")
        {
            return 1;
        }

        if (trangThaiPhieu == "Đã xác nhận" || trangThaiPhieu == "Đang sử dụng")
        {
            return 2;
        }

        if (trangThaiPhieu == "Hoàn thành")
        {
            return 3;
        }

        if (trangThaiPhieu == "Đã hủy" ||
            trangThaiPhieu == "Đã huỷ" ||
            trangThaiPhieu == "Hủy" ||
            trangThaiPhieu == "Huy" ||
            trangThaiPhieu == "DaHuy" ||
            trangThaiPhieu == "Khách không đến" ||
            trangThaiPhieu == "Hủy do bảo trì" ||
            trangThaiThanhToan == "Hoàn cọc 100%" ||
            trangThaiThanhToan == "Hoàn cọc 50%" ||
            trangThaiThanhToan == "Hoàn cọc 20%" ||
            trangThaiThanhToan == "Không hoàn cọc" ||
            trangThaiThanhToan == "Đã hủy" ||
            trangThaiThanhToan == "Đã huỷ")
        {
            return 4;
        }

        return 5;
    }

    public string FormatTime(TimeSpan time)
    {
        return time.ToString(@"hh\:mm");
    }
}

