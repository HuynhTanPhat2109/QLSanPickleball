@using System
@using System.Linq
@using System.Collections.Generic
@model IEnumerable<QLSanPickleball_65132651.Models.PHIEUDATSAN>

@{
    ViewBag.Title = "Phiếu đặt sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    var tienDichVuTheoPhieu = ViewBag.TienDichVuTheoPhieu as Dictionary<string, decimal>;
}

@functions {
    public string LayMaNhomTuGhiChu(string ghiChu)
    {
        if (string.IsNullOrWhiteSpace(ghiChu))
        {
            return "";
        }

        int viTri = ghiChu.IndexOf("GRP");

        if (viTri < 0)
        {
            return "";
        }

        string chuoiTuGRP = ghiChu.Substring(viTri);

        int viTriKhoangTrang = chuoiTuGRP.IndexOf(" ");
        if (viTriKhoangTrang > 0)
        {
            chuoiTuGRP = chuoiTuGRP.Substring(0, viTriKhoangTrang);
        }

        int viTriGach = chuoiTuGRP.IndexOf("|");
        if (viTriGach > 0)
        {
            chuoiTuGRP = chuoiTuGRP.Substring(0, viTriGach);
        }

        return chuoiTuGRP.Trim();
    }
    public string LayKhoaNhom(QLSanPickleball_65132651.Models.PHIEUDATSAN p)
    {
        string maNhom = LayMaNhomTuGhiChu(p.GHICHU);

        if (!string.IsNullOrWhiteSpace(maNhom))
        {
            return maNhom;
        }

        return p.MAPHIEUDAT;
    }

    public string LayTrangThaiDaiDien(IEnumerable<QLSanPickleball_65132651.Models.PHIEUDATSAN> ds)
    {
        if (ds.Any(p => p.TRANGTHAIPHIEU == "Chờ xác nhận" || p.TRANGTHAIPHIEU == "Chờ duyệt"))
            return "Chờ xác nhận";

        if (ds.Any(p => p.TRANGTHAIPHIEU == "Đã xác nhận"))
            return "Đã xác nhận";

        if (ds.Any(p => p.TRANGTHAIPHIEU == "Hoàn thành"))
            return "Hoàn thành";

        if (ds.Any(p => p.TRANGTHAIPHIEU == "Đã hủy" || p.TRANGTHAIPHIEU == "Đã huỷ" || p.TRANGTHAIPHIEU == "Hủy" || p.TRANGTHAIPHIEU == "Huy" || p.TRANGTHAIPHIEU == "DaHuy"))
            return "Đã hủy";

        return ds.First().TRANGTHAIPHIEU;
    }

    public string LayThanhToanDaiDien(IEnumerable<QLSanPickleball_65132651.Models.PHIEUDATSAN> ds)
    {
        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Chờ xác nhận chuyển khoản"))
            return "Chờ xác nhận chuyển khoản";

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Đã đặt cọc"))
            return "Đã đặt cọc";

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Đã thanh toán 100%"))
            return "Đã thanh toán 100%";

        if (ds.Any(p => p.TRANGTHAITHANHTOAN == "Đã hủy" || p.TRANGTHAITHANHTOAN == "Đã huỷ"))
            return "Đã hủy";

        return ds.First().TRANGTHAITHANHTOAN;
    }

    public string FormatTime(TimeSpan time)
    {
        return time.ToString(@"hh\:mm");
    }
}

