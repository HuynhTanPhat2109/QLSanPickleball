@using System
@using System.Linq
@using System.Collections.Generic
@model QLSanPickleball_65132651.Models.PHIEUDATSAN

@{
    ViewBag.Title = "Chi tiết phiếu đặt sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    var danhSachPhieuCungNhom = ViewBag.DanhSachPhieuCungNhom as IEnumerable<QLSanPickleball_65132651.Models.PHIEUDATSAN>;
    var danhSachDichVu = ViewBag.DanhSachDichVu as IEnumerable<QLSanPickleball_65132651.Models.CHITIETDICHVUDAT>;

    if (danhSachPhieuCungNhom == null || !danhSachPhieuCungNhom.Any())
    {
        danhSachPhieuCungNhom = new List<QLSanPickleball_65132651.Models.PHIEUDATSAN> { Model };
    }

    bool daCoHoaDon = ViewBag.DaCoHoaDon != null && (bool)ViewBag.DaCoHoaDon;

    string tenSan = Model.SAN != null ? Model.SAN.TENSAN : Model.MASAN;
    string loaiSan = Model.SAN != null && Model.SAN.LOAISAN != null ? Model.SAN.LOAISAN.TENLOAISAN : "Không rõ";
    string tenKhach = Model.KHACHHANG != null ? Model.KHACHHANG.HOTENKH : "Khách vãng lai";
    string sdtKhach = Model.KHACHHANG != null ? Model.KHACHHANG.SODIENTHOAIKH : "";
    string emailKhach = Model.KHACHHANG != null ? Model.KHACHHANG.EMAILKH : "";
    string tenNhanVien = Model.NHANVIEN != null ? Model.NHANVIEN.HOTENNV : "Chưa xử lý";

    decimal tongTienSan = ViewBag.TongTienSan == null
        ? danhSachPhieuCungNhom.Sum(p => p.TONGTIENTAMTINH)
        : Convert.ToDecimal(ViewBag.TongTienSan);

    decimal tongTienDichVu = ViewBag.TongTienDichVu == null
        ? (danhSachDichVu != null && danhSachDichVu.Any() ? danhSachDichVu.Sum(x => x.THANHTIEN) : 0m)
        : Convert.ToDecimal(ViewBag.TongTienDichVu);

    decimal tongTamTinh = ViewBag.TongTamTinh == null
        ? tongTienSan + tongTienDichVu
        : Convert.ToDecimal(ViewBag.TongTamTinh);

    string khungGioNhom = ViewBag.KhungGioNhom == null
        ? danhSachPhieuCungNhom.Min(p => p.GIOBATDAU).ToString(@"hh\:mm") + " - " + danhSachPhieuCungNhom.Max(p => p.GIOKETTHUC).ToString(@"hh\:mm")
        : ViewBag.KhungGioNhom.ToString();

    string maNhom = ViewBag.MaNhomDatSan == null ? LayMaNhomTuGhiChu(Model.GHICHU) : ViewBag.MaNhomDatSan.ToString();

    string minhChungPath = LayMinhChungTuGhiChu(Model.GHICHU);
    string tenFileMinhChung = string.IsNullOrWhiteSpace(minhChungPath) ? "" : System.IO.Path.GetFileName(minhChungPath);

    string classPhieu = "st-gray";

    if (Model.TRANGTHAIPHIEU == "Tam_Giu")
    {
        classPhieu = "st-temp";
    }
    else if (Model.TRANGTHAIPHIEU == "Cho_Thanh_Toan")
    {
        classPhieu = "st-pay";
    }
    else if (Model.TRANGTHAIPHIEU == "Chờ duyệt" || Model.TRANGTHAIPHIEU == "Chờ xác nhận")
    {
        classPhieu = "st-wait";
    }
    else if (Model.TRANGTHAIPHIEU == "Đã xác nhận")
    {
        classPhieu = "st-confirm";
    }
    else if (Model.TRANGTHAIPHIEU == "Hoàn thành")
    {
        classPhieu = "st-done";
    }
    else if (Model.TRANGTHAIPHIEU == "Đã hủy" || Model.TRANGTHAIPHIEU == "Đã huỷ" || Model.TRANGTHAIPHIEU == "Hủy" || Model.TRANGTHAIPHIEU == "Huy" || Model.TRANGTHAIPHIEU == "DaHuy" || Model.TRANGTHAIPHIEU == "Hủy do bảo trì")
    {
        classPhieu = "st-cancel";
    }

    string classThanhToan = "st-gray";

    if (Model.TRANGTHAITHANHTOAN == "ChuaThanhToan")
    {
        classThanhToan = "st-temp";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Cho_Chuyen_Khoan")
    {
        classThanhToan = "st-pay";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Chờ xác nhận chuyển khoản")
    {
        classThanhToan = "st-wait";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Đã đặt cọc")
    {
        classThanhToan = "st-confirm";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Đã thanh toán 100%")
    {
        classThanhToan = "st-done";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Đã hủy" || Model.TRANGTHAITHANHTOAN == "Đã huỷ")
    {
        classThanhToan = "st-cancel";
    }

    bool choXacNhan =
        Model.TRANGTHAIPHIEU == "Chờ xác nhận" ||
        Model.TRANGTHAIPHIEU == "Chờ duyệt" ||
        Model.TRANGTHAITHANHTOAN == "Chờ xác nhận chuyển khoản";

    bool daXacNhan = Model.TRANGTHAIPHIEU == "Đã xác nhận";
    bool daHoanThanh = Model.TRANGTHAIPHIEU == "Hoàn thành";

    bool daHuy =
        Model.TRANGTHAIPHIEU == "Đã hủy" ||
        Model.TRANGTHAIPHIEU == "Đã huỷ" ||
        Model.TRANGTHAIPHIEU == "Hủy" ||
        Model.TRANGTHAIPHIEU == "Huy" ||
        Model.TRANGTHAIPHIEU == "DaHuy" ||
        Model.TRANGTHAIPHIEU == "Hủy do bảo trì" ||
        Model.TRANGTHAITHANHTOAN == "Đã hủy" ||
        Model.TRANGTHAITHANHTOAN == "Đã huỷ";

    bool duocSuaDichVu = !daHuy && !daHoanThanh && !daCoHoaDon;
}

@functions {
    public string LayMaNhomTuGhiChu(string ghiChu)
    {
        if (string.IsNullOrWhiteSpace(ghiChu))
        {
            return "";
        }

        int viTri = ghiChu.IndexOf("GRP");

        if (viTri < 0)
        {
            return "";
        }

        string chuoiTuGRP = ghiChu.Substring(viTri);

        int viTriGach = chuoiTuGRP.IndexOf("|");
        if (viTriGach > 0)
        {
            chuoiTuGRP = chuoiTuGRP.Substring(0, viTriGach);
        }

        int viTriKhoangTrang = chuoiTuGRP.IndexOf(" ");
        if (viTriKhoangTrang > 0)
        {
            chuoiTuGRP = chuoiTuGRP.Substring(0, viTriKhoangTrang);
        }

        return chuoiTuGRP.Trim();
    }

    public string LayMinhChungTuGhiChu(string ghiChu)
    {
        if (string.IsNullOrWhiteSpace(ghiChu))
        {
            return "";
        }

        string key = "/Content/Uploads/MinhChungThanhToan/";
        int viTri = ghiChu.IndexOf(key);

        if (viTri < 0)
        {
            return "";
        }

        string path = ghiChu.Substring(viTri);

        int viTriGach = path.IndexOf("|");
        if (viTriGach > 0)
        {
            path = path.Substring(0, viTriGach);
        }

        return path.Trim();
    }
}

