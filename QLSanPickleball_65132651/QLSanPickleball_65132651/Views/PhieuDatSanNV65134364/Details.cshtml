@using System
@using System.Linq
@model QLSanPickleball_65132651.Models.PHIEUDATSAN

@{
    ViewBag.Title = "Chi tiết phiếu đặt sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    var danhSachDichVu = ViewBag.DanhSachDichVu as IEnumerable<QLSanPickleball_65132651.Models.CHITIETDICHVUDAT>;
    bool daCoHoaDon = ViewBag.DaCoHoaDon != null && (bool)ViewBag.DaCoHoaDon;

    string tenSan = Model.SAN != null ? Model.SAN.TENSAN : Model.MASAN;
    string loaiSan = Model.SAN != null && Model.SAN.LOAISAN != null ? Model.SAN.LOAISAN.TENLOAISAN : "Không rõ";
    string tenKhach = Model.KHACHHANG != null ? Model.KHACHHANG.HOTENKH : "Khách vãng lai";
    string sdtKhach = Model.KHACHHANG != null ? Model.KHACHHANG.SODIENTHOAIKH : "";
    string emailKhach = Model.KHACHHANG != null ? Model.KHACHHANG.EMAILKH : "";
    string tenNhanVien = Model.NHANVIEN != null ? Model.NHANVIEN.HOTENNV : "Chưa xử lý";

    decimal tongTienDichVu = 0;
    if (danhSachDichVu != null && danhSachDichVu.Any())
    {
        tongTienDichVu = danhSachDichVu.Sum(x => x.THANHTIEN);
    }

    decimal tongTamTinh = Model.TONGTIENTAMTINH + tongTienDichVu;

    string classPhieu = "st-gray";

    if (Model.TRANGTHAIPHIEU == "Tam_Giu")
    {
        classPhieu = "st-temp";
    }
    else if (Model.TRANGTHAIPHIEU == "Cho_Thanh_Toan")
    {
        classPhieu = "st-pay";
    }
    else if (Model.TRANGTHAIPHIEU == "Chờ duyệt" || Model.TRANGTHAIPHIEU == "Chờ xác nhận")
    {
        classPhieu = "st-wait";
    }
    else if (Model.TRANGTHAIPHIEU == "Đã xác nhận")
    {
        classPhieu = "st-confirm";
    }
    else if (Model.TRANGTHAIPHIEU == "Hoàn thành")
    {
        classPhieu = "st-done";
    }
    else if (Model.TRANGTHAIPHIEU == "Đã hủy" || Model.TRANGTHAIPHIEU == "Đã huỷ" || Model.TRANGTHAIPHIEU == "Hủy" || Model.TRANGTHAIPHIEU == "Huy" || Model.TRANGTHAIPHIEU == "DaHuy" || Model.TRANGTHAIPHIEU == "Khách không đến"|| Model.TRANGTHAIPHIEU == "Hủy do bảo trì")
    {
        classPhieu = "st-cancel";
    }

    string classThanhToan = "st-gray";

    if (Model.TRANGTHAITHANHTOAN == "ChuaThanhToan")
    {
        classThanhToan = "st-temp";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Cho_Chuyen_Khoan")
    {
        classThanhToan = "st-pay";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Chờ xác nhận chuyển khoản")
    {
        classThanhToan = "st-wait";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Đã đặt cọc")
    {
        classThanhToan = "st-confirm";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Đã thanh toán 100%")
    {
        classThanhToan = "st-done";
    }
    else if (Model.TRANGTHAITHANHTOAN == "Đã hủy" || Model.TRANGTHAITHANHTOAN == "Đã huỷ")
    {
        classThanhToan = "st-cancel";
    }

    bool choXacNhan = Model.TRANGTHAIPHIEU == "Chờ xác nhận"
        || Model.TRANGTHAIPHIEU == "Chờ duyệt"
        || Model.TRANGTHAITHANHTOAN == "Chờ xác nhận chuyển khoản";

    bool daXacNhan = Model.TRANGTHAIPHIEU == "Đã xác nhận";
    bool daHoanThanh = Model.TRANGTHAIPHIEU == "Hoàn thành";

    bool daHuy = Model.TRANGTHAIPHIEU == "Đã hủy"
        || Model.TRANGTHAIPHIEU == "Đã huỷ"
        || Model.TRANGTHAIPHIEU == "Hủy"
        || Model.TRANGTHAIPHIEU == "Huy"
        || Model.TRANGTHAIPHIEU == "DaHuy"
        || Model.TRANGTHAITHANHTOAN == "Đã hủy"
        || Model.TRANGTHAIPHIEU == "Khách không đến"
        || Model.TRANGTHAIPHIEU == "Hủy do bảo trì"
        || Model.TRANGTHAITHANHTOAN == "Đã huỷ";

    bool duocSuaDichVu = !daHuy && !daHoanThanh && !daCoHoaDon;

    string maNhom = "";
    string minhChungPath = "";

    if (!string.IsNullOrWhiteSpace(Model.GHICHU))
    {
        int viTriGRP = Model.GHICHU.IndexOf("GRP");

        if (viTriGRP >= 0)
        {
            string temp = Model.GHICHU.Substring(viTriGRP).Trim();

            int viTriSpace = temp.IndexOf(" ");
            int viTriGach = temp.IndexOf("|");

            int viTriCat = -1;

            if (viTriSpace > 0 && viTriGach > 0)
            {
                viTriCat = Math.Min(viTriSpace, viTriGach);
            }
            else if (viTriSpace > 0)
            {
                viTriCat = viTriSpace;
            }
            else if (viTriGach > 0)
            {
                viTriCat = viTriGach;
            }

            maNhom = viTriCat > 0 ? temp.Substring(0, viTriCat).Trim() : temp.Trim();
        }

        if (Model.GHICHU.Contains("Minh chứng:"))
        {
            int viTri = Model.GHICHU.IndexOf("Minh chứng:");
            minhChungPath = Model.GHICHU.Substring(viTri + "Minh chứng:".Length).Trim();

            int viTriGach2 = minhChungPath.IndexOf("|");
            if (viTriGach2 > 0)
            {
                minhChungPath = minhChungPath.Substring(0, viTriGach2).Trim();
            }
        }
    }

    string tenFileMinhChung = "";
    if (!string.IsNullOrWhiteSpace(minhChungPath))
    {
        tenFileMinhChung = System.IO.Path.GetFileName(minhChungPath);
    }
}

<style>
