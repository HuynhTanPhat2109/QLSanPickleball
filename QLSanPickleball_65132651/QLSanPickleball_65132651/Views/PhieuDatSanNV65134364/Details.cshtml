    }

    .card-title {
        font-size: 18px;
        font-weight: 900;
        color: #111827;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
