@model QLSanPickleball_65132651.Models.KHACHHANG

@{
    ViewBag.Title = "Xóa khách hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .delete-wrapper {
        max-width: 850px;
        margin: 0 auto
    }

    .delete-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 22px rgba(0,0,0,.05)
    }

    .delete-head {
        background: #dc2626;
        color: white;
        padding: 24px;
        display: flex;
        gap: 16px;
        align-items: center
    }

    .warning {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: rgba(255,255,255,.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        font-weight: 900
    }

    .delete-body {
        padding: 24px
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-bottom: 18px
    }

    .info-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 14px
    }

    .label {
        color: #6b7280;
        font-weight: 900;
        font-size: 12px;
        text-transform: uppercase
    }

    .value {
        color: #111827;
        font-weight: 900;
        margin-top: 6px
    }

    .note {
        background: #fef3c7;
        color: #92400e;
        border: 1px solid #fde68a;
        border-radius: 12px;
        padding: 14px;
        margin-bottom: 18px;
        font-weight: 700
    }

    .action-bar {
        display: flex;
        justify-content: flex-end;
        gap: 10px
    }

    .btn-delete {
        background: #dc2626;
        color: white;
        border: none;
        padding: 11px 18px;
        border-radius: 10px;
        font-weight: 900
    }

    .btn-back {
        background: #6b7280;
        color: white !important;
        padding: 11px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 900
    }

    .btn-detail {
        background: #0ea5e9;
        color: white !important;
        padding: 11px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 900
    }
</style>

<div class="delete-wrapper">
    <div class="delete-card">
        <div class="delete-head">
            <div class="warning">!</div>
            <div>
                <h3>Xác nhận xóa khách hàng</h3>
                <p>Bạn có chắc muốn xóa khách hàng này không?</p>
            </div>
        </div>

        <div class="delete-body">
            <div class="note">
                Nếu khách hàng đã có lịch sử đặt sân, hệ thống sẽ không xóa dữ liệu mà chuyển tài khoản sang trạng thái Đã khóa.
            </div>

            <div class="info-grid">
                <div class="info-item"><div class="label">Mã khách hàng</div><div class="value">@Model.MAKH</div></div>
                <div class="info-item"><div class="label">Họ tên</div><div class="value">@Model.HOTENKH</div></div>
                <div class="info-item"><div class="label">Số điện thoại</div><div class="value">@Model.SODIENTHOAIKH</div></div>
                <div class="info-item"><div class="label">Email</div><div class="value">@Model.EMAILKH</div></div>
                <div class="info-item"><div class="label">Số lần bùng</div><div class="value">@Model.SOLANBUNG</div></div>
                <div class="info-item"><div class="label">Trạng thái</div><div class="value">@Model.TRANGTHAITK</div></div>
            </div>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="action-bar">
                    @Html.ActionLink("Quay lại", "Index", null, new { @class = "btn-back" })
                    @Html.ActionLink("Chi tiết", "Details", new { id = Model.MAKH }, new { @class = "btn-detail" })

                    <button type="submit"
                            class="btn-delete"
                            onclick="return confirm('Xác nhận xóa hoặc khóa khách hàng này?');">
                        Xác nhận xóa
                    </button>
                </div>
            }
        </div>
    </div>
</div>