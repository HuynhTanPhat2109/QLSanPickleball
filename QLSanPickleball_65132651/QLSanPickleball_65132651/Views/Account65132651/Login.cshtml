@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Army Pickleball</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            /* Nền gradient di chuyển tạo cảm giác mượt mà */
            background: linear-gradient(-45deg, #1e5631, #2d7a45, #a4eb5d, #1e5631);
            background-size: 400% 400%;
            animation: gradient 15s ease infinite;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        @@keyframes gradient {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .login-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px); /* Hiệu ứng kính mờ */
            border-radius: 25px;
            padding: 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.2);
            border: 1px solid rgba(255, 255, 255, 0.3);
            animation: zoomIn 0.5s ease;
        }

        @@keyframes zoomIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        .brand-logo {
            width: 80px;
            height: 80px;
            background: #1e5631;
            color: #a4eb5d;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            margin: 0 auto 20px;
            box-shadow: 0 10px 20px rgba(30, 86, 49, 0.3);
        }

        .form-label {
            font-weight: 600;
            color: #333;
            font-size: 14px;
        }

        .input-group-text {
            background: transparent;
            border-right: none;
            border-radius: 10px 0 0 10px;
            color: #1e5631;
        }

        .form-control {
            border-left: none;
            border-radius: 0 10px 10px 0;
            padding: 10px;
        }

            .form-control:focus {
                box-shadow: none;
                border-color: #dee2e6;
            }

        .btn-login {
            background: #1e5631;
            border: none;
            border-radius: 10px;
            padding: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            transition: 0.3s;
            color: white;
        }

            .btn-login:hover {
                background: #153e23;
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
                color: #a4eb5d;
            }

        .register-link {
            color: #1e5631;
            text-decoration: none;
            font-weight: 700;
        }

            .register-link:hover {
                text-decoration: underline;
            }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="brand-logo">
            <i class="fas fa-table-tennis-paddle-ball"></i>
        </div>
        <h3 class="text-center fw-bold mb-1" style="color: #1e5631;">ARMY PICKLEBALL</h3>
        <p class="text-center text-muted mb-4 small">Chào mừng bạn quay trở lại!</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2 small text-center mb-4">
                <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
            </div>
        }

        @using (Html.BeginForm("Login", "Account65132651", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Tài khoản / Số điện thoại</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                    <input type="text" name="username" class="form-control" placeholder="Nhập tên hoặc SĐT..." required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>
                <div class="d-flex">
                    <a href="#" class="small text-muted text-decoration-none ms-auto mt-2">Quên mật khẩu?</a>
                </div>
            </div>

            <button type="submit" class="btn btn-login w-100 mb-4">
                Đăng nhập
            </button>

            <div class="d-flex text-center align-items-center justify-content-center">
                <p class="small mb-0 me-1">Bạn chưa có tài khoản?</p>
                <a href="@Url.Action("Register", "Account65132651")" class="register-link small">Đăng ký ngay</a>
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>