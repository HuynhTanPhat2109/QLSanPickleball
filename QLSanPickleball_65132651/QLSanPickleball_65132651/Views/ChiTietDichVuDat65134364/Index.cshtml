@using System
@using System.Linq
@model IEnumerable<QLSanPickleball_65132651.Models.CHITIETDICHVUDAT>

@{
    ViewBag.Title = "Dịch vụ sử dụng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .page-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 12px;
        flex-wrap: wrap;
    }

        .page-head h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        margin-top: 4px;
        color: #6b7280;
        font-size: 14px;
    }

    .total-box {
        background: linear-gradient(135deg, #0f766e, #14b8a6);
        color: white;
        padding: 16px 22px;
        border-radius: 18px;
        min-width: 260px;
        box-shadow: 0 10px 25px rgba(20, 184, 166, 0.22);
    }

    .total-label {
        font-size: 13px;
        font-weight: 800;
        color: #ccfbf1;
        text-transform: uppercase;
    }

    .total-value {
        font-size: 26px;
        font-weight: 900;
        margin-top: 5px;
    }

    .filter-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 18px;
        margin-bottom: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
    }

    .filter-row {
        display: grid;
        grid-template-columns: 2fr 1fr auto auto;
        gap: 12px;
        align-items: end;
    }

    .form-label {
        display: block;
        font-weight: 800;
        color: #374151;
        margin-bottom: 6px;
        font-size: 13px;
    }

    .form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        outline: none;
        background: white;
        font-size: 14px;
    }

    .btn-filter,
    .btn-reset {
        border: none;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 900;
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-filter {
        background: #0ea5e9;
        color: white;
    }

    .btn-reset {
        background: #6b7280;
        color: white !important;
    }

    .service-list {
        display: grid;
        gap: 14px;
    }

    .service-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        padding: 16px 18px;
        display: grid;
        grid-template-columns: 110px 1.3fr 1.3fr 1.2fr 1fr 130px;
        gap: 16px;
        align-items: center;
    }

    .service-avatar {
        width: 66px;
        height: 66px;
        border-radius: 18px;
        background: linear-gradient(135deg, #f59e0b, #b45309);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 16px;
        box-shadow: 0 8px 16px rgba(245, 158, 11, 0.25);
    }

    .main-text {
        font-size: 15px;
        font-weight: 900;
        color: #111827;
    }

    .sub-text {
        margin-top: 4px;
        font-size: 13px;
        color: #6b7280;
        line-height: 1.35;
    }

    .info-label {
        color: #6b7280;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .money {
        color: #047857;
        font-size: 19px;
        font-weight: 900;
    }

    .badge-qty {
        display: inline-block;
        background: #eef2ff;
        color: #1d4ed8;
        padding: 7px 11px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 900;
    }

    .btn-action {
        padding: 8px 12px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 13px;
        color: white !important;
        display: inline-block;
        font-weight: 900;
        text-align: center;
        min-width: 76px;
    }

    .btn-detail {
        background: #0ea5e9;
    }

    .btn-action:hover,
    .btn-reset:hover {
        opacity: 0.88;
        color: white;
        text-decoration: none;
    }

    .empty-card {
        background: white;
        border: 1px dashed #cbd5e1;
        border-radius: 18px;
        padding: 38px;
        text-align: center;
        color: #64748b;
        font-weight: 800;
    }

    .pagination-wrap {
        margin-top: 20px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 14px 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.05);
    }

    .pagination-info {
        color: #6b7280;
        font-size: 14px;
        font-weight: 800;
    }

    .pagination-list {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .page-btn {
        min-width: 38px;
        height: 38px;
        padding: 0 12px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        background: #ffffff;
        color: #374151 !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        font-size: 13px;
    }

        .page-btn.active {
            background: #2563eb;
            border-color: #2563eb;
            color: white !important;
        }

        .page-btn.disabled {
            opacity: 0.45;
            pointer-events: none;
            cursor: not-allowed;
        }

    @@media(max-width: 1100px) {
        .service-card {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .filter-row {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width: 700px) {
        .service-card,
        .filter-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-head">
    <div>
         <div class="page-sub">Hiển thị theo thời gian đặt sân mới nhất lên trước để kiểm tra dễ hơn.</div>
    </div>

    <div class="total-box">
        <div class="total-label">Tổng tiền dịch vụ</div>
        <div class="total-value">@(((decimal)(ViewBag.TongTienDichVu ?? 0m)).ToString("N0")) đ</div>
    </div>
</div>

<div class="filter-card">
    @using (Html.BeginForm("Index", "ChiTietDichVuDat65134364", FormMethod.Get))
    {
        <input type="hidden" name="page" value="1" />

        <div class="filter-row">
            <div>
                <label class="form-label">Tìm kiếm</label>
                <input type="text"
                       name="search"
                       class="form-control"
                       value="@ViewBag.Search"
                       placeholder="Mã phiếu, dịch vụ, khách hàng, số điện thoại, sân..." />
            </div>

            <div>
                <label class="form-label">Ngày đặt</label>
                <input type="date"
                       name="ngayDat"
                       class="form-control"
                       value="@ViewBag.NgayDat" />
            </div>

            <div>
                <button type="submit" class="btn-filter">Lọc</button>
            </div>

            <div>
                @Html.ActionLink("Làm mới", "Index", "ChiTietDichVuDat65134364", null, new { @class = "btn-reset" })
            </div>
        </div>
    }
</div>

<div class="service-list">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model
            .OrderByDescending(c => c.PHIEUDATSAN != null ? c.PHIEUDATSAN.NGAYDAT : DateTime.MinValue)
            .ThenByDescending(c => c.PHIEUDATSAN != null ? c.PHIEUDATSAN.GIOBATDAU : TimeSpan.Zero))
        {
            string tenDV = item.DICHVU != null ? item.DICHVU.TENDV : item.MADV;
            string donVi = item.DICHVU != null ? item.DICHVU.DONVITINH : "";

            string tenKhach = item.PHIEUDATSAN != null && item.PHIEUDATSAN.KHACHHANG != null
                ? item.PHIEUDATSAN.KHACHHANG.HOTENKH
                : "Không rõ";

            string sdtKhach = item.PHIEUDATSAN != null && item.PHIEUDATSAN.KHACHHANG != null
                ? item.PHIEUDATSAN.KHACHHANG.SODIENTHOAIKH
                : "";

            string tenSan = item.PHIEUDATSAN != null && item.PHIEUDATSAN.SAN != null
                ? item.PHIEUDATSAN.SAN.TENSAN
                : "Không rõ";

            string thoiGian = "";

            if (item.PHIEUDATSAN != null)
            {
                thoiGian = item.PHIEUDATSAN.NGAYDAT.ToString("dd/MM/yyyy")
                    + " • "
                    + item.PHIEUDATSAN.GIOBATDAU.ToString(@"hh\:mm")
                    + " - "
                    + item.PHIEUDATSAN.GIOKETTHUC.ToString(@"hh\:mm");
            }

            <div class="service-card">
                <div class="service-avatar">@item.MADV</div>

                <div>
                    <div class="info-label">Dịch vụ</div>
                    <div class="main-text">@tenDV</div>
                    <div class="sub-text">Đơn vị: @(string.IsNullOrWhiteSpace(donVi) ? "Không có" : donVi)</div>
                </div>

                <div>
                    <div class="info-label">Khách hàng</div>
                    <div class="main-text">@tenKhach</div>
                    <div class="sub-text">@(string.IsNullOrWhiteSpace(sdtKhach) ? "Không có SĐT" : sdtKhach)</div>
                </div>

                <div>
                    <div class="info-label">Thời gian sử dụng</div>
                    <div class="main-text">@tenSan</div>
                    <div class="sub-text">@thoiGian</div>
                    <div class="sub-text">Phiếu: @item.MAPHIEUDAT</div>
                </div>

                <div>
                    <div class="info-label">Số lượng</div>
                    <span class="badge-qty">@item.SOLUONG</span>
                    <div class="sub-text">Đơn giá: @item.DONGIA.ToString("N0") đ</div>
                </div>

                <div>
                    <div class="info-label">Thành tiền</div>
                    <div class="money">@item.THANHTIEN.ToString("N0") đ</div>
                    @Html.ActionLink("Xem phiếu", "Details", "PhieuDatSanNV65134364", new { id = item.MAPHIEUDAT }, new { @class = "btn-action btn-detail" })
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-card">Chưa có dịch vụ nào được sử dụng.</div>
    }
</div>

@{
    int currentPage = ViewBag.CurrentPage == null ? 1 : (int)ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages == null ? 1 : (int)ViewBag.TotalPages;
    int pageSize = ViewBag.PageSize == null ? 10 : (int)ViewBag.PageSize;
    int totalItems = ViewBag.TotalItems == null ? 0 : (int)ViewBag.TotalItems;

    int fromItem = totalItems == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    int toItem = currentPage * pageSize;

    if (toItem > totalItems)
    {
        toItem = totalItems;
    }

    int startPage = currentPage - 2;
    int endPage = currentPage + 2;

    if (startPage < 1) { startPage = 1; }
    if (endPage > totalPages) { endPage = totalPages; }
}

@if (totalItems > 0)
{
    <div class="pagination-wrap">
        <div class="pagination-info">
            Hiển thị @fromItem - @toItem / @totalItems dịch vụ sử dụng
        </div>

        <div class="pagination-list">
            @Html.ActionLink("Trước", "Index", "ChiTietDichVuDat65134364",
                new { page = currentPage - 1, search = ViewBag.Search, ngayDat = ViewBag.NgayDat },
                new { @class = currentPage <= 1 ? "page-btn disabled" : "page-btn" })

            @for (int i = startPage; i <= endPage; i++)
            {
                @Html.ActionLink(i.ToString(), "Index", "ChiTietDichVuDat65134364",
                    new { page = i, search = ViewBag.Search, ngayDat = ViewBag.NgayDat },
                    new { @class = i == currentPage ? "page-btn active" : "page-btn" })
            }

            @Html.ActionLink("Sau", "Index", "ChiTietDichVuDat65134364",
                new { page = currentPage + 1, search = ViewBag.Search, ngayDat = ViewBag.NgayDat },
                new { @class = currentPage >= totalPages ? "page-btn disabled" : "page-btn" })
        </div>
    </div>
}