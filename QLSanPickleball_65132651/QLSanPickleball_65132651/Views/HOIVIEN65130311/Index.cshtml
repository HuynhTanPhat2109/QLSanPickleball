@model IEnumerable<QLSanPickleball_65132651.Models.HOIVIEN>

@{
    ViewBag.Title = "Quản lý hội viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

        .page-header h2 {
            margin: 0;
            font-size: 24px;
            font-weight: bold;
            color: #111827;
        }

    .btn-add {
        background: #2563eb;
        color: white !important;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

        .btn-add:hover {
            background: #1d4ed8;
            text-decoration: none;
            color: white;
        }

    .filter-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 18px;
        margin-bottom: 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .filter-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr auto auto;
        gap: 12px;
        align-items: end;
    }

    .form-label {
        font-weight: bold;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }

    .form-control,
    .form-select {
        width: 100%;
        padding: 9px 10px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        outline: none;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #2563eb;
        }

    .btn-search {
        background: #16a34a;
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
    }

        .btn-search:hover {
            background: #15803d;
        }

    .btn-reset {
        display: inline-block;
        background: #6b7280;
        color: white !important;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

        .btn-reset:hover {
            background: #4b5563;
            text-decoration: none;
        }

    .table-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        overflow-x: auto;
    }

    .table th {
        background: #f3f4f6;
        text-align: center;
        vertical-align: middle;
    }

    .table td {
        vertical-align: middle;
        white-space: nowrap;
    }

    .badge-status {
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: bold;
        display: inline-block;
    }

    .status-paid {
        background: #dcfce7;
        color: #166534;
    }

    .status-wait {
        background: #fef3c7;
        color: #92400e;
    }

    .status-unpaid {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-reject {
        background: #e5e7eb;
        color: #374151;
    }

    .action-group {
        display: flex;
        gap: 6px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 6px 10px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
        color: white !important;
        display: inline-block;
    }

    .btn-detail {
        background: #0ea5e9;
    }

    .btn-edit {
        background: #f59e0b;
    }

    .btn-paid {
        background: #16a34a;
    }

    .btn-approve {
        background: #2563eb;
    }

    .btn-reject {
        background: #dc2626;
    }

    .btn-action:hover {
        opacity: 0.85;
        text-decoration: none;
        color: white;
    }

    .alert-success-custom {
        background: #dcfce7;
        color: #166534;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 15px;
    }

    .alert-error-custom {
        background: #fee2e2;
        color: #991b1b;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 15px;
    }

    @@media(max-width: 1000px) {
        .filter-row {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width: 600px) {
        .filter-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-header">
    <h2>Quản lý hội viên</h2>

    @Html.ActionLink("+ Thêm hội viên", "Create", null, new { @class = "btn-add" })

</div>

@if (TempData["Success"] != null)
{<div class="alert-success-custom">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{<div class="alert-error-custom">
        @TempData["Error"]
    </div>
}

<div class="filter-card">
    @using (Html.BeginForm("Index", "HOIVIEN65130311", FormMethod.Get))
    {
        <div class="filter-row">
            <div>
                <label class="form-label">Tìm kiếm</label>
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Nhập mã HV, tên KH, SĐT..." />
            </div>

            ```
            <div>
                <label class="form-label">Loại thẻ</label>
                <select name="loaiThe" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="Thường">Thường</option>
                    <option value="VIP">VIP</option>
                    <option value="Luxury">Luxury</option>
                </select>
            </div>

            <div>
                <label class="form-label">Trạng thái phí</label>
                <select name="trangThaiPhi" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="Chờ duyệt">Chờ duyệt</option>
                    <option value="Chưa thanh toán">Chưa thanh toán</option>
                    <option value="Đã thanh toán">Đã thanh toán</option>
                    <option value="Từ chối">Từ chối</option>
                </select>
            </div>

            <div>
                <button type="submit" class="btn-search">Lọc</button>
            </div>

            <div>
                @Html.ActionLink("Làm mới", "Index", null, new { @class = "btn-reset" })
            </div>
        </div>
    }
    ```

</div>

<div class="table-card">
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Mã HV</th>
                <th>Khách hàng</th>
                <th>Loại thẻ</th>
                <th>Ngày bắt đầu</th>
                <th>Ngày kết thúc</th>
                <th>Phí đăng ký</th>
                <th>Trạng thái phí</th>
                <th>Nhân viên</th>
                <th>Chức năng</th>
            </tr>
        </thead>

        ```
        <tbody>
            @foreach (var item in Model)
            {
                string statusClass = "status-wait";

                if (item.TRANGTHAIPHI == "Đã thanh toán")
                {
                    statusClass = "status-paid";
                }
                else if (item.TRANGTHAIPHI == "Chưa thanh toán")
                {
                    statusClass = "status-unpaid";
                }
                else if (item.TRANGTHAIPHI == "Từ chối")
                {
                    statusClass = "status-reject";
                }
                else if (item.TRANGTHAIPHI == "Đã duyệt")
                {
                    statusClass = "status-paid";
                }

                <tr>
                    <td>@item.MAHOIVIEN</td>
                    <td>@item.KHACHHANG.HOTENKH</td>
                    <td>@item.LOAITHE</td>
                    <td>@item.NGAYBATDAU.ToString("dd/MM/yyyy")</td>
                    <td>@item.NGAYKETTHUC.ToString("dd/MM/yyyy")</td>
                    <td>@String.Format("{0:N0} đ", item.PHIDANGKY)</td>

                    <td class="text-center">
                        <span class="badge-status @statusClass">
                            @item.TRANGTHAIPHI
                        </span>
                    </td>

                    <td>
                        @(item.NHANVIEN != null ? item.NHANVIEN.HOTENNV : "")
                    </td>

                    <td>
                        <div class="action-group">
                            @Html.ActionLink("Chi tiết", "Details", new { id = item.MAHOIVIEN }, new { @class = "btn-action btn-detail" })

                            @Html.ActionLink("Sửa", "Edit", new { id = item.MAHOIVIEN }, new { @class = "btn-action btn-edit" })

                            @if (item.TRANGTHAIPHI == "Chờ duyệt" || item.TRANGTHAIPHI == "Chưa thanh toán")
                            {
                                @Html.ActionLink("Đóng phí", "XacNhanDongPhi", new { id = item.MAHOIVIEN }, new { @class = "btn-action btn-paid" })
                            }

                            @if (item.TRANGTHAIPHI == "Đã thanh toán")
                            {
                                @Html.ActionLink("Duyệt", "Duyet", new { id = item.MAHOIVIEN }, new { @class = "btn-action btn-approve" })
                            }

                            @if (item.TRANGTHAIPHI != "Từ chối")
                            {
                                @Html.ActionLink("Từ chối", "TuChoi", new { id = item.MAHOIVIEN }, new { @class = "btn-action btn-reject" })
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    ```

</div>
