@model QLSanPickleball_65132651.Models.HOIVIEN

@{
    ViewBag.Title = "Xóa hội viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .delete-wrapper {
        max-width: 850px;
        margin: 0 auto;
    }

    .delete-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .delete-header {
        background: #dc2626;
        color: white;
        padding: 24px;
        display: flex;
        gap: 16px;
        align-items: center;
    }

    .warning-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: bold;
    }

    .delete-body {
        padding: 24px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 20px;
    }

    .info-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 15px;
    }

    .info-label {
        font-size: 13px;
        color: #6b7280;
        font-weight: bold;
        margin-bottom: 6px;
        text-transform: uppercase;
    }

    .info-value {
        font-size: 16px;
        font-weight: 600;
        color: #111827;
    }

    .note-box {
        background: #fef3c7;
        border: 1px solid #fde68a;
        color: #92400e;
        padding: 14px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .action-bar {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn-delete {
        background: #dc2626;
        color: white;
        border: none;
        padding: 11px 18px;
        border-radius: 8px;
        font-weight: bold;
    }

    .btn-back {
        background: #6b7280;
        color: white !important;
        padding: 11px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-detail {
        background: #0ea5e9;
        color: white !important;
        padding: 11px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }
</style>

<div class="delete-wrapper">

    ```
    <div class="delete-card">

        <div class="delete-header">
            <div class="warning-icon">!</div>

            <div>
                <h3>Xác nhận xóa hội viên</h3>
                <p>Bạn có chắc muốn xóa hội viên này không?</p>
            </div>
        </div>

        <div class="delete-body">

            <div class="note-box">
                Hành động này có thể ảnh hưởng tới dữ liệu lịch sử thanh toán và ưu đãi hội viên.
            </div>

            <div class="info-grid">

                <div class="info-item">
                    <div class="info-label">Mã hội viên</div>
                    <div class="info-value">@Model.MAHOIVIEN</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Khách hàng</div>
                    <div class="info-value">@Model.KHACHHANG.HOTENKH</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Loại thẻ</div>
                    <div class="info-value">@Model.LOAITHE</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Phí đăng ký</div>
                    <div class="info-value">
                        @String.Format("{0:N0} đ", Model.PHIDANGKY)
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">Ngày bắt đầu</div>
                    <div class="info-value">
                        @Model.NGAYBATDAU.ToString("dd/MM/yyyy")
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">Ngày kết thúc</div>
                    <div class="info-value">
                        @Model.NGAYKETTHUC.ToString("dd/MM/yyyy")
                    </div>
                </div>

            </div>

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="action-bar">

                    @Html.ActionLink("Quay lại",
                        "Index",
                        null,
                        new { @class = "btn-back" })

                    @Html.ActionLink("Chi tiết",
                        "Details",
                        new { id = Model.MAHOIVIEN },
                        new { @class = "btn-detail" })

                    <button type="submit"
                            class="btn-delete"
                            onclick="return confirm('Bạn chắc chắn muốn xóa hội viên này?');">
                        Xác nhận xóa
                    </button>

                </div>
            }

        </div>

    </div>
    ```

</div>
