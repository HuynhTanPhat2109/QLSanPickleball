@model QLSanPickleball_65132651.Models.HOIVIEN

@{
    ViewBag.Title = "Thêm hội viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .create-wrapper {
        max-width: 1000px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        padding: 24px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 28px;
    }

    .avatar-box {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 22px;
        text-align: center;
        background: #f9fafb;
    }

    .avatar-circle {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 42px;
        font-weight: bold;
        margin: 0 auto 16px auto;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .form-label {
        display: block;
        font-weight: bold;
        color: #374151;
        margin-bottom: 6px;
    }

    .form-control,
    .form-select {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
    }

    .action-bar {
        margin-top: 24px;
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .btn-save {
        background: #2563eb;
        color: white;
        border: none;
        padding: 11px 18px;
        border-radius: 8px;
        font-weight: bold;
    }

    .btn-back {
        background: #6b7280;
        color: white !important;
        padding: 11px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

    @@media(max-width: 850px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="create-wrapper">
    <div class="form-card">

        ```
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-grid">

                <div class="avatar-box">
                    <div class="avatar-circle">HV</div>
