                            <label class="form-label">Khách hàng</label>
                            @Html.DropDownList("MAKH", null, "-- Chọn khách hàng --", new { @class = "form-select" })
                        </div>

                        <div>
                            <label class="form-label">Nhân viên duyệt</label>
                            @Html.DropDownList("MANV", null, "-- Chọn nhân viên --", new { @class = "form-select" })
                        </div>

                        <div>
                            <label class="form-label">Loại thẻ</label>
                            @Html.DropDownListFor(m => m.LOAITHE,
                                (SelectList)ViewBag.LoaiTheList,
                                "-- Chọn loại thẻ --",
                                new { @class = "form-select" })
                        </div>

                        <div>
                            <label class="form-label">Ngày bắt đầu</label>
                            @Html.TextBoxFor(m => m.NGAYBATDAU, "{0:dd/MM/yyyy}",
                                new { @class = "form-control", placeholder = "dd/MM/yyyy", id = "NGAYBATDAU" })
                        </div>

                        <div>
                            <label class="form-label">Ngày kết thúc</label>
                            @Html.TextBoxFor(m => m.NGAYKETTHUC, "{0:dd/MM/yyyy}",
                                new { @class = "form-control", placeholder = "dd/MM/yyyy", id = "NGAYKETTHUC", @readonly = "readonly" })
                        </div>

                        <div>
                            <label class="form-label">Phí đăng ký</label>
                            @Html.TextBoxFor(m => m.PHIDANGKY,
                                new { @class = "form-control", type = "number" })
                        </div>

                        <div>
                            <label class="form-label">Trạng thái phí</label>
                            @Html.DropDownListFor(m => m.TRANGTHAIPHI,
                                (SelectList)ViewBag.TrangThaiPhiList,
                                "-- Chọn trạng thái --",
                                new { @class = "form-select" })
                        </div>

                    </div>

                    <div class="action-bar">
                        @Html.ActionLink("Quay lại", "Index", null, new { @class = "btn-back" })
                        <button type="submit" class="btn-save">Lưu hội viên</button>
                    </div>

                </div>
            </div>
        }

    </div>
    ```
    <script>
        function formatDateVN(date) {
            var dd = String(date.getDate()).padStart(2, '0');
            var mm = String(date.getMonth() + 1).padStart(2, '0');
            var yyyy = date.getFullYear();
            return dd + '/' + mm + '/' + yyyy;
        }

        function parseDateVN(value) {
            if (!value) return new Date();

            var parts = value.split('/');
            if (parts.length !== 3) return new Date();

            return new Date(parts[2], parts[1] - 1, parts[0]);
        }

        function congThang(date, months) {
            var d = new Date(date);
            d.setMonth(d.getMonth() + months);
            return d;
        }

        var loaiThe = document.getElementById("LOAITHE");
        var ngayBatDau = document.getElementById("NGAYBATDAU");
        var ngayKetThuc = document.getElementById("NGAYKETTHUC");
        var phiDangKy = document.getElementById("PHIDANGKY");

        function capNhatTheoLoaiThe() {
            var start = parseDateVN(ngayBatDau.value);
            var value = loaiThe.value.toLowerCase();

            if (value === "thường") {
                phiDangKy.value = 200000;
                ngayKetThuc.value = formatDateVN(congThang(start, 3));
            }
            else if (value === "vip") {
                phiDangKy.value = 750000;
                ngayKetThuc.value = formatDateVN(congThang(start, 12));
            }
            else if (value === "luxury") {
                phiDangKy.value = 1000000;
                ngayKetThuc.value = formatDateVN(congThang(start, 12));
            }
        }

        loaiThe.addEventListener("change", capNhatTheoLoaiThe);
        ngayBatDau.addEventListener("change", capNhatTheoLoaiThe);
    </script>
</div>
