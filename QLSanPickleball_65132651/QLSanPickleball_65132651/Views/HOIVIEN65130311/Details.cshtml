@model QLSanPickleball_65132651.Models.HOIVIEN

@{
    ViewBag.Title = "Chi tiết hội viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .detail-wrapper {
        max-width: 900px;
        margin: 0 auto;
    }

    .detail-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .detail-header {
        background: #111827;
        color: white;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .avatar {
        width: 65px;
        height: 65px;
        border-radius: 50%;
        background: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: bold;
    }

    .detail-body {
        padding: 24px;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .detail-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 15px;
    }

    .detail-label {
        font-size: 13px;
        font-weight: bold;
        color: #6b7280;
        margin-bottom: 8px;
        text-transform: uppercase;
    }

    .detail-value {
        font-size: 16px;
        color: #111827;
        font-weight: 600;
    }

    .badge-status {
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: bold;
    }

    .status-paid {
        background: #dcfce7;
        color: #166534;
    }

    .status-wait {
        background: #fef3c7;
        color: #92400e;
    }

    .status-unpaid {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-reject {
        background: #e5e7eb;
        color: #374151;
    }

    .action-bar {
        margin-top: 20px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn-custom {
        padding: 10px 16px;
        border-radius: 8px;
        color: white !important;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-back {
        background: #6b7280;
    }

    .btn-edit {
        background: #f59e0b;
    }

    .btn-delete {
        background: #dc2626;
    }
</style>

@{
    string statusClass = "status-wait";

```
if (Model.TRANGTHAIPHI == "Đã thanh toán")
    {
        statusClass = "status-paid";
    }
    else if (Model.TRANGTHAIPHI == "Chưa thanh toán")
    {
        statusClass = "status-unpaid";
    }
    else if (Model.TRANGTHAIPHI == "Từ chối")
    {
        statusClass = "status-reject";
    }
```

}

<div class="detail-wrapper">

    ```
    <div class="detail-card">

        <div class="detail-header">
            <div class="avatar">HV</div>

            <div>
                <h3>@Model.KHACHHANG.HOTENKH</h3>
                <p>Mã hội viên: @Model.MAHOIVIEN</p>
            </div>
        </div>

        <div class="detail-body">

            <div class="detail-grid">

                <div class="detail-item">
                    <div class="detail-label">Mã hội viên</div>
                    <div class="detail-value">@Model.MAHOIVIEN</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Khách hàng</div>
                    <div class="detail-value">@Model.KHACHHANG.HOTENKH</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Số điện thoại</div>
                    <div class="detail-value">@Model.KHACHHANG.SODIENTHOAIKH</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Loại thẻ</div>
                    <div class="detail-value">@Model.LOAITHE</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Ngày bắt đầu</div>
                    <div class="detail-value">@Model.NGAYBATDAU.ToString("dd/MM/yyyy")</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Ngày kết thúc</div>
                    <div class="detail-value">@Model.NGAYKETTHUC.ToString("dd/MM/yyyy")</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Phí đăng ký</div>
                    <div class="detail-value">@String.Format("{0:N0} đ", Model.PHIDANGKY)</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Trạng thái phí</div>

                    <div class="detail-value">
                        <span class="badge-status @statusClass">
                            @Model.TRANGTHAIPHI
                        </span>
                    </div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Nhân viên duyệt</div>
                    <div class="detail-value">
                        @(Model.NHANVIEN != null ? Model.NHANVIEN.HOTENNV : "")
                    </div>
                </div>

            </div>

            <div class="action-bar">

                @Html.ActionLink("Quay lại",
                    "Index",
                    null,
                    new { @class = "btn-custom btn-back" })

                @Html.ActionLink("Sửa",
                    "Edit",
                    new { id = Model.MAHOIVIEN },
                    new { @class = "btn-custom btn-edit" })

                @Html.ActionLink("Xóa",
                    "Delete",
                    new { id = Model.MAHOIVIEN },
                    new { @class = "btn-custom btn-delete" })

            </div>

        </div>

    </div>
    ```

</div>
