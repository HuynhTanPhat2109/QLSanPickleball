@using System
@using System.Linq
@using System.Collections.Generic
@model QLSanPickleball_65132651.Models.HOADON

@{
    ViewBag.Title = "Chi tiết hóa đơn";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    var dsPhieu = ViewBag.DanhSachPhieuCungNhom as IEnumerable<QLSanPickleball_65132651.Models.PHIEUDATSAN>;
    var dsDichVu = ViewBag.DanhSachDichVu as IEnumerable<QLSanPickleball_65132651.Models.CHITIETDICHVUDAT>;

    if (dsPhieu == null)
    {
        dsPhieu = new List<QLSanPickleball_65132651.Models.PHIEUDATSAN>();
    }

    if (dsDichVu == null)
    {
        dsDichVu = new List<QLSanPickleball_65132651.Models.CHITIETDICHVUDAT>();
    }

    string maNhom = ViewBag.MaNhomDatSan == null ? "" : ViewBag.MaNhomDatSan.ToString();

    string tenKhach = Model.PHIEUDATSAN != null && Model.PHIEUDATSAN.KHACHHANG != null
        ? Model.PHIEUDATSAN.KHACHHANG.HOTENKH
        : "Không rõ";

    string sdtKhach = Model.PHIEUDATSAN != null && Model.PHIEUDATSAN.KHACHHANG != null
        ? Model.PHIEUDATSAN.KHACHHANG.SODIENTHOAIKH
        : "";

    string emailKhach = Model.PHIEUDATSAN != null && Model.PHIEUDATSAN.KHACHHANG != null
        ? Model.PHIEUDATSAN.KHACHHANG.EMAILKH
        : "";

    string tenNhanVien = Model.NHANVIEN != null ? Model.NHANVIEN.HOTENNV : "Không rõ";

    decimal tongTienSan = ViewBag.TongTienSan == null ? Model.TIENTHUESAN : (decimal)ViewBag.TongTienSan;
    decimal tongTienDichVu = ViewBag.TongTienDichVu == null ? Model.TIENDICHVU : (decimal)ViewBag.TongTienDichVu;
    decimal tongGiamGia = ViewBag.TongGiamGia == null ? Model.GIAMGIAHOIVIEN : (decimal)ViewBag.TongGiamGia;
    decimal tongThanhToan = ViewBag.TongThanhToan == null ? Model.TONGTHANHTOAN : (decimal)ViewBag.TongThanhToan;
}

<style>
    .invoice-detail {
        max-width: 1150px;
        margin: 0 auto;
    }

    .page-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

        .page-head h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        margin-top: 5px;
        color: #6b7280;
        font-weight: 700;
    }

    .btn-back,
    .btn-print {
        padding: 10px 15px;
        border-radius: 11px;
        color: white !important;
        text-decoration: none;
        font-weight: 900;
        display: inline-block;
    }

    .btn-back {
        background: #6b7280;
    }

    .btn-print {
        background: #f59e0b;
    }

        .btn-back:hover,
        .btn-print:hover {
            opacity: 0.88;
            text-decoration: none;
            color: white;
        }

    .hero-card {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        color: white;
        border-radius: 22px;
        padding: 26px;
        display: grid;
        grid-template-columns: 170px 1fr 260px;
        gap: 20px;
        align-items: center;
        box-shadow: 0 14px 35px rgba(15,23,42,0.16);
        margin-bottom: 22px;
    }

    .hero-code {
        min-width: 130px;
        height: 82px;
        border-radius: 22px;
        background: rgba(255,255,255,0.16);
        border: 1px solid rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 22px;
        padding: 0 12px;
        word-break: break-word;
    }

    .hero-title {
        font-size: 27px;
        font-weight: 900;
    }

    .hero-sub {
        color: #bfdbfe;
        margin-top: 7px;
        line-height: 1.6;
        font-weight: 700;
    }

    .hero-money {
        text-align: right;
    }

    .hero-money-label {
        color: #bfdbfe;
        font-weight: 900;
        text-transform: uppercase;
        font-size: 13px;
    }

    .hero-money-value {
        margin-top: 7px;
        font-size: 32px;
        font-weight: 900;
    }

    .grid-main {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 20px;
    }

    .card-box {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 22px;
        box-shadow: 0 10px 25px rgba(15,23,42,0.06);
        margin-bottom: 20px;
    }

    .card-title {
        font-size: 19px;
        font-weight: 900;
        color: #111827;
        margin-bottom: 16px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 13px;
    }

    .info-item {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 14px;
    }

    .info-label {
        color: #6b7280;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .info-value {
        color: #111827;
        font-weight: 900;
        word-break: break-word;
    }

    .money-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        border-bottom: 1px solid #e5e7eb;
        padding: 13px 0;
        font-weight: 900;
    }

        .money-row span {
            color: #6b7280;
        }

        .money-row strong {
            color: #111827;
        }

    .money-total strong {
        color: #047857;
        font-size: 22px;
    }

    .slot-list {
        display: grid;
        gap: 12px;
    }

    .slot-item {
        display: grid;
        grid-template-columns: 1.2fr 1fr 0.8fr;
        gap: 12px;
        align-items: center;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 14px 16px;
    }

    .slot-name {
        font-weight: 900;
        color: #111827;
    }

    .slot-sub {
        color: #6b7280;
        font-size: 13px;
        font-weight: 700;
        margin-top: 4px;
    }

    .slot-time {
        font-weight: 900;
        color: #1d4ed8;
    }

    .slot-money {
        text-align: right;
        font-weight: 900;
        color: #047857;
    }

    .service-table {
        width: 100%;
        border-collapse: collapse;
    }

        .service-table th {
            background: #f3f4f6;
            color: #111827;
            padding: 11px;
            font-size: 12px;
            text-transform: uppercase;
            border-bottom: 1px solid #e5e7eb;
        }

        .service-table td {
            padding: 12px 11px;
            border-bottom: 1px solid #e5e7eb;
            color: #111827;
            font-weight: 700;
        }

    .text-right {
        text-align: right;
    }

    .empty-box {
        border: 1px dashed #cbd5e1;
        border-radius: 14px;
        padding: 22px;
        text-align: center;
        color: #64748b;
        font-weight: 700;
        background: #f8fafc;
    }

    @@media(max-width: 900px) {
        .grid-main,
        .hero-card {
            grid-template-columns: 1fr;
        }

        .hero-money,
        .slot-money {
            text-align: left;
        }

        .slot-item {
            grid-template-columns: 1fr;
        }
    }

    @@media(max-width: 650px) {
        .info-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media print {
        .admin-sidebar,
        .admin-topbar,
        .footer-admin,
        .page-head {
            display: none !important;
        }

        .admin-main {
            margin-left: 0 !important;
            width: 100% !important;
        }

        .admin-content {
            padding: 0 !important;
        }

        .card-box,
        .hero-card {
            box-shadow: none !important;
        }
    }
</style>

<div class="invoice-detail">
    <div class="page-head">
        <div>
            <div class="page-sub">Hiển thị đầy đủ các sân/khung giờ trong cùng nhóm đặt sân.</div>
        </div>

        <div>
            @Html.ActionLink("Quay lại", "Index", "HoaDonNV65134364", null, new { @class = "btn-back" })
            <a href="javascript:window.print()" class="btn-print">In hóa đơn</a>
        </div>
    </div>

    <div class="hero-card">
        <div class="hero-code">@Model.SOHD</div>

        <div>
            <div class="hero-title">ARMY PICKLEBALL</div>
            <div class="hero-sub">
                Hóa đơn: @Model.SOHD <br />
                Mã phiếu đại diện: @Model.MAPHIEUDAT
                @if (!string.IsNullOrWhiteSpace(maNhom))
                {
                    <span> • Nhóm: @maNhom</span>
                }
                <br />
                Ngày lập: @Model.NGAYLAP.ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>

        <div class="hero-money">
            <div class="hero-money-label">Tổng thanh toán</div>
            <div class="hero-money-value">@tongThanhToan.ToString("N0") đ</div>
        </div>
    </div>

    <div class="grid-main">
        <div>
            <div class="card-box">
                <div class="card-title">Thông tin khách hàng</div>

                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">Khách hàng</div>
                        <div class="info-value">@tenKhach</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Số điện thoại</div>
                        <div class="info-value">@(string.IsNullOrWhiteSpace(sdtKhach) ? "Không có" : sdtKhach)</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Email</div>
                        <div class="info-value">@(string.IsNullOrWhiteSpace(emailKhach) ? "Không có" : emailKhach)</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Nhân viên lập</div>
                        <div class="info-value">@tenNhanVien</div>
                    </div>
                </div>
            </div>

            <div class="card-box">
                <div class="card-title">Các sân / khung giờ trong hóa đơn</div>

                @if (dsPhieu.Any())
                {
                    <div class="slot-list">
                        @foreach (var p in dsPhieu)
                        {
                            string tenSan = p.SAN != null ? p.SAN.TENSAN : p.MASAN;
                            string loaiSan = p.SAN != null && p.SAN.LOAISAN != null ? p.SAN.LOAISAN.TENLOAISAN : "";

                            <div class="slot-item">
                                <div>
                                    <div class="slot-name">@tenSan</div>
                                    <div class="slot-sub">
                                        Mã phiếu: @p.MAPHIEUDAT • Mã sân: @p.MASAN • @loaiSan
                                    </div>
                                </div>

                                <div class="slot-time">
                                    @p.NGAYDAT.ToString("dd/MM/yyyy") • @p.GIOBATDAU.ToString(@"hh\:mm") - @p.GIOKETTHUC.ToString(@"hh\:mm")
                                </div>

                                <div class="slot-money">
                                    @p.TONGTIENTAMTINH.ToString("N0") đ
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-box">Không có thông tin sân.</div>
                }
            </div>

            <div class="card-box">
                <div class="card-title">Dịch vụ đi kèm</div>

                @if (dsDichVu.Any())
                {
                    <table class="service-table">
                        <thead>
                            <tr>
                                <th>Dịch vụ</th>
                                <th>Đơn vị</th>
                                <th class="text-right">Đơn giá</th>
                                <th class="text-right">Số lượng</th>
                                <th class="text-right">Thành tiền</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in dsDichVu)
                            {
                                string tenDV = item.DICHVU != null ? item.DICHVU.TENDV : item.MADV;
                                string donVi = item.DICHVU != null ? item.DICHVU.DONVITINH : "";

                                <tr>
                                    <td>@tenDV</td>
                                    <td>@donVi</td>
                                    <td class="text-right">@item.DONGIA.ToString("N0") đ</td>
                                    <td class="text-right">@item.SOLUONG</td>
                                    <td class="text-right">@item.THANHTIEN.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-box">Không có dịch vụ đi kèm.</div>
                }
            </div>
        </div>

        <div>
            <div class="card-box">
                <div class="card-title">Thanh toán</div>

                <div class="money-row">
                    <span>Tiền sân</span>
                    <strong>@tongTienSan.ToString("N0") đ</strong>
                </div>

                <div class="money-row">
                    <span>Tiền dịch vụ</span>
                    <strong>@tongTienDichVu.ToString("N0") đ</strong>
                </div>

                <div class="money-row">
                    <span>Giảm giá hội viên</span>
                    <strong>@tongGiamGia.ToString("N0") đ</strong>
                </div>

                <div class="money-row money-total">
                    <span>Tổng thanh toán</span>
                    <strong>@tongThanhToan.ToString("N0") đ</strong>
                </div>
            </div>

            <div class="card-box">
                <div class="card-title">Thông tin hóa đơn</div>

                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">Số hóa đơn</div>
                        <div class="info-value">@Model.SOHD</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Hình thức TT</div>
                        <div class="info-value">@Model.HINHTHUCTT</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Ngày lập</div>
                        <div class="info-value">@Model.NGAYLAP.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Nhân viên</div>
                        <div class="info-value">@tenNhanVien</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>