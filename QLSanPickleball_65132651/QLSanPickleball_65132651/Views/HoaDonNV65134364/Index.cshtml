@using System
@using System.Linq
@model IEnumerable<QLSanPickleball_65132651.Models.HOADON>

@{
    ViewBag.Title = "Hóa đơn";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .page-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 12px;
        flex-wrap: wrap;
    }

        .page-head h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        margin-top: 4px;
        color: #6b7280;
        font-size: 14px;
    }

    .revenue-box {
        background: linear-gradient(135deg, #047857, #16a34a);
        color: white;
        padding: 16px 22px;
        border-radius: 18px;
        min-width: 260px;
        box-shadow: 0 10px 25px rgba(22, 163, 74, 0.22);
    }

    .revenue-label {
        font-size: 13px;
        font-weight: 800;
        color: #dcfce7;
        text-transform: uppercase;
    }

    .revenue-value {
        font-size: 26px;
        font-weight: 900;
        margin-top: 5px;
    }

    .filter-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 18px;
        margin-bottom: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
    }

    .filter-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr auto auto;
        gap: 12px;
        align-items: end;
    }

    .form-label {
        display: block;
        font-weight: 800;
        color: #374151;
        margin-bottom: 6px;
        font-size: 13px;
    }

    .form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        outline: none;
        background: white;
        font-size: 14px;
    }

    .btn-filter,
    .btn-reset {
        border: none;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 900;
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-filter {
        background: #16a34a;
        color: white;
    }

    .btn-reset {
        background: #6b7280;
        color: white !important;
    }

    .alert-success-custom {
        background: #dcfce7;
        color: #166534;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #bbf7d0;
        font-weight: 800;
    }

    .alert-error-custom {
        background: #fee2e2;
        color: #991b1b;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #fecaca;
        font-weight: 800;
    }

    .invoice-list {
        display: grid;
        gap: 14px;
    }

    .invoice-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        padding: 16px 18px;
        display: grid;
        grid-template-columns: 150px 1.4fr 1.4fr 1fr 1fr 150px;
        gap: 16px;
        align-items: center;
    }

    .sohd {
        font-size: 21px;
        font-weight: 900;
        color: #111827;
        word-break: break-word;
    }

    .maphieu {
        display: inline-block;
        margin-top: 6px;
        background: #eef2ff;
        color: #1d4ed8;
        padding: 4px 8px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 900;
        max-width: 130px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .main-text {
        font-size: 15px;
        font-weight: 900;
        color: #111827;
    }

    .sub-text {
        margin-top: 4px;
        font-size: 13px;
        color: #6b7280;
        line-height: 1.35;
    }

    .info-label {
        color: #6b7280;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .info-value {
        color: #111827;
        font-size: 15px;
        font-weight: 800;
    }

    .money {
        color: #047857;
        font-size: 19px;
        font-weight: 900;
    }

    .payment-badge {
        display: inline-block;
        background: #dcfce7;
        color: #166534;
        padding: 7px 11px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
    }

    .btn-action {
        padding: 8px 12px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 13px;
        color: white !important;
        display: inline-block;
        font-weight: 900;
        text-align: center;
        min-width: 76px;
    }

    .btn-detail {
        background: #0ea5e9;
    }

    .btn-print {
        background: #f59e0b;
    }

    .btn-action:hover,
    .btn-reset:hover {
        opacity: 0.88;
        color: white;
        text-decoration: none;
    }

    .action-box {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .empty-card {
        background: white;
        border: 1px dashed #cbd5e1;
        border-radius: 18px;
        padding: 38px;
        text-align: center;
        color: #64748b;
        font-weight: 800;
    }

    .pagination-wrap {
        margin-top: 20px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 14px 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.05);
    }

    .pagination-info {
        color: #6b7280;
        font-size: 14px;
        font-weight: 800;
    }

    .pagination-list {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .page-btn {
        min-width: 38px;
        height: 38px;
        padding: 0 12px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        background: #ffffff;
        color: #374151 !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        font-size: 13px;
    }

        .page-btn.active {
            background: #2563eb;
            border-color: #2563eb;
            color: white !important;
        }

        .page-btn.disabled {
            opacity: 0.45;
            pointer-events: none;
            cursor: not-allowed;
        }

    @@media(max-width: 1200px) {
        .invoice-card {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .action-box {
            grid-column: 1 / span 3;
            justify-content: flex-start;
            border-top: 1px solid #e5e7eb;
            padding-top: 12px;
        }
    }

    @@media(max-width: 700px) {
        .invoice-card,
        .filter-row {
            grid-template-columns: 1fr;
        }

        .action-box {
            grid-column: auto;
        }
    }
</style>

<div class="page-head">
    <div>
        <div class="page-sub">Hiển thị theo thời gian lập hóa đơn mới nhất lên trước.</div>
    </div>

    <div class="revenue-box">
        <div class="revenue-label">Tổng doanh thu</div>
        <div class="revenue-value">@(((decimal)(ViewBag.TongDoanhThu ?? 0m)).ToString("N0")) đ</div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert-success-custom">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-error-custom">@TempData["Error"]</div>
}

<div class="filter-card">
    @using (Html.BeginForm("Index", "HoaDonNV65134364", FormMethod.Get))
    {
        <input type="hidden" name="page" value="1" />

        <div class="filter-row">
            <div>
                <label class="form-label">Tìm kiếm</label>
                <input type="text"
                       name="search"
                       class="form-control"
                       value="@ViewBag.Search"
                       placeholder="Số HĐ, mã phiếu, khách hàng, sân, nhân viên..." />
            </div>

            <div>
                <label class="form-label">Từ ngày</label>
                <input type="date"
                       name="tuNgay"
                       class="form-control"
                       value="@ViewBag.TuNgay" />
            </div>

            <div>
                <label class="form-label">Đến ngày</label>
                <input type="date"
                       name="denNgay"
                       class="form-control"
                       value="@ViewBag.DenNgay" />
            </div>

            <div>
                <button type="submit" class="btn-filter">Lọc</button>
            </div>

            <div>
                @Html.ActionLink("Làm mới", "Index", "HoaDonNV65134364", null, new { @class = "btn-reset" })
            </div>
        </div>
    }
</div>

<div class="invoice-list">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model.OrderByDescending(h => h.NGAYLAP))
        {
            string tenKhach = item.PHIEUDATSAN != null && item.PHIEUDATSAN.KHACHHANG != null
                ? item.PHIEUDATSAN.KHACHHANG.HOTENKH
                : "Không rõ";

            string sdtKhach = item.PHIEUDATSAN != null && item.PHIEUDATSAN.KHACHHANG != null
                ? item.PHIEUDATSAN.KHACHHANG.SODIENTHOAIKH
                : "";

            string tenNhanVien = item.NHANVIEN != null ? item.NHANVIEN.HOTENNV : "Không rõ";

            string tenSan = item.PHIEUDATSAN != null && item.PHIEUDATSAN.SAN != null
                ? item.PHIEUDATSAN.SAN.TENSAN
                : "Xem chi tiết";

            string khungGio = "";

            if (item.PHIEUDATSAN != null)
            {
                khungGio = item.PHIEUDATSAN.NGAYDAT.ToString("dd/MM/yyyy")
                    + " • "
                    + item.PHIEUDATSAN.GIOBATDAU.ToString(@"hh\:mm")
                    + " - "
                    + item.PHIEUDATSAN.GIOKETTHUC.ToString(@"hh\:mm");
            }

            <div class="invoice-card">
                <div>
                    <div class="sohd">@item.SOHD</div>
                    <div class="maphieu">@item.MAPHIEUDAT</div>
                </div>

                <div>
                    <div class="info-label">Khách hàng</div>
                    <div class="main-text">@tenKhach</div>
                    <div class="sub-text">@(string.IsNullOrWhiteSpace(sdtKhach) ? "Không có SĐT" : sdtKhach)</div>
                </div>

                <div>
                    <div class="info-label">Lịch sân đại diện</div>
                    <div class="main-text">@tenSan</div>
                    <div class="sub-text">@khungGio</div>
                </div>

                <div>
                    <div class="info-label">Ngày lập</div>
                    <div class="info-value">@item.NGAYLAP.ToString("dd/MM/yyyy HH:mm")</div>
                    <div class="sub-text">NV: @tenNhanVien</div>
                </div>

                <div>
                    <div class="info-label">Tổng tiền</div>
                    <div class="money">@item.TONGTHANHTOAN.ToString("N0") đ</div>
                    <div class="sub-text">Sân: @item.TIENTHUESAN.ToString("N0") đ</div>

                    @if (item.TIENDICHVU > 0)
                    {
                        <div class="sub-text">DV: @item.TIENDICHVU.ToString("N0") đ</div>
                    }

                    @if (item.GIAMGIAHOIVIEN > 0)
                    {
                        <div class="sub-text">Giảm: @item.GIAMGIAHOIVIEN.ToString("N0") đ</div>
                    }

                    <div class="sub-text">
                        <span class="payment-badge">@item.HINHTHUCTT</span>
                    </div>
                </div>

                <div class="action-box">
                    @Html.ActionLink("Chi tiết", "Details", "HoaDonNV65134364", new { id = item.SOHD }, new { @class = "btn-action btn-detail" })
                    @Html.ActionLink("In HĐ", "Details", "HoaDonNV65134364", new { id = item.SOHD }, new { @class = "btn-action btn-print" })
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-card">Không tìm thấy hóa đơn nào.</div>
    }
</div>

@{
    int currentPage = ViewBag.CurrentPage == null ? 1 : (int)ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages == null ? 1 : (int)ViewBag.TotalPages;
    int pageSize = ViewBag.PageSize == null ? 10 : (int)ViewBag.PageSize;
    int totalItems = ViewBag.TotalItems == null ? 0 : (int)ViewBag.TotalItems;

    int fromItem = totalItems == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    int toItem = currentPage * pageSize;

    if (toItem > totalItems)
    {
        toItem = totalItems;
    }

    int startPage = currentPage - 2;
    int endPage = currentPage + 2;

    if (startPage < 1) { startPage = 1; }
    if (endPage > totalPages) { endPage = totalPages; }
}

@if (totalItems > 0)
{
    <div class="pagination-wrap">
        <div class="pagination-info">
            Hiển thị @fromItem - @toItem / @totalItems hóa đơn
        </div>

        <div class="pagination-list">
            @Html.ActionLink("Trước", "Index", "HoaDonNV65134364",
                new { page = currentPage - 1, search = ViewBag.Search, tuNgay = ViewBag.TuNgay, denNgay = ViewBag.DenNgay },
                new { @class = currentPage <= 1 ? "page-btn disabled" : "page-btn" })

            @for (int i = startPage; i <= endPage; i++)
            {
                @Html.ActionLink(i.ToString(), "Index", "HoaDonNV65134364",
                    new { page = i, search = ViewBag.Search, tuNgay = ViewBag.TuNgay, denNgay = ViewBag.DenNgay },
                    new { @class = i == currentPage ? "page-btn active" : "page-btn" })
            }

            @Html.ActionLink("Sau", "Index", "HoaDonNV65134364",
                new { page = currentPage + 1, search = ViewBag.Search, tuNgay = ViewBag.TuNgay, denNgay = ViewBag.DenNgay },
                new { @class = currentPage >= totalPages ? "page-btn disabled" : "page-btn" })
        </div>
    </div>
}