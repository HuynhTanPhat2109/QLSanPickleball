@using System
@using System.Linq
@model IEnumerable<QLSanPickleball_65132651.Models.THAMSO>

@{
    ViewBag.Title = "Tham số hệ thống";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .page-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 12px;
        flex-wrap: wrap;
    }

        .page-head h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        margin-top: 4px;
        color: #6b7280;
        font-size: 14px;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 18px;
    }

    .stat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
    }

    .stat-label {
        color: #6b7280;
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
    }

    .stat-value {
        margin-top: 8px;
        font-size: 28px;
        font-weight: 900;
        color: #111827;
    }

    .stat-blue {
        color: #2563eb;
    }

    .stat-green {
        color: #047857;
    }

    .stat-red {
        color: #dc2626;
    }

    .filter-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 18px;
        margin-bottom: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
    }

    .filter-row {
        display: grid;
        grid-template-columns: 2fr 1fr auto auto;
        gap: 12px;
        align-items: end;
    }

    .form-label {
        display: block;
        font-weight: 900;
        color: #374151;
        margin-bottom: 6px;
        font-size: 13px;
    }

    .form-control,
    .form-select {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        outline: none;
        background: white;
        font-size: 14px;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
        }

    .btn-filter,
    .btn-reset {
        border: none;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 900;
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-filter {
        background: #2563eb;
        color: white;
    }

    .btn-reset {
        background: #6b7280;
        color: white !important;
    }

        .btn-filter:hover,
        .btn-reset:hover {
            opacity: 0.88;
            text-decoration: none;
            color: white;
        }

    .alert-success-custom {
        background: #dcfce7;
        color: #166534;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #bbf7d0;
        font-weight: 800;
    }

    .alert-error-custom {
        background: #fee2e2;
        color: #991b1b;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #fecaca;
        font-weight: 800;
    }

    .param-list {
        display: grid;
        gap: 14px;
    }

    .param-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        padding: 18px;
        display: grid;
        grid-template-columns: 110px 1.4fr 1fr 1fr 160px;
        gap: 14px;
        align-items: center;
    }

    .param-code {
        width: 78px;
        height: 64px;
        border-radius: 18px;
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 15px;
        box-shadow: 0 8px 16px rgba(37, 99, 235, 0.22);
    }

    .info-label {
        color: #6b7280;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .main-text {
        color: #111827;
        font-size: 15px;
        font-weight: 900;
        line-height: 1.4;
    }

    .sub-text {
        margin-top: 4px;
        color: #6b7280;
        font-size: 13px;
        line-height: 1.45;
    }

    .value-badge {
        display: inline-block;
        background: #dcfce7;
        color: #166534;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 900;
        word-break: break-word;
    }

    .type-badge {
        display: inline-block;
        background: #eef2ff;
        color: #1d4ed8;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 900;
    }

    .status-active {
        background: #dcfce7;
        color: #166534;
    }

    .status-stop {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-other {
        background: #e5e7eb;
        color: #374151;
    }

    .action-box {
        display: flex;
        gap: 7px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 8px 11px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 12px;
        color: white !important;
        display: inline-block;
        font-weight: 900;
        text-align: center;
        min-width: 70px;
    }

    .btn-detail {
        background: #0ea5e9;
    }

    .btn-edit {
        background: #f59e0b;
    }

    .btn-action:hover {
        opacity: 0.88;
        color: white;
        text-decoration: none;
        transform: translateY(-1px);
    }

    .empty-card {
        background: white;
        border: 1px dashed #cbd5e1;
        border-radius: 18px;
        padding: 38px;
        text-align: center;
        color: #64748b;
        font-weight: 800;
    }

    .pagination-wrap {
        margin-top: 20px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 14px 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.05);
    }

    .pagination-info {
        color: #6b7280;
        font-size: 14px;
        font-weight: 800;
    }

    .pagination-list {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .page-btn {
        min-width: 38px;
        height: 38px;
        padding: 0 12px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        background: #ffffff;
        color: #374151 !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        font-size: 13px;
    }

        .page-btn:hover {
            background: #eff6ff;
            border-color: #2563eb;
            color: #1d4ed8 !important;
            text-decoration: none;
        }

        .page-btn.active {
            background: #2563eb;
            border-color: #2563eb;
            color: white !important;
        }

        .page-btn.disabled {
            opacity: 0.45;
            pointer-events: none;
            cursor: not-allowed;
        }

    @@media(max-width: 1150px) {
        .stat-grid {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .param-card {
            grid-template-columns: 100px 1.4fr 1fr;
        }

        .action-box {
            grid-column: 1 / span 3;
            justify-content: flex-start;
            border-top: 1px solid #e5e7eb;
            padding-top: 12px;
        }
    }

    @@media(max-width: 760px) {
        .stat-grid {
            grid-template-columns: 1fr;
        }

        .filter-row {
            grid-template-columns: 1fr;
        }

        .param-card {
            grid-template-columns: 1fr;
        }

        .action-box {
            grid-column: auto;
        }
    }
</style>

<div class="page-head">
    <div>
        <div class="page-sub">Quản lý các cấu hình chung như thời gian giữ chỗ, giờ mở cửa, tỷ lệ giảm giá...</div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert-success-custom">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-error-custom">@TempData["Error"]</div>
}

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Tổng tham số</div>
        <div class="stat-value stat-blue">@ViewBag.TongThamSo</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Đang áp dụng</div>
        <div class="stat-value stat-green">@ViewBag.DangApDung</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Ngừng áp dụng</div>
        <div class="stat-value stat-red">@ViewBag.NgungApDung</div>
    </div>
</div>

<div class="filter-card">
    @using (Html.BeginForm("Index", "THAMSO65134364", FormMethod.Get))
    {
        <input type="hidden" name="page" value="1" />

        <div class="filter-row">
            <div>
                <label class="form-label">Tìm kiếm</label>
                <input type="text"
                       name="search"
                       class="form-control"
                       value="@ViewBag.Search"
                       placeholder="Nhập mã tham số, tên tham số, kiểu/ĐVT, giá trị..." />
            </div>

            <div>
                <label class="form-label">Tình trạng</label>
                <select name="tinhTrang" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="Đang áp dụng" @(ViewBag.TinhTrang == "Đang áp dụng" ? "selected" : "")>Đang áp dụng</option>
                    <option value="Ngừng áp dụng" @(ViewBag.TinhTrang == "Ngừng áp dụng" ? "selected" : "")>Ngừng áp dụng</option>
                </select>
            </div>

            <div>
                <button type="submit" class="btn-filter">Lọc</button>
            </div>

            <div>
                @Html.ActionLink("Làm mới", "Index", "THAMSO65134364", null, new { @class = "btn-reset" })
            </div>
        </div>
    }
</div>

<div class="param-list">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            string statusClass = "status-other";

            if (item.TINHTRANG == "Đang áp dụng")
            {
                statusClass = "status-active";
            }
            else if (item.TINHTRANG == "Ngừng áp dụng")
            {
                statusClass = "status-stop";
            }

            <div class="param-card">
                <div>
                    <div class="param-code">@item.MATHAMSO</div>
                </div>

                <div>
                    <div class="info-label">Tên tham số</div>
                    <div class="main-text">@item.TENTHAMSO</div>
                    <div class="sub-text">Mã tham số: @item.MATHAMSO</div>
                </div>

                <div>
                    <div class="info-label">Kiểu / ĐVT</div>
                    <span class="type-badge">@item.KIEU_DVT</span>
                </div>

                <div>
                    <div class="info-label">Giá trị / Tình trạng</div>
                    <span class="value-badge">@item.GIATRI</span>
                    <div class="sub-text" style="margin-top:8px;">
                        <span class="value-badge @statusClass">@item.TINHTRANG</span>
                    </div>
                </div>

                <div class="action-box">
                    @Html.ActionLink("Chi tiết", "Details", "THAMSO65134364", new { id = item.MATHAMSO }, new { @class = "btn-action btn-detail" })
                    @Html.ActionLink("Sửa", "Edit", "THAMSO65134364", new { id = item.MATHAMSO }, new { @class = "btn-action btn-edit" })
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-card">
            Không tìm thấy tham số hệ thống nào.
        </div>
    }
</div>

@{
    int currentPage = ViewBag.CurrentPage == null ? 1 : (int)ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages == null ? 1 : (int)ViewBag.TotalPages;
    int pageSize = ViewBag.PageSize == null ? 10 : (int)ViewBag.PageSize;
    int totalItems = ViewBag.TotalItems == null ? 0 : (int)ViewBag.TotalItems;

    int fromItem = totalItems == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    int toItem = currentPage * pageSize;

    if (toItem > totalItems)
    {
        toItem = totalItems;
    }

    int startPage = currentPage - 2;
    int endPage = currentPage + 2;

    if (startPage < 1)
    {
        startPage = 1;
    }

    if (endPage > totalPages)
    {
        endPage = totalPages;
    }
}

@if (totalItems > 0)
{
    <div class="pagination-wrap">
        <div class="pagination-info">
            Hiển thị @fromItem - @toItem / @totalItems tham số
        </div>

        <div class="pagination-list">
            @Html.ActionLink("Trước", "Index", "THAMSO65134364",
                new
                {
                    page = currentPage - 1,
                    search = ViewBag.Search,
                    tinhTrang = ViewBag.TinhTrang
                },
                new
                {
                    @class = currentPage <= 1 ? "page-btn disabled" : "page-btn"
                })

            @if (startPage > 1)
            {
                @Html.ActionLink("1", "Index", "THAMSO65134364",
                    new
                    {
                        page = 1,
                        search = ViewBag.Search,
                        tinhTrang = ViewBag.TinhTrang
                    },
                    new { @class = "page-btn" })

                if (startPage > 2)
                {
                    <span class="page-btn disabled">...</span>
                }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                @Html.ActionLink(i.ToString(), "Index", "THAMSO65134364",
                    new
                    {
                        page = i,
                        search = ViewBag.Search,
                        tinhTrang = ViewBag.TinhTrang
                    },
                    new
                    {
                        @class = i == currentPage ? "page-btn active" : "page-btn"
                    })
            }

            @if (endPage < totalPages)
            {
                if (endPage < totalPages - 1)
                {
                    <span class="page-btn disabled">...</span>
                }

                @Html.ActionLink(totalPages.ToString(), "Index", "THAMSO65134364",
                    new
                    {
                        page = totalPages,
                        search = ViewBag.Search,
                        tinhTrang = ViewBag.TinhTrang
                    },
                    new { @class = "page-btn" })
            }

            @Html.ActionLink("Sau", "Index", "THAMSO65134364",
                new
                {
                    page = currentPage + 1,
                    search = ViewBag.Search,
                    tinhTrang = ViewBag.TinhTrang
                },
                new
                {
                    @class = currentPage >= totalPages ? "page-btn disabled" : "page-btn"
                })
        </div>
    </div>
}