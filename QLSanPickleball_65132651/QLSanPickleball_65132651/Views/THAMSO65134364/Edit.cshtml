@model QLSanPickleball_65132651.Models.THAMSO

@{
    ViewBag.Title = "Sửa tham số";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .form-wrapper {
        max-width: 850px;
        margin: 0 auto;
    }

    .page-head {
        margin-bottom: 18px;
    }

        .page-head h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        margin-top: 5px;
        color: #6b7280;
    }

    .form-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 10px 25px rgba(15,23,42,0.06);
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .form-group-full {
        grid-column: 1 / span 2;
    }

    .control-label {
        display: block;
        font-weight: 900;
        color: #374151;
        margin-bottom: 7px;
    }

    .form-control {
        width: 100%;
        padding: 11px 13px;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        font-size: 14px;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
            outline: none;
        }

    .text-danger {
        color: #dc2626;
        font-size: 13px;
        font-weight: 700;
        margin-top: 5px;
        display: block;
    }

    .note-box {
        margin-top: 18px;
        background: #eff6ff;
        color: #1e40af;
        border: 1px solid #bfdbfe;
        border-radius: 14px;
        padding: 14px 16px;
        font-weight: 800;
        line-height: 1.5;
    }

    .btn-row {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 24px;
        flex-wrap: wrap;
    }

    .btn-save,
    .btn-back {
        border: none;
        padding: 11px 18px;
        border-radius: 12px;
        font-weight: 900;
        text-decoration: none;
        color: white !important;
        display: inline-block;
    }

    .btn-save {
        background: #f59e0b;
    }

    .btn-back {
        background: #6b7280;
    }

        .btn-save:hover,
        .btn-back:hover {
            opacity: 0.88;
            text-decoration: none;
            color: white;
        }

    @@media(max-width: 650px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-group-full {
            grid-column: 1;
        }
    }
</style>

<div class="form-wrapper">
    <div class="page-head">
        <div class="page-sub">Cập nhật giá trị cấu hình chung cho hệ thống.</div>
    </div>

    <div class="form-card">
        @using (Html.BeginForm("Edit", "THAMSO65134364", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-grid">
                <div>
                    @Html.LabelFor(model => model.MATHAMSO, "Mã tham số", new { @class = "control-label" })
                    @Html.TextBoxFor(model => model.MATHAMSO, new { @class = "form-control", @readonly = "readonly" })
                    @Html.ValidationMessageFor(model => model.MATHAMSO, "", new { @class = "text-danger" })
                </div>

                <div>
                    @Html.LabelFor(model => model.KIEU_DVT, "Kiểu / Đơn vị tính", new { @class = "control-label" })
                    @Html.TextBoxFor(model => model.KIEU_DVT, new { @class = "form-control", placeholder = "Ví dụ: phút, %, giờ, số lần..." })
                    @Html.ValidationMessageFor(model => model.KIEU_DVT, "", new { @class = "text-danger" })
                </div>

                <div class="form-group-full">
                    @Html.LabelFor(model => model.TENTHAMSO, "Tên tham số", new { @class = "control-label" })
                    @Html.TextBoxFor(model => model.TENTHAMSO, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.TENTHAMSO, "", new { @class = "text-danger" })
                </div>

                <div>
                    @Html.LabelFor(model => model.GIATRI, "Giá trị", new { @class = "control-label" })
                    @Html.TextBoxFor(model => model.GIATRI, new { @class = "form-control", placeholder = "Ví dụ: 5, 6, 22:00, 10..." })
                    @Html.ValidationMessageFor(model => model.GIATRI, "", new { @class = "text-danger" })
                </div>

                <div>
                    @Html.LabelFor(model => model.TINHTRANG, "Tình trạng", new { @class = "control-label" })
                    @Html.DropDownListFor(model => model.TINHTRANG, (SelectList)ViewBag.TinhTrangList, new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.TINHTRANG, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="note-box">
                Lưu ý: Chỉ nên sửa giá trị tham số khi hiểu rõ ý nghĩa. Ví dụ thời gian giữ chỗ, giờ mở cửa, giờ đóng cửa, tỷ lệ giảm giá...
            </div>

            <div class="btn-row">
                @Html.ActionLink("Quay lại", "Index", "THAMSO65134364", null, new { @class = "btn-back" })
                <button type="submit" class="btn-save">Cập nhật</button>
            </div>
        }
    </div>
</div>