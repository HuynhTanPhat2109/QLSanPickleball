@model QLSanPickleball_65132651.Models.NHANVIEN

@{
    ViewBag.Title = "Xóa nhân viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .delete-wrapper {
        max-width: 850px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 18px;
    }

        .page-header h2 {
            margin: 0;
            font-size: 24px;
            font-weight: bold;
            color: #111827;
        }

    .delete-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .delete-warning {
        background: #dc2626;
        color: white;
        padding: 22px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .warning-icon {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: rgba(255,255,255,0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        font-weight: bold;
    }

    .warning-text h3 {
        margin: 0;
        font-size: 22px;
        font-weight: bold;
    }

    .warning-text p {
        margin: 6px 0 0 0;
        color: #fee2e2;
    }

    .delete-body {
        padding: 24px;
    }

    .employee-head {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .avatar-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #dc2626, #991b1b);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: bold;
        flex-shrink: 0;
    }

    .employee-name {
        font-size: 20px;
        font-weight: bold;
        color: #111827;
    }

    .employee-code {
        margin-top: 4px;
        color: #6b7280;
        font-size: 14px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-bottom: 20px;
    }

    .info-item {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 14px;
        background: #ffffff;
    }

    .info-label {
        font-size: 13px;
        font-weight: bold;
        color: #6b7280;
        margin-bottom: 6px;
        text-transform: uppercase;
    }

    .info-value {
        font-size: 16px;
        color: #111827;
        font-weight: 600;
        word-break: break-word;
    }

    .badge-role,
    .badge-status {
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: bold;
        display: inline-block;
    }

    .role-admin {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .role-manager {
        background: #fef3c7;
        color: #92400e;
    }

    .role-staff {
        background: #dcfce7;
        color: #166534;
    }

    .status-active {
        background: #dcfce7;
        color: #166534;
    }

    .status-lock {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-off {
        background: #e5e7eb;
        color: #374151;
    }

    .note-box {
        background: #fef3c7;
        border: 1px solid #fde68a;
        color: #92400e;
        padding: 14px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
        line-height: 1.5;
    }

    .action-bar {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-delete-confirm {
        background: #dc2626;
        color: white;
        border: none;
        padding: 11px 18px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
    }

        .btn-delete-confirm:hover {
            background: #b91c1c;
        }

    .btn-back {
        background: #6b7280;
        color: white !important;
        padding: 11px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

        .btn-back:hover {
            background: #4b5563;
            text-decoration: none;
            color: white;
        }

    .btn-detail {
        background: #0ea5e9;
        color: white !important;
        padding: 11px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
    }

        .btn-detail:hover {
            background: #0284c7;
            text-decoration: none;
            color: white;
        }

    @@media(max-width: 700px) {
        .info-grid {
            grid-template-columns: 1fr;
        }

        .employee-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .action-bar {
            justify-content: flex-start;
        }
    }
</style>

@{
    string roleClass = "role-staff";

    if (Model.VAITRO == "Admin")
    {
        roleClass = "role-admin";
    }
    else if (Model.VAITRO == "Quản lý")
    {
        roleClass = "role-manager";
    }

    string statusClass = "status-off";

    if (Model.TRANGTHAI == "Đang hoạt động")
    {
        statusClass = "status-active";
    }
    else if (Model.TRANGTHAI == "Tạm khóa")
    {
        statusClass = "status-lock";
    }

    string chuDaiDien = "NV";

    if (!string.IsNullOrWhiteSpace(Model.HOTENNV))
    {
        var parts = Model.HOTENNV.Trim().Split(new[] { ' ' }, System.StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length >= 2)
        {
            chuDaiDien = (parts[parts.Length - 2].Substring(0, 1) + parts[parts.Length - 1].Substring(0, 1)).ToUpper();
        }
        else
        {
            chuDaiDien = parts[0].Substring(0, 1).ToUpper();
        }
    }
}

<div class="delete-wrapper">
  

    <div class="delete-card">
        <div class="delete-warning">
            <div class="warning-icon">!</div>
            <div class="warning-text">
                <h3>Xác nhận xóa tài khoản</h3>
                <p>Bạn có chắc chắn muốn xóa nhân viên này không?</p>
            </div>
        </div>

        <div class="delete-body">
            <div class="employee-head">
                <div class="avatar-circle">@chuDaiDien</div>
                <div>
                    <div class="employee-name">@Model.HOTENNV</div>
                    <div class="employee-code">Mã nhân viên: @Model.MANV</div>
                </div>
            </div>

            <div class="note-box">
                Nếu nhân viên đã có phiếu đặt sân, hóa đơn hoặc hội viên liên quan thì hệ thống sẽ không xóa khỏi dữ liệu,
                mà chuyển tài khoản sang trạng thái <strong>Tạm khóa</strong> để tránh lỗi khóa ngoại.
            </div>

            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">Mã nhân viên</div>
                    <div class="info-value">@Model.MANV</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Họ tên</div>
                    <div class="info-value">@Model.HOTENNV</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Số điện thoại</div>
                    <div class="info-value">@Model.SODIENTHOAINV</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Email</div>
                    <div class="info-value">@Model.EMAILNV</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Tên đăng nhập</div>
                    <div class="info-value">@Model.TENDANGNHAP</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Mật khẩu</div>
                    <div class="info-value">@Model.MATKHAUNV</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Vai trò</div>
                    <div class="info-value">
                        <span class="badge-role @roleClass">@Model.VAITRO</span>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">Trạng thái</div>
                    <div class="info-value">
                        <span class="badge-status @statusClass">@Model.TRANGTHAI</span>
                    </div>
                </div>
            </div>

            @using (Html.BeginForm("Delete", "NHANVIEN65134364", new { id = Model.MANV }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="action-bar">
                    @Html.ActionLink("Quay lại", "Index", "NHANVIEN65134364", null, new { @class = "btn-back" })

                    @Html.ActionLink("Chi tiết", "Details", "NHANVIEN65134364", new { id = Model.MANV }, new { @class = "btn-detail" })

                    <button type="submit"
                            class="btn-delete-confirm"
                            onclick="return confirm('Xác nhận xóa nhân viên @Model.HOTENNV?');">
                        Xác nhận xóa
                    </button>
                </div>
            }
        </div>
    </div>
</div>