@model IEnumerable<QLSanPickleball_65132651.Models.NHANVIEN>

@{
    ViewBag.Title = "Quản lý nhân viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    bool laAdmin = ViewBag.LaAdmin != null && (bool)ViewBag.LaAdmin;
    bool laQuanLy = ViewBag.LaQuanLy != null && (bool)ViewBag.LaQuanLy;

    bool duocThem = ViewBag.DuocThem != null && (bool)ViewBag.DuocThem;
    bool duocSua = ViewBag.DuocSua != null && (bool)ViewBag.DuocSua;
    bool duocKhoa = ViewBag.DuocKhoa != null && (bool)ViewBag.DuocKhoa;
    bool duocXoa = ViewBag.DuocXoa != null && (bool)ViewBag.DuocXoa;
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 12px;
        flex-wrap: wrap;
    }

        .page-header h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        color: #6b7280;
        font-size: 14px;
        margin-top: 5px;
    }

    .btn-add {
        background: #2563eb;
        color: white !important;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 900;
        display: inline-block;
    }

        .btn-add:hover {
            background: #1d4ed8;
            text-decoration: none;
            color: white;
        }

    .role-note {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 15px;
        font-weight: 800;
    }

    .filter-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 18px;
        margin-bottom: 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .filter-row {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr auto auto;
        gap: 12px;
        align-items: end;
    }

    .form-label {
        font-weight: 900;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }

    .form-control,
    .form-select {
        width: 100%;
        padding: 9px 10px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        outline: none;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #2563eb;
        }

    .btn-search {
        background: #16a34a;
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 8px;
        font-weight: 900;
        cursor: pointer;
    }

    .btn-reset {
        display: inline-block;
        background: #6b7280;
        color: white !important;
        padding: 10px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 900;
    }

        .btn-search:hover,
        .btn-reset:hover {
            opacity: 0.88;
            text-decoration: none;
            color: white;
        }

    .table-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        overflow-x: auto;
    }

    .table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: collapse;
    }

        .table th {
            background: #f3f4f6;
            color: #111827;
            white-space: nowrap;
            text-align: center;
            vertical-align: middle;
        }

        .table td {
            vertical-align: middle;
            white-space: nowrap;
        }

    .employee-box {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .employee-avatar {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        flex-shrink: 0;
    }

    .employee-name {
        font-weight: 900;
        color: #111827;
    }

    .employee-sub {
        color: #6b7280;
        font-size: 13px;
        margin-top: 3px;
    }

    .badge-role,
    .badge-status {
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
        display: inline-block;
    }

    .role-admin {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .role-manager {
        background: #fef3c7;
        color: #92400e;
    }

    .role-staff {
        background: #dcfce7;
        color: #166534;
    }

    .status-active {
        background: #dcfce7;
        color: #166534;
    }

    .status-lock {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-off {
        background: #e5e7eb;
        color: #374151;
    }

    .action-group {
        display: flex;
        gap: 6px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 7px 10px;
        border-radius: 7px;
        text-decoration: none;
        font-size: 13px;
        color: white !important;
        display: inline-block;
        font-weight: 900;
    }

    .btn-detail {
        background: #0ea5e9;
    }

    .btn-edit {
        background: #f59e0b;
    }

    .btn-delete {
        background: #dc2626;
    }

    .btn-lock {
        background: #7c2d12;
    }

    .btn-unlock {
        background: #16a34a;
    }

    .btn-action:hover {
        opacity: 0.85;
        text-decoration: none;
        color: white;
    }

    .alert-success-custom {
        background: #dcfce7;
        color: #166534;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 15px;
        border: 1px solid #bbf7d0;
        font-weight: 800;
    }

    .alert-error-custom {
        background: #fee2e2;
        color: #991b1b;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 15px;
        border: 1px solid #fecaca;
        font-weight: 800;
    }

    .empty-row {
        text-align: center;
        color: #64748b;
        padding: 24px;
        font-weight: 800;
    }

    @@media(max-width: 1000px) {
        .filter-row {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media(max-width: 600px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .filter-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-header">
    <div>
        <div class="page-sub">
            Admin có toàn quyền. Quản lý chỉ được xem chi tiết và sửa thông tin nhân viên.
        </div>
    </div>

    @if (duocThem)
    {
        @Html.ActionLink("+ Thêm nhân viên", "Create", "NHANVIEN65134364", null, new { @class = "btn-add" })
    }
</div>

@if (laQuanLy && !laAdmin)
{
    <div class="role-note">
        Vai trò hiện tại: Quản lý. Bạn chỉ được xem chi tiết và sửa thông tin nhân viên, không được thêm, khóa hoặc xóa tài khoản.
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert-success-custom">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-error-custom">@TempData["Error"]</div>
}

<div class="filter-card">
    @using (Html.BeginForm("Index", "NHANVIEN65134364", FormMethod.Get))
    {
        <div class="filter-row">
            <div>
                <label class="form-label">Tìm kiếm</label>
                <input type="text"
                       name="search"
                       class="form-control"
                       value="@ViewBag.Search"
                       placeholder="Nhập mã, họ tên, SĐT, email hoặc tên đăng nhập..." />
            </div>

            <div>
                <label class="form-label">Vai trò</label>
                <select name="vaiTro" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="Admin" @(ViewBag.VaiTro == "Admin" ? "selected" : "")>Admin</option>
                    <option value="Quản lý" @(ViewBag.VaiTro == "Quản lý" ? "selected" : "")>Quản lý</option>
                    <option value="Nhân viên" @(ViewBag.VaiTro == "Nhân viên" ? "selected" : "")>Nhân viên</option>
                </select>
            </div>

            <div>
                <label class="form-label">Trạng thái</label>
                <select name="trangThai" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="Đang hoạt động" @(ViewBag.TrangThai == "Đang hoạt động" ? "selected" : "")>Đang hoạt động</option>
                    <option value="Tạm khóa" @(ViewBag.TrangThai == "Tạm khóa" ? "selected" : "")>Tạm khóa</option>
                    <option value="Đã nghỉ việc" @(ViewBag.TrangThai == "Đã nghỉ việc" ? "selected" : "")>Đã nghỉ việc</option>
                </select>
            </div>

            <div>
                <button type="submit" class="btn-search">Lọc</button>
            </div>

            <div>
                @Html.ActionLink("Làm mới", "Index", "NHANVIEN65134364", null, new { @class = "btn-reset" })
            </div>
        </div>
    }
</div>

<div class="table-card">
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Mã NV</th>
                <th>Thông tin nhân viên</th>
                <th>Tài khoản</th>
                <th>Vai trò</th>
                <th>Trạng thái</th>
                <th>Chức năng</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    string roleClass = "role-staff";

                    if (item.VAITRO == "Admin")
                    {
                        roleClass = "role-admin";
                    }
                    else if (item.VAITRO == "Quản lý")
                    {
                        roleClass = "role-manager";
                    }

                    string statusClass = "status-active";

                    if (item.TRANGTHAI == "Tạm khóa")
                    {
                        statusClass = "status-lock";
                    }
                    else if (item.TRANGTHAI == "Đã nghỉ việc")
                    {
                        statusClass = "status-off";
                    }

                    string chuCai = !string.IsNullOrWhiteSpace(item.HOTENNV)
                        ? item.HOTENNV.Trim().Substring(0, 1).ToUpper()
                        : "NV";

                    <tr>
                        <td class="text-center">
                            <strong>@item.MANV</strong>
                        </td>

                        <td>
                            <div class="employee-box">
                                <div class="employee-avatar">@chuCai</div>

                                <div>
                                    <div class="employee-name">@item.HOTENNV</div>
                                    <div class="employee-sub">@item.SODIENTHOAINV</div>
                                    <div class="employee-sub">@item.EMAILNV</div>
                                </div>
                            </div>
                        </td>

                        <td class="text-center">
                            <strong>@item.TENDANGNHAP</strong>
                        </td>

                        <td class="text-center">
                            <span class="badge-role @roleClass">@item.VAITRO</span>
                        </td>

                        <td class="text-center">
                            <span class="badge-status @statusClass">@item.TRANGTHAI</span>
                        </td>

                        <td>
                            <div class="action-group">
                                @Html.ActionLink("Chi tiết", "Details", "NHANVIEN65134364", new { id = item.MANV }, new { @class = "btn-action btn-detail" })

                                @if (duocSua)
                                {
                                    @Html.ActionLink("Sửa", "Edit", "NHANVIEN65134364", new { id = item.MANV }, new { @class = "btn-action btn-edit" })
                                }

                                @if (duocKhoa)
                                {
                                    if (item.TRANGTHAI == "Tạm khóa")
                                    {
                                        @Html.ActionLink("Mở khóa", "MoKhoaTaiKhoan", "NHANVIEN65134364", new { id = item.MANV }, new
                                        {
                                            @class = "btn-action btn-unlock",
                                            onclick = "return confirm('Mở khóa tài khoản " + item.TENDANGNHAP + "?');"
                                        })
                                    }
                                    else if (item.TRANGTHAI == "Đang hoạt động")
                                    {
                                        @Html.ActionLink("Khóa", "KhoaTaiKhoan", "NHANVIEN65134364", new { id = item.MANV }, new
                                        {
                                            @class = "btn-action btn-lock",
                                            onclick = "return confirm('Khóa tài khoản " + item.TENDANGNHAP + "?');"
                                        })
                                    }
                                }

                                @if (duocXoa)
                                {
                                    @Html.ActionLink("Xóa", "Delete", "NHANVIEN65134364", new { id = item.MANV }, new { @class = "btn-action btn-delete" })
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="empty-row">Không tìm thấy nhân viên nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>