@model QLSanPickleball_65132651.Models.SAN

@{
    ViewBag.Title = "Cập nhật trạng thái sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    string tenLoaiSan = Model.LOAISAN != null ? Model.LOAISAN.TENLOAISAN : Model.MALOAISAN;
}

<style>
    .status-wrapper {
        max-width: 760px;
        margin: 0 auto;
    }

    .page-head {
        margin-bottom: 18px;
    }

        .page-head h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        margin-top: 6px;
        color: #6b7280;
        font-size: 14px;
    }

    .status-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 12px 28px rgba(15,23,42,0.08);
    }

    .court-head {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        color: white;
        border-radius: 18px;
        padding: 22px;
        margin-bottom: 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .court-code {
        width: 78px;
        height: 70px;
        border-radius: 20px;
        background: rgba(255,255,255,0.16);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 18px;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .court-title {
        font-size: 24px;
        font-weight: 900;
    }

    .court-sub {
        margin-top: 5px;
        color: #bfdbfe;
        font-size: 14px;
        line-height: 1.5;
    }

    .current-badge {
        background: rgba(255,255,255,0.16);
        color: white;
        padding: 9px 13px;
        border-radius: 999px;
        font-weight: 900;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .form-group {
        margin-bottom: 18px;
    }

    .control-label {
        display: block;
        font-weight: 900;
        color: #374151;
        margin-bottom: 7px;
    }

    .form-control {
        width: 100%;
        padding: 12px 13px;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        font-size: 14px;
        outline: none;
        background: white;
    }

        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
        }

    .note-box {
        background: #eff6ff;
        color: #1e40af;
        border: 1px solid #bfdbfe;
        padding: 14px 16px;
        border-radius: 14px;
        font-weight: 800;
        line-height: 1.5;
        margin-top: 14px;
    }

    .btn-row {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        flex-wrap: wrap;
        margin-top: 24px;
    }

    .btn-save,
    .btn-back {
        border: none;
        padding: 11px 18px;
        border-radius: 12px;
        font-weight: 900;
        color: white !important;
        text-decoration: none;
        display: inline-block;
    }

    .btn-save {
        background: #16a34a;
    }

    .btn-back {
        background: #6b7280;
    }

        .btn-save:hover,
        .btn-back:hover {
            opacity: 0.88;
            text-decoration: none;
            color: white;
        }
</style>

<div class="status-wrapper">
    <div class="page-head">
        <h2>Cập nhật trạng thái sân</h2>
        <div class="page-sub">Nhân viên có thể cập nhật tình trạng sân trong quá trình vận hành.</div>
    </div>

    <div class="status-card">
        <div class="court-head">
            <div style="display:flex;align-items:center;gap:16px;">
                <div class="court-code">@Model.MASAN</div>

                <div>
                    <div class="court-title">@Model.TENSAN</div>
                    <div class="court-sub">
                        Mã sân: @Model.MASAN <br />
                        Loại sân: @tenLoaiSan
                    </div>
                </div>
            </div>

            <div class="current-badge">
                Hiện tại: @Model.TRANGTHAISAN
            </div>
        </div>

        @using (Html.BeginForm("CapNhatTrangThai", "SAN65134364", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <input type="hidden" name="MASAN" value="@Model.MASAN" />

            <div class="form-group">
                <label class="control-label">Trạng thái mới</label>
                @Html.DropDownList("TRANGTHAISAN", (SelectList)ViewBag.TrangThaiList, new { @class = "form-control" })
            </div>

            <div class="note-box">
                Gợi ý: trạng thái “Đang đặt” và “Đang sử dụng” thường được cập nhật tự động từ phiếu đặt sân.
                Nhân viên chỉ nên đổi thủ công khi cần xử lý thực tế tại sân.
            </div>

            <div class="btn-row">
                @Html.ActionLink("Quay lại", "Index", "SAN65134364", null, new { @class = "btn-back" })
                <button type="submit" class="btn-save">Cập nhật trạng thái</button>
            </div>
        }
    </div>
</div>