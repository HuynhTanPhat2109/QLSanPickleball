@model QLSanPickleball_65132651.Models.SAN

@{
    ViewBag.Title = "Xóa sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .delete-wrapper {
        max-width: 850px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 18px;
    }

        .page-header h2 {
            margin: 0;
            font-size: 24px;
            font-weight: bold;
            color: #111827;
        }

    .delete-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .delete-warning {
        background: #dc2626;
        color: white;
        padding: 22px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .warning-icon {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: rgba(255,255,255,0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        font-weight: bold;
    }

    .warning-text h3 {
        margin: 0;
        font-size: 22px;
        font-weight: bold;
    }

    .warning-text p {
        margin: 6px 0 0 0;
        color: #fee2e2;
    }

    .delete-body {
        padding: 24px;
    }

    .court-head {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        margin-bottom: 20px;
    }

    .court-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: linear-gradient(135deg, #dc2626, #991b1b);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: bold;
        flex-shrink: 0;
    }

    .court-name {
        font-size: 20px;
        font-weight: bold;
        color: #111827;
    }

    .court-code {
        margin-top: 4px;
        color: #6b7280;
        font-size: 14px;
    }

    .note-box {
        background: #fef3c7;
        border: 1px solid #fde68a;
        color: #92400e;
        padding: 14px 16px;
        border-radius: 10px;
        margin-bottom: 20px;
        line-height: 1.5;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-bottom: 20px;
    }

    .info-item {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 14px;
        background: #ffffff;
    }

    .info-item-full {
        grid-column: 1 / span 2;
    }

    .info-label {
        font-size: 13px;
        font-weight: bold;
        color: #6b7280;
        margin-bottom: 6px;
        text-transform: uppercase;
    }

    .info-value {
        font-size: 16px;
        color: #111827;
        font-weight: 600;
        word-break: break-word;
        line-height: 1.5;
    }

    .badge-type,
    .badge-status {
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: bold;
        display: inline-block;
    }

    .type-vip {
        background: #fef3c7;
        color: #92400e;
    }

    .type-normal {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-free {
        background: #dcfce7;
        color: #166534;
    }

    .status-booked {
        background: #fef3c7;
        color: #92400e;
    }

    .status-playing {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-maintain {
        background: #e5e7eb;
        color: #374151;
    }

    .action-bar {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-delete-confirm {
        background: #dc2626;
        color: white;
        border: none;
        padding: 11px 18px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
    }

        .btn-delete-confirm:hover {
            background: #b91c1c;
        }

    .btn-back,
    .btn-detail {
        color: white !important;
        padding: 11px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        display: inline-block;
    }

    .btn-back {
        background: #6b7280;
    }

        .btn-back:hover {
            background: #4b5563;
            text-decoration: none;
            color: white;
        }

    .btn-detail {
        background: #0ea5e9;
    }

        .btn-detail:hover {
            background: #0284c7;
            text-decoration: none;
            color: white;
        }

    @@media(max-width: 700px) {
        .info-grid {
            grid-template-columns: 1fr;
        }

        .info-item-full {
            grid-column: 1;
        }

        .court-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .action-bar {
            justify-content: flex-start;
        }
    }
</style>

@{
    string tenLoaiSan = Model.LOAISAN != null ? Model.LOAISAN.TENLOAISAN : Model.MALOAISAN;

    string typeClass = "type-normal";
    if (!string.IsNullOrWhiteSpace(tenLoaiSan) && tenLoaiSan.ToLower().Contains("vip"))
    {
        typeClass = "type-vip";
    }

    string statusClass = "status-free";

    if (Model.TRANGTHAISAN == "Đang đặt")
    {
        statusClass = "status-booked";
    }
    else if (Model.TRANGTHAISAN == "Đang sử dụng")
    {
        statusClass = "status-playing";
    }
    else if (Model.TRANGTHAISAN == "Bảo trì")
    {
        statusClass = "status-maintain";
    }
}

<div class="delete-wrapper">
    <div class="delete-card">
        <div class="delete-warning">
            <div class="warning-icon">!</div>
            <div class="warning-text">
                <h3>Xác nhận xóa sân</h3>
                <p>Bạn có chắc chắn muốn xóa sân này không?</p>
            </div>
        </div>

        <div class="delete-body">
            <div class="court-head">
                <div class="court-circle">@Model.MASAN</div>
                <div>
                    <div class="court-name">@Model.TENSAN</div>
                    <div class="court-code">Mã sân: @Model.MASAN</div>
                </div>
            </div>

            <div class="note-box">
                Nếu sân đã có phiếu đặt sân liên quan thì hệ thống sẽ không xóa khỏi dữ liệu,
                mà chuyển sân sang trạng thái <strong>Bảo trì</strong> để tránh lỗi khóa ngoại.
            </div>

            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">Mã sân</div>
                    <div class="info-value">@Model.MASAN</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Tên sân</div>
                    <div class="info-value">@Model.TENSAN</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Loại sân</div>
                    <div class="info-value">
                        <span class="badge-type @typeClass">@tenLoaiSan</span>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">Trạng thái</div>
                    <div class="info-value">
                        <span class="badge-status @statusClass">@Model.TRANGTHAISAN</span>
                    </div>
                </div>

                <div class="info-item info-item-full">
                    <div class="info-label">Mô tả sân</div>
                    <div class="info-value">
                        @(string.IsNullOrWhiteSpace(Model.MOTASAN) ? "Không có mô tả." : Model.MOTASAN)
                    </div>
                </div>
            </div>

            @using (Html.BeginForm("Delete", "SAN65134364", new { id = Model.MASAN }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="action-bar">
                    @Html.ActionLink("Quay lại", "Index", "SAN65134364", null, new { @class = "btn-back" })

                    @Html.ActionLink("Chi tiết", "Details", "SAN65134364", new { id = Model.MASAN }, new { @class = "btn-detail" })

                    <button type="submit"
                            class="btn-delete-confirm"
                            onclick="return confirm('Xác nhận xóa sân @Model.TENSAN?');">
                        Xác nhận xóa
                    </button>
                </div>
            }
        </div>
    </div>
</div>