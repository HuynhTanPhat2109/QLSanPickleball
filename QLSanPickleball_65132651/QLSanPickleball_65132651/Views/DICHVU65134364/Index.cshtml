@using System
@using System.Linq
@model IEnumerable<QLSanPickleball_65132651.Models.DICHVU>

@{
    ViewBag.Title = "Quản lý dịch vụ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .page-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 12px;
        flex-wrap: wrap;
    }

        .page-head h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        margin-top: 4px;
        color: #6b7280;
        font-size: 14px;
    }

    .btn-create {
        background: #16a34a;
        color: white !important;
        padding: 11px 18px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 900;
        display: inline-block;
        box-shadow: 0 8px 18px rgba(22, 163, 74, 0.22);
    }

        .btn-create:hover {
            background: #15803d;
            text-decoration: none;
            color: white;
        }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-bottom: 18px;
    }

    .stat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
    }

    .stat-label {
        color: #6b7280;
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
    }

    .stat-value {
        margin-top: 8px;
        font-size: 28px;
        font-weight: 900;
        color: #111827;
    }

    .stat-green {
        color: #047857;
    }

    .stat-red {
        color: #dc2626;
    }

    .stat-blue {
        color: #2563eb;
    }

    .filter-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 18px;
        margin-bottom: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
    }

    .filter-row {
        display: grid;
        grid-template-columns: 2fr 1fr auto auto;
        gap: 12px;
        align-items: end;
    }

    .form-label {
        display: block;
        font-weight: 800;
        color: #374151;
        margin-bottom: 6px;
        font-size: 13px;
    }

    .form-control,
    .form-select {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        outline: none;
        background: white;
        font-size: 14px;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
        }

    .btn-filter,
    .btn-reset {
        border: none;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 900;
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-filter {
        background: #2563eb;
        color: white;
    }

        .btn-filter:hover {
            background: #1d4ed8;
        }

    .btn-reset {
        background: #6b7280;
        color: white !important;
    }

        .btn-reset:hover {
            background: #4b5563;
            text-decoration: none;
        }

    .alert-success-custom {
        background: #dcfce7;
        color: #166534;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #bbf7d0;
        font-weight: 800;
    }

    .alert-error-custom {
        background: #fee2e2;
        color: #991b1b;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #fecaca;
        font-weight: 800;
    }

    .service-list {
        display: grid;
        gap: 14px;
    }

    .service-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        padding: 18px;
        display: grid;
        grid-template-columns: 90px 1.5fr 1fr 1fr 1fr 210px;
        gap: 14px;
        align-items: center;
    }

    .service-avatar {
        width: 66px;
        height: 66px;
        border-radius: 18px;
        background: linear-gradient(135deg, #f59e0b, #b45309);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 16px;
        box-shadow: 0 8px 16px rgba(245, 158, 11, 0.25);
    }

    .main-text {
        font-size: 16px;
        font-weight: 900;
        color: #111827;
    }

    .sub-text {
        margin-top: 4px;
        font-size: 13px;
        color: #6b7280;
        line-height: 1.35;
    }

    .info-label {
        color: #6b7280;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .info-value {
        color: #111827;
        font-size: 15px;
        font-weight: 800;
    }

    .money {
        color: #047857;
        font-size: 18px;
        font-weight: 900;
    }

    .stock {
        font-size: 18px;
        font-weight: 900;
        color: #2563eb;
    }

    .badge-status {
        padding: 7px 11px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 900;
        display: inline-block;
        white-space: nowrap;
    }

    .status-active {
        background: #dcfce7;
        color: #166534;
    }

    .status-stop {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-other {
        background: #e5e7eb;
        color: #374151;
    }

    .action-box {
        display: flex;
        gap: 7px;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 8px 11px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 12px;
        color: white !important;
        display: inline-block;
        font-weight: 900;
        text-align: center;
        min-width: 66px;
    }

    .btn-detail {
        background: #0ea5e9;
    }

    .btn-edit {
        background: #f59e0b;
    }

    .btn-delete {
        background: #dc2626;
    }

    .btn-action:hover {
        opacity: 0.88;
        color: white;
        text-decoration: none;
        transform: translateY(-1px);
    }

    .empty-card {
        background: white;
        border: 1px dashed #cbd5e1;
        border-radius: 18px;
        padding: 38px;
        text-align: center;
        color: #64748b;
        font-weight: 800;
    }

    .pagination-wrap {
        margin-top: 20px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 14px 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.05);
    }

    .pagination-info {
        color: #6b7280;
        font-size: 14px;
        font-weight: 800;
    }

    .pagination-list {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .page-btn {
        min-width: 38px;
        height: 38px;
        padding: 0 12px;
        border-radius: 10px;
        border: 1px solid #d1d5db;
        background: #ffffff;
        color: #374151 !important;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 900;
        font-size: 13px;
    }

        .page-btn:hover {
            background: #eff6ff;
            border-color: #2563eb;
            color: #1d4ed8 !important;
            text-decoration: none;
        }

        .page-btn.active {
            background: #2563eb;
            border-color: #2563eb;
            color: white !important;
        }

        .page-btn.disabled {
            opacity: 0.45;
            pointer-events: none;
            cursor: not-allowed;
        }

    @@media(max-width: 1150px) {
        .stat-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .service-card {
            grid-template-columns: 80px 1.5fr 1fr;
        }

        .action-box {
            grid-column: 1 / span 3;
            justify-content: flex-start;
            border-top: 1px solid #e5e7eb;
            padding-top: 12px;
        }
    }

    @@media(max-width: 800px) {
        .filter-row {
            grid-template-columns: 1fr;
        }

        .service-card {
            grid-template-columns: 1fr;
        }

        .action-box {
            grid-column: auto;
        }
    }

    @@media(max-width: 600px) {
        .stat-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-head">
    <div>
        <div class="page-sub">Quản lý nước uống, thuê vợt, bóng và các dịch vụ đi kèm sân.</div>
    </div>

    @Html.ActionLink("Thêm dịch vụ", "Create", "DICHVU65134364", null, new { @class = "btn-create" })
</div>

@if (TempData["Success"] != null)
{
    <div class="alert-success-custom">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-error-custom">@TempData["Error"]</div>
}

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Tổng dịch vụ</div>
        <div class="stat-value">@ViewBag.TongDichVu</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Đang kinh doanh</div>
        <div class="stat-value stat-green">@ViewBag.DangKinhDoanh</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Ngừng kinh doanh</div>
        <div class="stat-value stat-red">@ViewBag.NgungKinhDoanh</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Tổng tồn kho</div>
        <div class="stat-value stat-blue">@ViewBag.TongTonKho</div>
    </div>
</div>

<div class="filter-card">
    @using (Html.BeginForm("Index", "DICHVU65134364", FormMethod.Get))
    {
        <input type="hidden" name="page" value="1" />

        <div class="filter-row">
            <div>
                <label class="form-label">Tìm kiếm</label>
                <input type="text"
                       name="search"
                       class="form-control"
                       value="@ViewBag.Search"
                       placeholder="Nhập mã dịch vụ, tên dịch vụ, đơn vị tính..." />
            </div>

            <div>
                <label class="form-label">Trạng thái</label>
                <select name="trangThai" class="form-select">
                    <option value="">-- Tất cả --</option>
                    <option value="Đang kinh doanh" @(ViewBag.TrangThai == "Đang kinh doanh" ? "selected" : "")>Đang kinh doanh</option>
                    <option value="Ngừng kinh doanh" @(ViewBag.TrangThai == "Ngừng kinh doanh" ? "selected" : "")>Ngừng kinh doanh</option>
                </select>
            </div>

            <div>
                <button type="submit" class="btn-filter">Lọc</button>
            </div>

            <div>
                @Html.ActionLink("Làm mới", "Index", "DICHVU65134364", null, new { @class = "btn-reset" })
            </div>
        </div>
    }
</div>

<div class="service-list">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            string statusClass = "status-other";

            if (item.TRANGTHAIKD == "Đang kinh doanh")
            {
                statusClass = "status-active";
            }
            else if (item.TRANGTHAIKD == "Ngừng kinh doanh")
            {
                statusClass = "status-stop";
            }

            <div class="service-card">
                <div>
                    <div class="service-avatar">@item.MADV</div>
                </div>

                <div>
                    <div class="main-text">@item.TENDV</div>
                    <div class="sub-text">Mã dịch vụ: @item.MADV</div>
                </div>

                <div>
                    <div class="info-label">Đơn vị tính</div>
                    <div class="info-value">@item.DONVITINH</div>
                </div>

                <div>
                    <div class="info-label">Đơn giá</div>
                    <div class="money">@item.DONGIA.ToString("N0") đ</div>
                </div>

                <div>
                    <div class="info-label">Tồn kho</div>
                    <div class="stock">@item.SOLUONGTON</div>
                    <div class="sub-text">
                        <span class="badge-status @statusClass">@item.TRANGTHAIKD</span>
                    </div>
                </div>

                <div class="action-box">
                    @Html.ActionLink("Chi tiết", "Details", "DICHVU65134364", new { id = item.MADV }, new { @class = "btn-action btn-detail" })
                    @Html.ActionLink("Sửa", "Edit", "DICHVU65134364", new { id = item.MADV }, new { @class = "btn-action btn-edit" })
                    @Html.ActionLink("Xóa", "Delete", "DICHVU65134364", new { id = item.MADV }, new { @class = "btn-action btn-delete" })
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-card">
            Không tìm thấy dịch vụ nào.
        </div>
    }
</div>

@{
    int currentPage = ViewBag.CurrentPage == null ? 1 : (int)ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages == null ? 1 : (int)ViewBag.TotalPages;
    int pageSize = ViewBag.PageSize == null ? 10 : (int)ViewBag.PageSize;
    int totalItems = ViewBag.TotalItems == null ? 0 : (int)ViewBag.TotalItems;

    int fromItem = totalItems == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    int toItem = currentPage * pageSize;

    if (toItem > totalItems)
    {
        toItem = totalItems;
    }

    int startPage = currentPage - 2;
    int endPage = currentPage + 2;

    if (startPage < 1)
    {
        startPage = 1;
    }

    if (endPage > totalPages)
    {
        endPage = totalPages;
    }
}

@if (totalItems > 0)
{
    <div class="pagination-wrap">
        <div class="pagination-info">
            Hiển thị @fromItem - @toItem / @totalItems dịch vụ
        </div>

        <div class="pagination-list">
            @Html.ActionLink("Trước", "Index", "DICHVU65134364",
                new
                {
                    page = currentPage - 1,
                    search = ViewBag.Search,
                    trangThai = ViewBag.TrangThai
                },
                new
                {
                    @class = currentPage <= 1 ? "page-btn disabled" : "page-btn"
                })

            @if (startPage > 1)
            {
                @Html.ActionLink("1", "Index", "DICHVU65134364",
                    new
                    {
                        page = 1,
                        search = ViewBag.Search,
                        trangThai = ViewBag.TrangThai
                    },
                    new { @class = "page-btn" })

                if (startPage > 2)
                {
                    <span class="page-btn disabled">...</span>
                }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                @Html.ActionLink(i.ToString(), "Index", "DICHVU65134364",
                    new
                    {
                        page = i,
                        search = ViewBag.Search,
                        trangThai = ViewBag.TrangThai
                    },
                    new
                    {
                        @class = i == currentPage ? "page-btn active" : "page-btn"
                    })
            }

            @if (endPage < totalPages)
            {
                if (endPage < totalPages - 1)
                {
                    <span class="page-btn disabled">...</span>
                }

                @Html.ActionLink(totalPages.ToString(), "Index", "DICHVU65134364",
                    new
                    {
                        page = totalPages,
                        search = ViewBag.Search,
                        trangThai = ViewBag.TrangThai
                    },
                    new { @class = "page-btn" })
            }

            @Html.ActionLink("Sau", "Index", "DICHVU65134364",
                new
                {
                    page = currentPage + 1,
                    search = ViewBag.Search,
                    trangThai = ViewBag.TrangThai
                },
                new
                {
                    @class = currentPage >= totalPages ? "page-btn disabled" : "page-btn"
                })
        </div>
    </div>
}