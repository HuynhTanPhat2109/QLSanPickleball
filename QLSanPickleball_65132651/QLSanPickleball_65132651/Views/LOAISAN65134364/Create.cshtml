@model QLSanPickleball_65132651.Models.LOAISAN

@{
    ViewBag.Title = "Thêm loại sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .form-wrapper {
        max-width: 760px;
        margin: 0 auto;
    }

    .page-head {
        margin-bottom: 18px;
    }

        .page-head h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        margin-top: 6px;
        color: #6b7280;
        font-size: 14px;
    }

    .form-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 22px;
        padding: 24px;
        box-shadow: 0 12px 28px rgba(15,23,42,0.08);
    }

    .form-group {
        margin-bottom: 18px;
    }

    .control-label {
        display: block;
        font-weight: 900;
        color: #374151;
        margin-bottom: 7px;
    }

    .form-control {
        width: 100%;
        padding: 12px 13px;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        outline: none;
        background: white;
        font-size: 14px;
    }

    .text-danger {
        color: #dc2626;
        font-weight: 700;
    }

    .btn-row {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 24px;
        flex-wrap: wrap;
    }

    .btn-save,
    .btn-back {
        border: none;
        padding: 11px 18px;
        border-radius: 12px;
        font-weight: 900;
        color: white !important;
        text-decoration: none;
        display: inline-block;
    }

    .btn-save {
        background: #16a34a;
    }

    .btn-back {
        background: #6b7280;
    }

        .btn-save:hover,
        .btn-back:hover {
            opacity: 0.88;
            color: white;
            text-decoration: none;
        }
</style>

<div class="form-wrapper">
    <div class="page-head">
        <div class="page-sub">Tạo loại sân để phân nhóm sân và áp dụng bảng giá.</div>
    </div>

    <div class="form-card">
        @using (Html.BeginForm("Create", "LOAISAN65134364", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-group">
                @Html.LabelFor(model => model.MALOAISAN, "Mã loại sân", new { @class = "control-label" })
                @Html.TextBoxFor(model => model.MALOAISAN, new { @class = "form-control", @readonly = "readonly" })
                @Html.ValidationMessageFor(model => model.MALOAISAN, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(model => model.TENLOAISAN, "Tên loại sân", new { @class = "control-label" })
                @Html.TextBoxFor(model => model.TENLOAISAN, new { @class = "form-control", placeholder = "Ví dụ: Sân thường, Sân VIP..." })
                @Html.ValidationMessageFor(model => model.TENLOAISAN, "", new { @class = "text-danger" })
            </div>

            <div class="btn-row">
                @Html.ActionLink("Quay lại", "Index", "LOAISAN65134364", null, new { @class = "btn-back" })
                <button type="submit" class="btn-save">Lưu loại sân</button>
            </div>
        }
    </div>
</div>