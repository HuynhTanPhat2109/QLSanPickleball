@model IEnumerable<QLSanPickleball_65132651.Models.LOAISAN>

@{
    ViewBag.Title = "Quản lý loại sân";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";

    bool duocThemSuaXoa = ViewBag.DuocThemSuaXoa != null && (bool)ViewBag.DuocThemSuaXoa;
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 12px;
        flex-wrap: wrap;
    }

        .page-header h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            color: #111827;
        }

    .page-sub {
        margin-top: 5px;
        color: #6b7280;
        font-size: 14px;
    }

    .btn-add {
        background: #2563eb;
        color: white !important;
        padding: 11px 17px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 900;
        display: inline-block;
    }

        .btn-add:hover {
            background: #1d4ed8;
            text-decoration: none;
            color: white;
        }

    .alert-success-custom {
        background: #dcfce7;
        color: #166534;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #bbf7d0;
        font-weight: 800;
    }

    .alert-error-custom {
        background: #fee2e2;
        color: #991b1b;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #fecaca;
        font-weight: 800;
    }

    .filter-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 18px;
        box-shadow: 0 10px 25px rgba(15,23,42,0.06);
    }

    .filter-row {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 12px;
        align-items: end;
    }

    .form-label {
        font-weight: 900;
        color: #374151;
        margin-bottom: 6px;
        display: block;
        font-size: 13px;
    }

    .form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        outline: none;
        background: white;
    }

    .btn-search {
        background: #16a34a;
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 900;
        cursor: pointer;
    }

    .btn-reset {
        display: inline-block;
        background: #6b7280;
        color: white !important;
        padding: 10px 16px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 900;
    }

    .type-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .type-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(15,23,42,0.06);
    }

    .type-top {
        display: flex;
        align-items: center;
        gap: 13px;
        margin-bottom: 14px;
    }

    .type-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        background: linear-gradient(135deg, #2563eb, #1e40af);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        flex-shrink: 0;
    }

    .type-title {
        font-size: 18px;
        font-weight: 900;
        color: #111827;
    }

    .type-code {
        margin-top: 4px;
        color: #6b7280;
        font-size: 13px;
        font-weight: 800;
    }

    .type-desc {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 12px;
        color: #374151;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .action-group {
        display: flex;
        gap: 7px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 8px 11px;
        border-radius: 9px;
        text-decoration: none;
        font-size: 13px;
        color: white !important;
        display: inline-block;
        font-weight: 900;
    }

    .btn-detail {
        background: #0ea5e9;
    }

    .btn-edit {
        background: #f59e0b;
    }

    .btn-delete {
        background: #dc2626;
    }

    .btn-action:hover,
    .btn-reset:hover {
        opacity: 0.88;
        text-decoration: none;
        color: white;
    }

    .empty-card {
        background: white;
        border: 1px dashed #cbd5e1;
        border-radius: 18px;
        padding: 38px;
        text-align: center;
        color: #64748b;
        font-weight: 800;
    }

    @@media(max-width: 1100px) {
        .type-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(max-width: 700px) {
        .type-grid,
        .filter-row {
            grid-template-columns: 1fr;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="page-header">
    <div>
        <div class="page-sub">Quản lý các nhóm loại sân như sân thường, sân VIP để dùng cho sân và bảng giá.</div>
    </div>

    @if (duocThemSuaXoa)
    {
        @Html.ActionLink("+ Thêm loại sân", "Create", "LOAISAN65134364", null, new { @class = "btn-add" })
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert-success-custom">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-error-custom">@TempData["Error"]</div>
}

<div class="filter-card">
    @using (Html.BeginForm("Index", "LOAISAN65134364", FormMethod.Get))
    {
        <div class="filter-row">
            <div>
                <label class="form-label">Tìm kiếm</label>
                <input type="text"
                       name="search"
                       class="form-control"
                       value="@ViewBag.Search"
                       placeholder="Nhập mã loại sân hoặc tên loại sân..." />
            </div>

            <div>
                <button type="submit" class="btn-search">Lọc</button>
            </div>

            <div>
                @Html.ActionLink("Làm mới", "Index", "LOAISAN65134364", null, new { @class = "btn-reset" })
            </div>
        </div>
    }
</div>

@if (Model != null && Model.Any())
{
    <div class="type-grid">
        @foreach (var item in Model)
        {
            string tenLoai = item.TENLOAISAN ?? "";

            <div class="type-card">
                <div class="type-top">
                    <div class="type-icon">@item.MALOAISAN</div>

                    <div>
                        <div class="type-title">@item.TENLOAISAN</div>
                        <div class="type-code">Mã loại: @item.MALOAISAN</div>
                    </div>
                </div>

                <div class="type-desc">
                    Loại sân dùng để phân nhóm sân và áp dụng bảng giá tương ứng.
                </div>

                <div class="action-group">
                    @Html.ActionLink("Chi tiết", "Details", "LOAISAN65134364", new { id = item.MALOAISAN }, new { @class = "btn-action btn-detail" })

                    @if (duocThemSuaXoa)
                    {
                        @Html.ActionLink("Sửa", "Edit", "LOAISAN65134364", new { id = item.MALOAISAN }, new { @class = "btn-action btn-edit" })

                        @Html.ActionLink("Xóa", "Delete", "LOAISAN65134364", new { id = item.MALOAISAN }, new { @class = "btn-action btn-delete" })
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-card">Không tìm thấy loại sân nào.</div>
}